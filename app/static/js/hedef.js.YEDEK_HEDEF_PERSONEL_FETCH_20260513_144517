function reddetOnayla() {
    if (!_aktifReddetId) return;
    var ta = document.getElementById('reddetNot');
    var notu = ta ? ta.value.trim() : '';

    if (!notu) {
        _showElem('reddetNotError', 'Reddetme nedeni zorunlu - lÃ¼tfen sebep yaz.', 5000);
        if (ta) ta.focus();
        return;
    }
    if (notu.length < 5) {
        _showElem('reddetNotError', 'En az 5 karakter girmelisin.', 5000);
        return;
    }

    var btn = document.getElementById('reddetOnaylaBtn');
    if (btn) { btn.disabled = true; btn.textContent = 'Reddediliyor...'; }

    _ustaApi("/api/v2/usta/onay", {
        method: "POST",
        body: JSON.stringify({
            uretim_kayit_id: _aktifReddetId,
            karar: "reddet",
            not: notu
        })
    })
    .then(function (r) {
        if (btn) { btn.disabled = false; btn.textContent = 'REDDET'; }
        if (r.status >= 400 || (r.data && r.data.ok === false)) {
            _showElem('reddetNotError', r.data.mesaj || ('HTTP ' + r.status), 5000);
            return;
        }
        reddetModalKapat();
        _showElem('onaySuccess', 'KayÄ±t reddedildi.', 4000);
        _onayYuklendi = false;
        _gecmisYuklendi = false;
        onaylariYukle();
