                        _esc(p.proses_adi || p.proses_kod) +
                        ' <span style="font-size:10px;color:#9ca3af;font-weight:400;">[' +
                        _esc(p.proses_kod) + ']</span></span>' +
                        '<span class="pdi-rozet" style="background:' + rozetRenk +
                        ';">' + (aktif ? 'AKTİF' : (p.durum || '').toUpperCase()) +
