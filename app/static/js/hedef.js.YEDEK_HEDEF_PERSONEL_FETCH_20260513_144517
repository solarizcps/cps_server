            }
            html += '<div class="' + cls + '">' +
                '<div class="pdp-proses-head">' +
                    '<span class="pdp-proses-ikon" style="background:' + ikonBg +
                    ';color:' + ikonRenk + ';">' + ikonText + '</span>' +
