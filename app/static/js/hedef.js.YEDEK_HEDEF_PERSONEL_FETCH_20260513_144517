        head.innerHTML = '<img src="' + DEFAULT_IKON + '" alt="">' +
            '<div class="pdp-info">' +
                '<div class="pdp-emir">E.' + _esc(d.emir_no) + '</div>' +
                '<div class="pdp-model" title="' + _esc(d.model_adi || d.model_kod || '') + '">' +
