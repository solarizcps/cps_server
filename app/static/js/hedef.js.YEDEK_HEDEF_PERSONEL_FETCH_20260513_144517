// ============== HELPERS (USTA) ==============

function _ustaApi(path, options) {
    options = options || {};
    options.headers = options.headers || {};
    options.headers["Authorization"] = "Bearer " + DEV_TOKEN;
    options.headers["Content-Type"] = "application/json";
    return fetch(MES_BASE + path, options).then(function (resp) {
        return resp.text().then(function (t) {
            var data;
            try { data = t ? JSON.parse(t) : {}; }
            catch (e) { data = { ok: false, hata: "parse_hatasi", mesaj: t.slice(0, 200) }; }
            return { status: resp.status, data: data };
        });
    });
}

function _showElem(id, msg, ms) {
    var el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg;
    el.style.display = "block";
    if (ms && ms > 0) {
        setTimeout(function () { el.style.display = "none"; }, ms);
    }
}

function _ustaEscape(s) {
    if (s === null || s === undefined) return "";
    return String(s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
}

function _ustaFmtTarih(t, s) {
    if (!t && !s) return "-";
    return (t || "") + (s ? " " + s : "");
}


