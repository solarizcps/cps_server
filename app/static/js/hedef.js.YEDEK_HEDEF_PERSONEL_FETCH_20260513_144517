var _raporYuklendi = false;

async function raporlariYukle(force) {
    if (_raporYuklendi && !force) return;  // tek seferlik yukle, performans
    var body = document.getElementById("raporBody");
    if (body) {
        body.innerHTML = "<tr class=\"h-row-loading\"><td colspan=\"12\"><span class=\"h-loading\">Yukleniyor...</span></td></tr>";
    }
    try {
        var url = MES_BASE + "/api/v2/hedef/rapor/liste?limit=500";
        var inpBas = document.getElementById("raporTarihBas");
        var inpBit = document.getElementById("raporTarihBit");
        if (inpBas && inpBas.value && inpBit && inpBit.value) {
            url += "&tarih_bas=" + inpBas.value + "&tarih_bit=" + inpBit.value;
        }
        var resp = await fetch(url, {
            method: "GET",
            headers: {
                "Authorization": "Bearer " + DEV_TOKEN,
                "Content-Type": "application/json"
            }
        });
        var data = await resp.json();
        console.log("RAPOR_LISTE", resp.status, data);
        if (resp.status >= 400 || (data && data.ok === false)) {
            if (body) body.innerHTML = "";
            var msg = (data && (data.mesaj || data.hata)) || ("HTTP " + resp.status);
            var errBox = document.getElementById("raporError");
            if (errBox) errBox.innerHTML = '<div class="h-error"><strong>Hata: </strong>' + msg + '</div>';
            return;
        }
        var rows = data.veriler || data.rows || [];
        renderRaporRows(rows);
        _raporYuklendi = true;
    } catch (e) {
        console.error("RAPOR FETCH:", e);
        if (body) body.innerHTML = "";
        var errBox2 = document.getElementById("raporError");
        if (errBox2) errBox2.innerHTML = '<div class="h-error"><strong>Hata: </strong>Sunucuya ulasilamadi: ' + e.message + '</div>';
    }
}

