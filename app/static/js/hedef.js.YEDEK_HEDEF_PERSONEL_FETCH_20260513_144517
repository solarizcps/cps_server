})();


/* === FAZ 4.8 F2.2: PLAN tablosu darbogaz lazy load === */
(function () {
    if (window._planDarbogazF22Yuklendi) return;
    window._planDarbogazF22Yuklendi = true;

    function _f22Fmt(n) {
        if (n === null || n === undefined || n === "") return "0";
        var x = Number(n);
        if (!isFinite(x)) return "0";
        return Math.round(x).toLocaleString("tr-TR");
    }

    function _f22FmtPct(n) {
        if (n === null || n === undefined) return "0%";
        var x = Number(n);
        if (!isFinite(x)) return "0%";
        return x.toLocaleString("tr-TR", { maximumFractionDigits: 1 }) + "%";
    }

    /* Header text ile sutun indeksini bul (DEBUG + contains) */
    function _f22Norm(s) {
        return (s || "")
            .toString()
            .toUpperCase()
            .replace(/İ/g, "I")
            .replace(/ı/g, "I")
            .replace(/Ü/g, "U").replace(/ü/g, "U")
            .replace(/Ş/g, "S").replace(/ş/g, "S")
            .replace(/Ö/g, "O").replace(/ö/g, "O")
            .replace(/Ç/g, "C").replace(/ç/g, "C")
            .replace(/Ğ/g, "G").replace(/ğ/g, "G")
            .trim();
    }

    function _f22SutunIndeksleri(table) {
        var thead = table.querySelector("thead tr");
        if (!thead) return null;
        var ths = thead.querySelectorAll("th");
        var headerRaw = [];
        var headerNorm = [];
        for (var j = 0; j < ths.length; j++) {
            headerRaw.push((ths[j].textContent || "").trim());
            headerNorm.push(_f22Norm(ths[j].textContent));
        }
        var idx = { yapilan: -1, kalan: -1, yuzde: -1, emir: -1 };
        for (var i = 0; i < headerNorm.length; i++) {
            var t = headerNorm[i];
            if (idx.yapilan < 0 && t.indexOf("YAPIL") >= 0) idx.yapilan = i;
            if (idx.kalan < 0 && t.indexOf("KALAN") >= 0) idx.kalan = i;
            if (idx.yuzde < 0 && (t.indexOf("%") >= 0 || t.indexOf("YUZDE") >= 0)) idx.yuzde = i;
            if (idx.emir < 0 && t.indexOf("EMIR") >= 0) idx.emir = i;
        }
        return idx;
    }

    /* F2.2 EX FIX */
    /* Bir TR icindeki emir_no'yu cikart - SADECE ilk hucreden, EMIR sutunu */
    function _f22EmirNoBul(tr, emirIdx) {
        var en = null;

        // Fallback 1: data-emir-no veya data-emir
        var v = tr.getAttribute("data-emir-no") || tr.getAttribute("data-emir");
        if (v) {
            var d = String(v).replace(/\D/g, "");
            if (d && /^\d{4,8}$/.test(d)) en = d;
        }

        // Fallback 2: EMIR sutunundan "E.XXXXX" pattern (sadece o hucre)
        if (!en && emirIdx >= 0) {
            var cells = tr.querySelectorAll("td");
            if (cells.length > emirIdx) {
                var celTxt = cells[emirIdx].textContent || "";
                var m = celTxt.match(/E\.?(\d+)/);
                if (m && m[1]) en = m[1];
                else {
                    var d2 = celTxt.replace(/\D/g, "");
                    if (d2 && /^\d{4,8}$/.test(d2)) en = d2;
                }
            }
        }

        // Fallback 3: Tum TR icinde "E.XXXXX" pattern (sadece bir tane)
        if (!en) {
            var txt = tr.textContent || "";
            var m3 = txt.match(/E\.?(\d{4,8})/);
            if (m3 && m3[1]) en = m3[1];
        }

        // Sadece 4-8 hane kabul (emir no genelde 6 hane)
        if (en && /^\d{4,8}$/.test(en)) return en;
        return null;
    }

    /* PLAN tablosunu bul ve darbogaz cek (single-run garantili) */
    function _f22Calistir() {
        if (window._f22RanOnce) return;
        var planBody = document.getElementById("planBody");
        if (!planBody) return;
        var table = planBody.closest("table");
        if (!table) return;

        var idx = _f22SutunIndeksleri(table);
        if (!idx) return;
        if (idx.yapilan < 0 && idx.kalan < 0 && idx.yuzde < 0) return;

        /* Detay satirlarini ATLA, sadece ana data satirlari */
        var rows = planBody.querySelectorAll("tr");
        var emirToTr = {};
        var emirler = [];
        for (var i = 0; i < rows.length; i++) {
            var tr = rows[i];
            if (tr.classList.contains("plan-detay-mini")) continue;
            if (tr.classList.contains("plan-detay-row")) continue;
            var en = _f22EmirNoBul(tr, idx.emir);
            if (!en) continue;
            if (!emirToTr[en]) {
                emirToTr[en] = tr;
                emirler.push(en);
            }
        }

        // Dedupe
        emirler = Array.from(new Set(emirler));
        if (!emirler.length) return;
        if (emirler.length > 100) emirler = emirler.slice(0, 100);

        // Loading guard - cift fetch engelle
        if (window._f22Loading) return;
        window._f22Loading = true;

        var url = "/hedef/plan-darbogaz?emirler=" + encodeURIComponent(emirler.join(",")) + "&_f22cb=" + Date.now();
        fetch(url, {
            credentials: "same-origin",
            headers: { "Accept": "application/json" }
        }).then(function (r) {
            if (!r.ok) throw new Error("HTTP " + r.status);
            return r.json();
        }).then(function (data) {
            if (!data || !data.ok || !data.darbogaz) return; /* sessiz fallback */
            var d = data.darbogaz;
            window._f22RanOnce = true;
            for (var k in d) {
                if (!Object.prototype.hasOwnProperty.call(d, k)) continue;
                var tr2 = emirToTr[k];
                if (!tr2) continue;
                if (tr2.getAttribute("data-f22-done")) continue;
                var v = d[k];
                if (!v) continue;
                if (v.yapilan_darbogaz === null || v.yapilan_darbogaz === undefined) continue;
                var cells = tr2.querySelectorAll("td");
                if (!cells || cells.length < 8) continue;
                if (idx.yapilan >= 0 && cells.length > idx.yapilan) {
                    cells[idx.yapilan].textContent = _f22Fmt(v.yapilan_darbogaz);
                }
                if (idx.kalan >= 0 && cells.length > idx.kalan) {
                    cells[idx.kalan].textContent = _f22Fmt(v.kalan_darbogaz);
                }
                if (idx.yuzde >= 0 && cells.length > idx.yuzde) {
                    var yc = cells[idx.yuzde];
                    var pill = yc.querySelector(".pill, .badge, span");
                    if (pill) {
                        pill.textContent = _f22FmtPct(v.yuzde_darbogaz);
                    } else {
                        yc.textContent = _f22FmtPct(v.yuzde_darbogaz);
                    }
                }
                tr2.setAttribute("data-f22-done", "1"); /* FAZ 4.9 LOGCLEAN */
            }
        }).catch(function (err) {
            /* Sessiz fallback - eski degerler kalir */
        }).finally(function () {
            window._f22Loading = false;
        });
    }

    /* PLAN tablosu render edildikten sonra calis. */
    /* renderPlanRows mevcut JS'de override edilmis (V3/V4 IIFE). En son override'in ustune sarmalayalim. */
    function _f22Sar() {
        if (typeof window.renderPlanRows === "function" && !window._origRenderRowsF22) {
            window._origRenderRowsF22 = window.renderPlanRows;
            window.renderPlanRows = function (emirler) {
                var sonuc = window._origRenderRowsF22.apply(this, arguments);
                /* Render bittikten sonra darbogaz cek */
                setTimeout(_f22Calistir, 50);
                return sonuc;
            };
        }
    }

    /* DOMContentLoaded sonrasi sarma */
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function () {
            _f22Sar();
            /* Tablo zaten doluysa hemen calistir */
            setTimeout(_f22Calistir, 100);
        });
    } else {
        _f22Sar();
        setTimeout(_f22Calistir, 100);
    }

    /* F2.2 ZORLA TETIK: 6 kez 1 sn arayla dene, sonra durdur */
    var _f22ZorlaTetik = 0;
    function _f22ZorlaCalistir() {
        try {
            var pb = document.getElementById("planBody");
            if (pb) {
                var rows = pb.querySelectorAll("tr");
                var dolu = 0;
                for (var i = 0; i < rows.length; i++) {
                    var tr = rows[i];
                    if (tr.classList.contains("plan-detay-mini")) continue;
                    if (tr.classList.contains("plan-detay-row")) continue;
                    if ((tr.textContent || "").match(/E\.\d+/)) dolu++;
                }
                if (dolu > 0) {
                    if (typeof _f22BaslatGozlem === "function") _f22BaslatGozlem();
                    _f22Calistir();
                    _f22ZorlaTetik = 99;
                    return;
                }
            }
        } catch (e) {}
        _f22ZorlaTetik++;
        if (_f22ZorlaTetik < 6) {
            setTimeout(_f22ZorlaCalistir, 1000);
        }
    }
    setTimeout(_f22ZorlaCalistir, 1500);

    console.log("[CPS LOCAL] PLAN darbogaz F2.2 yuklendi");
})();
