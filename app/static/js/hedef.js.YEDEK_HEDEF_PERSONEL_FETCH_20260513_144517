    })
    .catch(function (e) {
        if (btn) { btn.disabled = false; btn.textContent = 'REDDET'; }
        console.error("reddet fetch:", e);
        _showElem('reddetNotError', 'Sunucuya ulaÃ…Å¸Ä±lamadÄ±: ' + e.message, 5000);
