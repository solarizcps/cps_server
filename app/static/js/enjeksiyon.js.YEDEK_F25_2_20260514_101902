/* enjeksiyon.js - FAZ 6.6
   Makine sekme toggle (client-side) + URL state. */
(function () {
    'use strict';

    function makineDegistir(mid) {
        document.querySelectorAll('.enj-mak-kart').forEach(function (k) {
            k.classList.toggle('aktif', k.dataset.makineId === mid);
        });
        document.querySelectorAll('.enj-mak-panel').forEach(function (p) {
            p.classList.toggle('aktif', p.dataset.makineId === mid);
        });
        try {
            var url = new URL(window.location);
            url.searchParams.set('makine', mid);
            window.history.replaceState({}, '', url);
        } catch (e) { /* IE / eski tarayici fallback */ }
    }

    function abToggle(btn) {
        btn.classList.toggle('on');
        // F7'de POST API cagrilacak. F6.6 client-only.
    }

    function topluUygula(makinePanel, action) {
        var slots = makinePanel.querySelectorAll('.enj-ist-cell .s');
        slots.forEach(function (s) {
            if (action === 'a' && s.dataset.slot === 'A') s.classList.add('on');
            else if (action === 'b' && s.dataset.slot === 'B') s.classList.add('on');
            else if (action === 'x') s.classList.remove('on');
        });
    }

    document.addEventListener('click', function (e) {
        var mak = e.target.closest('.enj-mak-kart');
        if (mak) { e.preventDefault(); makineDegistir(mak.dataset.makineId); return; }

        var slot = e.target.closest('.enj-ist-cell .s');
        if (slot) { e.preventDefault(); abToggle(slot); return; }

        var toplu = e.target.closest('[data-toplu]');
        if (toplu) {
            e.preventDefault();
            var panel = toplu.closest('.enj-mak-panel');
            if (panel) topluUygula(panel, toplu.dataset.toplu);
            return;
        }
    });

    console.log('[CPS LOCAL] enjeksiyon.js F6.6 yuklendi');
})();
