    /**
     * Secili kalemler + toplam tutar alt bar mesajini gunceller.
     * Hem parser satirlari hem manuel eklenen satirlari dahil eder.
     */
    _oneriToplamGuncelle: function () {
      var toplamDiv = document.getElementById('cps-ith-onay-oneri-toplam');
      if (!toplamDiv) return;
      var trler = document.querySelectorAll('.cps-ith-onay-oneri-tbl tbody tr');
      var secili = 0;
      var manuelSayi = 0;
      var paraToplam = {};  // {TRY: 1234, USD: 500}
      trler.forEach(function (tr) {
        var cb = tr.querySelector('.cps-ith-onay-oneri-cb');
        if (!cb || !cb.checked) return;
        var tutarIn = tr.querySelector('.cps-ith-onay-oneri-tutar-input');
        var tutar = parseFloat(tutarIn.value) || 0;
        // Para birimi: class bazli (manuel/parser fark etmez)
        var paraSel = tr.querySelector('.cps-ith-onay-oneri-para');
        var para = paraSel ? paraSel.value : 'TRY';
        if (tutar <= 0) return;
        secili++;
        if (tr.dataset.manuel === 'true') manuelSayi++;
        paraToplam[para] = (paraToplam[para] || 0) + tutar;
      });

      if (secili === 0) {
        toplamDiv.innerHTML = '<em>Hiçbir kalem seçili değil</em>';
      } else {
        var parts = [];
        Object.keys(paraToplam).sort().forEach(function (p) {
          parts.push('<strong>' + paraToplam[p].toLocaleString('tr-TR', {
            minimumFractionDigits: 2, maximumFractionDigits: 2
          }) + '</strong> ' + p);
        });
        var manuelEk = manuelSayi > 0 ? ' (' + manuelSayi + ' manuel)' : '';
        toplamDiv.innerHTML = '<span class="cps-ith-onay-oneri-toplam-label">' +
          'Seçili: ' + secili + ' kalem' + manuelEk + ' · Toplam: </span>' +
          parts.join(' · ');
      }
    },

    /**
     * Alt bardaki "Uygula" butonunu mode'a göre ayarla.
     *   duplicate=true, oneriMod=false  -> "Override ile Uygula" kirmizi
     *   duplicate=true, oneriMod=true   -> "Override: Seçilenleri Uygula" kirmizi
     *   duplicate=false, oneriMod=false -> "Onayla ve Uygula" mavi
     *   duplicate=false, oneriMod=true  -> "Seçilenleri Maliyete Ekle" mavi
     */
    _altBarAyarla: function (duplicate, oneriMod) {
      var btn = $('cps-ith-onay-uygula');
      if (!btn) return;
      var metin = btn.querySelector('.cps-ith-btn-metin');
      var dst = $('cps-ith-onay-durum');

      btn.disabled = false;
      btn.classList.remove('cps-ith-btn-primary', 'cps-ith-btn-tehlike',
                           'cps-ith-onay-override-btn');
      if (dst) {
        dst.textContent = '';
        dst.className = 'cps-ith-kayit-durum';
      }

      if (duplicate) {
        btn.classList.add('cps-ith-btn-tehlike', 'cps-ith-onay-override-btn');
        if (metin) {
          metin.textContent = oneriMod ?
            '🔄 Override: Seçilenleri Uygula' :
            '🔄 Override ile Uygula';
        }
        btn.dataset.mode = oneriMod ? 'override-oneri' : 'override';
      } else {
        btn.classList.add('cps-ith-btn-primary');
        if (metin) {
          metin.textContent = oneriMod ?
            'Seçilenleri Maliyete Ekle ▶' :
            'Onayla ve Uygula ▶';
        }
        btn.dataset.mode = oneriMod ? 'oneri' : 'normal';
      }
    },

    /**
     * Duplicate durumunda gösterilen üst uyarı kutusu.
     * Açıklama: "Eski maliyet kalemleri iptal edilir, yenileri yazılır..."
     */
    _duplicateKutusu: function (veri) {
      var d = document.createElement('div');
      d.className = 'cps-ith-onay-duplicate-box';

      var ref = veri.kaynak_ref || '—';
      var existing = veri.existing_ref || {};

      var baslik = document.createElement('div');
      baslik.className = 'cps-ith-onay-duplicate-baslik';
      baslik.innerHTML = '⚠ Bu referans zaten işlenmiş: <strong>' + ref + '</strong>';
      d.appendChild(baslik);

      if (existing && existing.onceki_kalem_sayisi) {
        var bilgi = document.createElement('div');
        bilgi.className = 'cps-ith-onay-duplicate-metin';
        var parcalar = [];
        if (existing.onceki_kalem_sayisi) {
          parcalar.push('Mevcut kalem sayısı: <strong>' +
                        existing.onceki_kalem_sayisi + '</strong>');
        }
        if (existing.onceki_tarih) {
