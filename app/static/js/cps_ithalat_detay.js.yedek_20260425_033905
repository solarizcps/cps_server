  var belgeModul = {
    yukle: function () {
      api.get(url_belgeler()).then(function (liste) {
        belgeModul.doldur(liste);
      }).catch(function () { belgeModul.doldur([]); });
    },

    doldur: function (liste) {
      var tbody = $('cps-ith-belge-tbody');
      var bos = $('cps-ith-belge-bos');
      var rozet = $('cps-ith-rozet-belge');
      if (!tbody) return;
      tbody.innerHTML = '';
      if (rozet) rozet.textContent = liste.length || '';
      if (!liste.length) { gosterGizle(bos, true); return; }
      gosterGizle(bos, false);

      // GRUPLAMA: Ayni (BelgeTipi + kaynak_ref) olanlari grupla
      // Kaynak_ref yoksa gruplamaya girmez, olduğu gibi gösterilir
      //
      // Gruplama anahtari: BelgeTipi|parse_kaynak_ref
      // Grup ici sirala: YuklemeTarih DESC (en yeni ilk)
      // Ana satir: en yeni UYGULANDI veya en yeni belge
      var gruplar = {};
      var tekliler = [];  // kaynak_ref olmayan ya da unique belgeler

      liste.forEach(function (b) {
        var ref = b.parse_kaynak_ref;
        var tip = b.BelgeTipi;
        if (!ref || !tip) {
          tekliler.push(b);
          return;
        }
        var key = tip + '|' + ref;
        if (!gruplar[key]) gruplar[key] = [];
        gruplar[key].push(b);
      });

      // Tek satirlari ve grup ana satirlarini sirali birlestir
      // Grup ici sira: YuklemeTarih DESC
      var siraliSatirlar = [];

      Object.keys(gruplar).forEach(function (key) {
        var grupBelgeleri = gruplar[key];
        grupBelgeleri.sort(function (a, b) {
          return (b.YuklemeTarih || '').localeCompare(a.YuklemeTarih || '');
        });
        // Ana satir: ilk UYGULANDI varsa o, yoksa en yeni
        var anaIdx = grupBelgeleri.findIndex(function (x) {
          return x.parse_durum === 'UYGULANDI' || x.parse_durum === 'OK';
        });
        if (anaIdx < 0) {
          // UYGULANDI yoksa BEKLIYOR_ONAY ara
          anaIdx = grupBelgeleri.findIndex(function (x) {
            return x.parse_durum === 'BEKLIYOR_ONAY';
          });
        }
        if (anaIdx < 0) anaIdx = 0;  // en yeni

        var anaBelge = grupBelgeleri[anaIdx];
        anaBelge._grup_sayisi = grupBelgeleri.length;
        anaBelge._grup_belgeler = grupBelgeleri;
        anaBelge._grup_key = key;
        siraliSatirlar.push(anaBelge);
      });

      // Tek belgeleri ekle
      tekliler.forEach(function (b) {
        siraliSatirlar.push(b);
      });

      // Tarih sirasi (en yeni ilk)
      siraliSatirlar.sort(function (a, b) {
        return (b.YuklemeTarih || '').localeCompare(a.YuklemeTarih || '');
      });

      siraliSatirlar.forEach(function (b) {
        belgeModul._satiriEkle(tbody, b);
      });
    },

    /**
     * Tek bir belge satirini tbody'ye ekle.
     * b._grup_sayisi ve b._grup_belgeler varsa grup modunda olusturur.
     */
    _satiriEkle: function (tbody, b) {
        var tr = document.createElement('tr');
        function td(t) {
          var c = document.createElement('td');
          c.textContent = t == null ? '—' : String(t);
          return c;
        }
        // Belge tipi + parse durum rozeti (varsa)
        var tipTd = document.createElement('td');
        var tipMetni = document.createElement('span');
        tipMetni.textContent = BELGE_TIP_ETIKET[b.BelgeTipi] || b.BelgeTipi || b.belge_tipi_ad || '—';
        tipTd.appendChild(tipMetni);

        // YENI: Parse durum rozeti
        var pd = b.parse_durum;
        if (pd === 'BEKLIYOR_ONAY') {
          var rz = document.createElement('span');
          rz.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-onay';
          rz.textContent = 'ONAY BEKLIYOR';
          rz.title = 'Parser güven skoru orta — manuel onay gerekli';
          tipTd.appendChild(rz);
        } else if (pd === 'ONERI_BEKLIYOR') {
          var rzo = document.createElement('span');
          rzo.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-onay';
          rzo.textContent = 'ÖNERI BEKLIYOR';
          rzo.title = 'Maliyet önerileri kullanıcı onayı bekliyor';
          tipTd.appendChild(rzo);
        } else if (pd === 'REDDEDILDI') {
          var rz2 = document.createElement('span');
          rz2.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-red';
          rz2.textContent = 'PARSE FAIL';
          rz2.title = 'Parser okuyamadı - manuel kalem ekleyin';
          tipTd.appendChild(rz2);
        } else if (pd === 'PARSE_JSON_HATA') {
          var rz4 = document.createElement('span');
          rz4.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-red';
          rz4.textContent = 'ÖNIZLEME EKSIK';
          rz4.title = 'Parse başarılı ama onay dosyası yazılamadı - belgeyi tekrar yükleyin';
          tipTd.appendChild(rz4);
        } else if (pd === 'UYGULANDI_BOS') {
          var rz5 = document.createElement('span');
          rz5.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-red';
          rz5.textContent = 'UYGULANDI ama BOŞ';
          rz5.title = 'Daha önce uygulandı ama aktif kalem yok (iptal edilmiş) - tekrar yükleyin';
          tipTd.appendChild(rz5);
        } else if (pd === 'META_GUNCELLENDI') {
          var rz6 = document.createElement('span');
          rz6.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-ok';
          rz6.textContent = 'BİLGİ GÜNCEL';
          rz6.title = 'Parti bilgileri güncellendi (Packing List gibi - maliyet yazmaz)';
          tipTd.appendChild(rz6);
        } else if (pd === 'UYGULANDI' || pd === 'OK') {
          var rz3 = document.createElement('span');
          rz3.className = 'cps-ith-belge-rozet cps-ith-belge-rozet-ok';
          rz3.textContent = 'UYGULANDI';
          tipTd.appendChild(rz3);
        }
        tr.appendChild(tipTd);

        tr.appendChild(td(b.OrijinalAd));
        var boyutTd = td(belgeModul.boyutFmt(b.DosyaBoyut));
        boyutTd.className = 'cps-ith-th-sag';
        tr.appendChild(boyutTd);
        tr.appendChild(td(b.Yukleyen));
        tr.appendChild(td(tarihSaatFmt(b.YuklemeTarih)));

        // Aciklama + "Onizleme Ac" butonu (sadece BEKLIYOR_ONAY ise)
        var acTd = document.createElement('td');
        if (b.Aciklama) {
          var acTxt = document.createElement('span');
          acTxt.textContent = b.Aciklama;
          acTxt.className = 'cps-ith-belge-aciklama';
          acTd.appendChild(acTxt);
        }
        // SADECE BEKLIYOR_ONAY ise buton gorunsun
        // (PARSE_JSON_HATA ise JSON yok - buton calismaz, gostermiyoruz)
        if (b.parse_durum === 'BEKLIYOR_ONAY') {
          var btnOnay = document.createElement('button');
          btnOnay.type = 'button';
          btnOnay.className = 'cps-ith-btn cps-ith-btn-primary cps-ith-btn-sm';
          btnOnay.textContent = 'Önizlemeyi Aç →';
          btnOnay.style.marginLeft = '8px';
          btnOnay.addEventListener('click', function () {
            onayModul.ac(b.Id);
          });
          acTd.appendChild(btnOnay);
        } else if (b.parse_durum === 'PARSE_JSON_HATA') {
          // Kullanicilar neden buton olmadigini anlasin
          var info = document.createElement('span');
          info.className = 'cps-ith-belge-aciklama';
          info.style.color = '#dc2626';
          info.style.marginLeft = '8px';
          info.style.fontSize = '11px';
          info.style.fontStyle = 'italic';
          info.textContent = '(Önizleme eksik — tekrar yükleyin)';
          acTd.appendChild(info);
        }

        // Grup bilgisi varsa altta kucuk not goster
        if (b._grup_sayisi && b._grup_sayisi > 1) {
          var gnot = document.createElement('div');
          gnot.className = 'cps-ith-belge-grup-not';
          var sonTarih = '';
          if (b._grup_belgeler && b._grup_belgeler.length) {
            var enYeni = b._grup_belgeler[0];
            sonTarih = tarihSaatFmt(enYeni.YuklemeTarih);
          }
          gnot.textContent = b._grup_sayisi + ' yükleme' +
            (sonTarih ? ' · son uygulama: ' + sonTarih : '');
          gnot.title = 'Bu referans için toplam ' + b._grup_sayisi + ' yükleme var';
          acTd.appendChild(gnot);
        }

        tr.appendChild(acTd);
        tbody.appendChild(tr);
    },

    boyutFmt: function (b) {
      if (b == null) return '—';
      var n = Number(b);
      if (isNaN(n)) return '—';
      if (n < 1024) return n + ' B';
      if (n < 1048576) return (n / 1024).toFixed(0) + ' KB';
      return (n / 1048576).toFixed(1) + ' MB';
    },

    _parseDurumunuYorumla: function (parse) {
      parse = parse || {};
      var durum = parse.durum || '';
      var uygulanan = parse.uygulanan || 0;
      var atlanan = parse.atlanan || 0;
      var iptal = parse.onceki_kalemler_iptal || 0;
      var ref = parse.kaynak_ref;
      var guven = parse.guven_skoru;

      if (!parse.denendi) {
        return { sinif: 'ok', metin: '✓ Yuklendi (bu tip icin otomatik okuma yok)',
                 aksiyon: null };
      }

      // PARSE_JSON_HATA - onizleme yazilamadi
      if (durum === 'PARSE_JSON_HATA') {
        return {
          sinif: 'hata',
          metin: '⚠ Önizleme verisi eksik — belgeyi tekrar yükleyin',
          aksiyon: null,
        };
      }

      // UYGULANDI_BOS - DB'de UYGULANDI ama aktif kalem yok
      if (durum === 'UYGULANDI_BOS') {
        return {
          sinif: 'hata',
          metin: '⚠ Uygulandı görünüyor ama aktif maliyet kalemi yok — belgeyi tekrar yükleyin',
          aksiyon: null,
        };
      }

      // META_GUNCELLENDI - Packing List gibi: parti bilgisi guncellendi
      if (durum === 'META_GUNCELLENDI') {
        return {
          sinif: 'ok',
          metin: '✓ Bilgi güncellendi — parti bilgileri yenilendi',
          aksiyon: null,
        };
      }

      // YENI: ONERI_BEKLIYOR - beyanname, maliyet_pdf icin
      if (durum === 'ONERI_BEKLIYOR') {
        var hazir_o = parse.onay_hazir !== false;
        if (!hazir_o) {
          return {
            sinif: 'hata',
            metin: '⚠ Önizleme verisi eksik — belgeyi tekrar yükleyin',
            aksiyon: null,
          };
        }
        return {
          sinif: 'uyari',
          metin: '🟡 Yüklendi — maliyet önerileri onay bekliyor',
          aksiyon: 'onay_ac',
          belge_id: parse.belge_id || null,
        };
      }

      // BEKLIYOR_ONAY - preview modalini ac (ama SADECE onay_hazir ise)
      if (durum === 'BEKLIYOR_ONAY') {
        var seviye = parse.guven_seviyesi || 'orta';
        var emoji = seviye === 'yuksek' ? '🟢' : (seviye === 'orta' ? '🟡' : '🟠');
        var hazir = parse.onay_hazir !== false;  // default true

        if (!hazir) {
          return {
            sinif: 'hata',
            metin: '⚠ Önizleme verisi eksik — belgeyi tekrar yükleyin',
            aksiyon: null,
          };
        }

        var mtn = emoji + ' Yüklendi — önizleme onayı bekleniyor' +
                  (guven != null ? ' (güven: ' + guven + '/100)' : '');
        return {
          sinif: 'uyari',
          metin: mtn,
          aksiyon: 'onay_ac',
          belge_id: parse.belge_id || null,
        };
      }

      // REDDEDILDI
      if (durum === 'REDDEDILDI') {
        var mtn2 = '✗ Yüklendi ama kalem eklenmedi';
        if (guven != null) mtn2 += ' (güven düşük: ' + guven + '/100)';
        mtn2 += ' — manuel kalem eklemeniz gerekebilir';
        return { sinif: 'hata', metin: mtn2, aksiyon: null };
      }

      if ((durum === 'OK' || durum === 'YENIDEN_ISLENDI') && uygulanan > 0) {
        var m = '✓ Yuklendi — ' + uygulanan + ' kalem maliyete eklendi';
        if (iptal > 0) m += ' (' + iptal + ' eski kalem iptal edildi)';
        if (atlanan > 0) m += ', ' + atlanan + ' atlandi';
        if (ref) m += ' · ' + ref;
        return { sinif: 'ok', metin: m, aksiyon: null };
      }
      if (durum === 'OK' || durum === 'BOS') {
        return { sinif: 'ok', metin: '✓ Yuklendi — parse tamam, eklenecek kalem yok',
                 aksiyon: null };
      }
      if (durum === 'ZATEN_ISLENDI') {
        return { sinif: 'hata', aksiyon: null,
          metin: '⚠ Bu belge zaten islenmis' + (ref ? ' (' + ref + ')' : '') + ' · tekrar eklenmedi' };
      }
      if (durum === 'INSAN_ONAYI_BEKLIYOR') {
        return { sinif: 'hata', aksiyon: null,
          metin: '⚠ Yuklendi — PI No bulunamadi, insan onayi gerekli' };
      }
      if (durum === 'DESTEKLENMIYOR') {
        return { sinif: 'ok', aksiyon: null,
          metin: '✓ Yuklendi (parser konfigurasyonu tamamlanmadi)' };
      }
      var sebep = parse.mesaj || 'parse edilemedi';
      return { sinif: 'hata', aksiyon: null,
               metin: '✗ Yuklendi ancak parse basarisiz: ' + sebep };
    },

    yuklemeBaslat: function () {
      var dosyaInput = $('bl-dosya');
      var tipInput = $('bl-tip');
      var aciklamaInput = $('bl-aciklama');
      var dst = $('cps-ith-belge-durum');
      var btn = $('cps-ith-btn-belge-yukle');

      if (!dosyaInput.files || !dosyaInput.files.length) {
        dst.className = 'cps-ith-kayit-durum hata';
        dst.textContent = 'Dosya secilmedi';
        return;
      }

      btn.disabled = true;
      dst.className = 'cps-ith-kayit-durum';
      dst.textContent = 'Yukleniyor...';

      var fd = new FormData();
      fd.append('dosya', dosyaInput.files[0]);
      fd.append('belge_tipi', tipInput.value);
      fd.append('aciklama', aciklamaInput.value.trim());

      api.upload(url_belge_up(), fd).then(function (r) {
        btn.disabled = false;
        if (!r.ok || !r.data.ok) {
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '✗ ' + (r.data.hata || 'Yuklenemedi');
          return;
        }
        var parse = r.data.parse || {};
        var yorum = belgeModul._parseDurumunuYorumla(parse);
        dst.className = 'cps-ith-kayit-durum ' + yorum.sinif;
        dst.textContent = yorum.metin;
        dosyaInput.value = '';
        aciklamaInput.value = '';
        belgeModul.yukle();

        if ((parse.uygulanan || 0) > 0) detayYukle();

        // YENI: BEKLIYOR_ONAY durumunda preview modal aç
        if (yorum.aksiyon === 'onay_ac') {
          var bid = r.data.id || r.data.belge_id;
          if (bid) {
            // Kisa bir gecikme - kullanici mesaji gorsun
            setTimeout(function () {
              onayModul.ac(bid);
            }, 300);
          }
        }

        var gosterMetin = yorum.metin;
        setTimeout(function () {
          if (dst.textContent === gosterMetin) {
            dst.textContent = '';
            dst.className = 'cps-ith-kayit-durum';
          }
        }, 12000);
      }).catch(function (e) {
        btn.disabled = false;
        dst.className = 'cps-ith-kayit-durum hata';
        dst.textContent = '✗ Baglanti hatasi';
        console.error('[cps-ith-detay] upload hatasi:', e);
      });
    },

    bagla: function () {
      var btn = $('cps-ith-btn-belge-yukle');
      if (btn) btn.addEventListener('click', this.yuklemeBaslat);
    },
  };


  // =====================================================================
  // DURUM MODUL
  // =====================================================================
  var durumModul = {
    doldur: function (d) {
      var p = d.parti;
      var dm = DURUM_MAP[p.Durum] || { etiket: p.Durum, sinif: '' };
      var mev = $('cps-ith-durum-mevcut');
      if (mev) {
        mev.className = 'cps-ith-durum-etiket ' + dm.sinif;
        mev.textContent = dm.etiket;
      }
      $$('.cps-ith-durum-butonlar button').forEach(function (b) {
        b.classList.remove('cps-ith-btn-primary');
        b.classList.add('cps-ith-btn-ghost');
      });
      var aktifBtn = document.querySelector(
        '.cps-ith-durum-butonlar button[data-durum="' + p.Durum + '"]');
      if (aktifBtn) {
        aktifBtn.classList.remove('cps-ith-btn-ghost');
        aktifBtn.classList.add('cps-ith-btn-primary');
      }

      var zaman = $('cps-ith-zaman');
      if (!zaman) return;
      zaman.innerHTML = '';
      var gecmis = d.durum_gecmisi || [];
      if (!gecmis.length) {
        var bos = document.createElement('div');
        bos.className = 'cps-ith-tablo-durum';
        bos.textContent = 'Henuz durum kaydi yok.';
        zaman.appendChild(bos);
        return;
      }
      gecmis.forEach(function (g) {
        var item = document.createElement('div');
        item.className = 'cps-ith-zaman-kayit';
        var t = document.createElement('div');
        t.className = 'cps-ith-zaman-tarih';
        t.textContent = tarihSaatFmt(g.Tarih);
        item.appendChild(t);
        var a = document.createElement('div');
        a.className = 'cps-ith-zaman-aciklama';
        a.textContent = g.Aciklama || '—';
        item.appendChild(a);
        if (g.Kullanici) {
          var k = document.createElement('div');
          k.className = 'cps-ith-zaman-kullanici';
          k.textContent = g.Kullanici;
          item.appendChild(k);
        }
        zaman.appendChild(item);
      });
    },

    degistir: function (yeniDurum) {
      var notMetni = $('cps-ith-durum-not-input').value.trim();
      var dst = $('cps-ith-durum-sonuc');
      dst.className = 'cps-ith-kayit-durum';
      dst.textContent = 'Kaydediliyor...';
      api.post(url_durum(), { durum: yeniDurum, 'not': notMetni || null }).then(function (r) {
        if (r.ok && r.data.ok) {
          dst.className = 'cps-ith-kayit-durum ok';
          dst.textContent = '✓ Durum degistirildi';
          $('cps-ith-durum-not-input').value = '';
          detayYukle();
          setTimeout(function () { dst.textContent = ''; }, 2500);
        } else {
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '✗ ' + (r.data.hata || 'Hata');
        }
      }).catch(function () {
        dst.className = 'cps-ith-kayit-durum hata';
        dst.textContent = '✗ Kaydedilemedi';
      });
    },

    bagla: function () {
      $$('.cps-ith-durum-butonlar button').forEach(function (b) {
        b.addEventListener('click', function () {
          var d = b.getAttribute('data-durum');
          if (d) durumModul.degistir(d);
        });
      });
    },
  };


  // =====================================================================
  // SEKME YONETIMI
  // =====================================================================
  var sekme = {
    bagla: function () {
      $$('.cps-ith-sekme').forEach(function (btn) {
        btn.addEventListener('click', function () {
          sekme.ac(btn.getAttribute('data-sekme'));
        });
      });
    },

    ac: function (ad) {
      if (!ad) return;
      $$('.cps-ith-sekme').forEach(function (b) { b.classList.remove('cps-ith-sekme-aktif'); });
      var aktifBtn = document.querySelector('.cps-ith-sekme[data-sekme="' + ad + '"]');
      if (aktifBtn) aktifBtn.classList.add('cps-ith-sekme-aktif');
      $$('.cps-ith-sekme-icerik').forEach(function (s) {
        s.classList.remove('cps-ith-sekme-icerik-aktif');
      });
      var aktifIcerik = document.querySelector('[data-sekme-icerik="' + ad + '"]');
      if (aktifIcerik) aktifIcerik.classList.add('cps-ith-sekme-icerik-aktif');
      if (ad === 'belge') belgeModul.yukle();
    },
  };


  // =====================================================================
  // BASLATMA
  // =====================================================================
  function baslat() {
    var root = document.querySelector('[data-sayfa="parti-detay"]');
    if (!root) {
      console.warn('[cps-ith-detay] detay sayfasi root bulunamadi');
      return;
    }
    PARTI_ID = parseInt(root.getAttribute('data-parti-id'), 10);
    if (!PARTI_ID) {
      console.error('[cps-ith-detay] parti id yok');
      return;
    }
    sekme.bagla();
    genelModul.bagla();
    maliyetModul.bagla();
    odemeModul.bagla();
    belgeModul.bagla();
    durumModul.bagla();
    urunModul.bagla();
    onayModul.bagla();
    var yenileBtn = $('cps-ith-btn-detay-yenile');
    if (yenileBtn) yenileBtn.addEventListener('click', detayYukle);
    var tekrarBtn = $('cps-ith-detay-hata-tekrar');
    if (tekrarBtn) {
      tekrarBtn.addEventListener('click', function (e) {
        e.preventDefault();
        detayYukle();
      });
    }
    detayYukle();
    console.info('[cps-ith-detay] aktif, parti=' + PARTI_ID);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', baslat);
  } else {
    baslat();
  }

})();
