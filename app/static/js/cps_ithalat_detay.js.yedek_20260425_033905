    _tespitOlustur: function (veri) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum';
      var b = document.createElement('h4');
      b.className = 'cps-ith-modal-bolum-baslik';
      b.textContent = 'Tespit Edilenler';
      d.appendChild(b);

      var grid = document.createElement('div');
      grid.className = 'cps-ith-onay-tespit-grid';

      function satir(etiket, deger, ikon) {
        var s = document.createElement('div');
        s.className = 'cps-ith-onay-tespit-satir';
        var et = document.createElement('div');
        et.className = 'cps-ith-onay-tespit-et';
        et.textContent = (ikon || '▸') + ' ' + etiket;
        s.appendChild(et);
        var dv = document.createElement('div');
        dv.className = 'cps-ith-onay-tespit-dv';
        if (deger == null || deger === '') {
          dv.textContent = '—';
          dv.classList.add('cps-ith-onay-tespit-bos');
        } else {
          dv.textContent = String(deger);
        }
        s.appendChild(dv);
        return s;
      }

      grid.appendChild(satir('Kaynak Ref (PI/Invoice)', veri.kaynak_ref, '🔑'));
      var bilgi = veri.parti_bilgi || {};
      // YENI: Tedarikci gorunen ad (Cince->Latin donusum backend'de)
      // veri.tedarikci = {orijinal_ad, gorunen_ad, cari_kod}
      var tedSource = veri.tedarikci || {};
      var tedGorunen = tedSource.gorunen_ad || bilgi.tedarikci_ad;
      var tedOrijinal = tedSource.orijinal_ad || bilgi.tedarikci_ad;
      if (tedGorunen) {
        var tedSatir = document.createElement('div');
        tedSatir.className = 'cps-ith-onay-tespit-satir';
        var tedEt = document.createElement('div');
        tedEt.className = 'cps-ith-onay-tespit-et';
        tedEt.textContent = '🏢 Tedarikçi';
        tedSatir.appendChild(tedEt);
        var tedDv = document.createElement('div');
        tedDv.className = 'cps-ith-onay-tespit-dv';
        // Gorunen + orijinal (farkli ise) tooltip'li
        if (tedOrijinal && tedOrijinal !== tedGorunen) {
          tedDv.innerHTML = '<span class="cps-ith-tedarikci-gorunen">' +
            tedGorunen + '</span>';
          tedDv.title = 'Orijinal: ' + tedOrijinal;
        } else {
          tedDv.textContent = tedGorunen;
        }
        tedSatir.appendChild(tedDv);
        grid.appendChild(tedSatir);
      }
      if (bilgi.para_birimi) {
        grid.appendChild(satir('Para Birimi', bilgi.para_birimi, '💱'));
      }
      if (bilgi.yukleme_tarih) {
        grid.appendChild(satir('Yükleme Tarihi', tarihFmt(bilgi.yukleme_tarih), '📅'));
      }
      if (bilgi.toplam_cift) {
        grid.appendChild(satir('Toplam Çift', sayiFmt(bilgi.toplam_cift, 0), '👟'));
      }

      // Kolon tespitleri
      var kolonlar = veri.tespit_edilen_kolonlar || {};
      var kolonKeys = Object.keys(kolonlar);

      // Kolon teknik adlarini Turkce etikete cevir
      var KOLON_ETIKET = {
        'item':             'Ürün/Item Kodu',
        'spec':             'Spec/Açıklama',
        'unit_price':       'Birim Fiyat',
        'qty':              'Miktar',
        'unit_of_measure':  'Birim (pair/pcs)',
        'amount_usd':       'Tutar USD',
        'amount_eur':       'Tutar EUR',
        'amount_try':       'Tutar TRY',
        'amount_rmb':       'Tutar RMB',
        'amount':           'Tutar',
        'description':      'Açıklama',
        'photo':            'Fotoğraf',
        'ext_factory':      'Ex-Factory',
        'extra_desc':       'Ek Açıklama',
      };

      if (kolonKeys.length) {
        var ayir = document.createElement('div');
        ayir.className = 'cps-ith-onay-tespit-ayirici';
        ayir.textContent = 'Excel kolonları:';
        grid.appendChild(ayir);
        kolonKeys.forEach(function (k) {
          var et = KOLON_ETIKET[k] || k;
          grid.appendChild(satir(et, kolonlar[k], '▪'));
        });
      }

      d.appendChild(grid);
      return d;
    },

