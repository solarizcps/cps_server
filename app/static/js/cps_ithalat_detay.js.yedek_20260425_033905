                         new Date().toISOString().substring(0, 10));
      if (!tarih) return;
      var veri = {
        parti_id: PARTI_ID,
        odeme_plan_id: plan.Id,
        tarih: tarih,
        tutar: tutarN,
        para_birimi: plan.ParaBirimi,
        cari_kod: plan.CariKod,
        cari_ad: plan.CariAd,
      };
      api.post('/api/ithalat/hareket/ekle', veri).then(function (r) {
        if (r.ok && r.data.ok) detayYukle();
        else alert('Kaydedilemedi: ' + (r.data.hata || 'hata'));
