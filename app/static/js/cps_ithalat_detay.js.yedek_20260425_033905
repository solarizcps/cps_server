    /**
     * Modal alt bar tek butonu: "Onayla ve Uygula" veya "Override ile Uygula"
     * Butonun dataset.mode degerine gore override flag'i gonderir.
     * NATIVE CONFIRM YOK. TEK TIK. Backend yanit verince ya kapanir ya hata mesaji.
     */
    uygula: function () {
      var bid = onayModul._aktif_belge_id;
      if (!bid) return;

      var btn = $('cps-ith-onay-uygula');
      var dst = $('cps-ith-onay-durum');
      if (!btn) return;

      var mode = btn.dataset.mode || 'normal';
      var isOverride = (mode === 'override' || mode === 'override-oneri');
      var isOneriMod = (mode === 'oneri' || mode === 'override-oneri');

      // ==== ONERI MODU: Secilenleri topla ====
      // Hem parser satirlari hem de manuel eklenen satirlari toplar
      // Manuel satirlarda: aciklama input'tan, parser'da span'den
      // Validation: aciklama bos / tutar <=0 durumunda uygula engellenir
      var secilenOneriler = null;
      if (isOneriMod) {
        secilenOneriler = [];
        var validationHatasi = null;
        var trler = document.querySelectorAll('.cps-ith-onay-oneri-tbl tbody tr');

        trler.forEach(function (tr) {
          var cb = tr.querySelector('.cps-ith-onay-oneri-cb');
          if (!cb || !cb.checked) return;  // secilmemis - atla

          var isManuel = (tr.dataset.manuel === 'true');

          // Tutar
          var tutarIn = tr.querySelector('.cps-ith-onay-oneri-tutar-input');
          var tutar = parseFloat(tutarIn.value);
          if (isNaN(tutar) || tutar <= 0) {
            // Validation hatasi - tutar
            tutarIn.classList.add('cps-ith-onay-oneri-input-hata');
            if (!validationHatasi) {
              validationHatasi = 'Tutar 0\'dan büyük olmalı';
            }
            return;
          } else {
            tutarIn.classList.remove('cps-ith-onay-oneri-input-hata');
          }

          // Aciklama - manuel ise input, parser ise span
          var aciklama = '';
          if (isManuel) {
            var adIn = tr.querySelector('.cps-ith-onay-oneri-aciklama-input');
            aciklama = (adIn.value || '').trim();
            if (!aciklama) {
              adIn.classList.add('cps-ith-onay-oneri-input-hata');
              if (!validationHatasi) {
                validationHatasi = 'Açıklama boş olamaz';
              }
              return;
            }
          } else {
            var adSpan = tr.querySelector('.cps-ith-onay-oneri-ad-text');
            aciklama = (adSpan ? adSpan.textContent : '').trim();
            // Fallback - eski yapidaki parser satirlari icin
            if (!aciklama) {
              var adTd = tr.querySelector('.cps-ith-onay-oneri-ad');
              if (adTd && adTd.childNodes[0]) {
                aciklama = adTd.childNodes[0].textContent.trim();
              }
            }
          }

          // Select degerleri - class bazli sec
          var paraSel = tr.querySelector('.cps-ith-onay-oneri-para');
          var tipSel = tr.querySelector('.cps-ith-onay-oneri-tip');
          var kaynakSel = tr.querySelector('.cps-ith-onay-oneri-kaynak');

          var para = paraSel ? paraSel.value : 'TRY';
          var tip = tipSel ? tipSel.value : 'DIGER';
          var kaynak = kaynakSel ? kaynakSel.value : 'GERCEKLESEN';
          var altKod = tr.dataset.altKod || null;

          secilenOneriler.push({
            aciklama:    aciklama,
            tutar:       tutar,
            para_birimi: para,
            tip:         tip,
            kaynak:      kaynak,
            alt_kod:     altKod,
            _manuel:     isManuel,  // debug bilgisi (backend kullanmaz)
          });
        });

        // Validation kontrol
        if (validationHatasi) {
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '⚠ ' + validationHatasi;
          return;
        }

        if (secilenOneriler.length === 0) {
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '⚠ En az bir kalem seçmelisiniz';
          return;
        }
      }

      // Loading state
      btn.disabled = true;
      var metin = btn.querySelector('.cps-ith-btn-metin');
      var sp = btn.querySelector('.cps-ith-btn-spinner');
      var eskiMetin = metin ? metin.textContent : '';
      if (metin) {
        metin.textContent = isOverride ? '⏳ Override uygulanıyor...' : '⏳ Uygulanıyor...';
      }
      if (sp) sp.classList.remove('cps-ith-gizle');
      dst.className = 'cps-ith-kayit-durum';
      dst.textContent = '';

      var ekstraCb = $('cps-ith-onay-ekstra-cb');
      var ekstra = ekstraCb ? ekstraCb.checked : false;

      var body = {
        ekstra_kalemler_dahil: ekstra,
        override_duplicate:    isOverride,
      };
      if (secilenOneriler !== null) {
        body.secilen_oneriler = secilenOneriler;
      }

      api.post('/api/ithalat/belge/' + bid + '/parse-onay/uygula', body)
        .then(function (r) {
          if (r.ok && r.data && r.data.ok) {
            dst.className = 'cps-ith-kayit-durum ok';
            var uygulananSay = r.data.uygulanan_kalem_sayisi || 0;
            if (isOverride) {
              dst.textContent = '✓ Referans güncellendi · ' + uygulananSay +
                ' kalem maliyete yazıldı (eski kalemler iptal edildi).';
            } else if (r.data.packing_list) {
              var atlSay = (r.data.atlamalar || []).length;
              var pl = '✓ ' + (r.data.mesaj || 'Packing List işlendi');
              if (atlSay > 0) pl += ' (' + atlSay + ' alan overwrite edilmedi)';
              dst.textContent = pl;
            } else if (isOneriMod) {
              dst.textContent = '✓ ' + uygulananSay +
                ' seçili kalem maliyete eklendi';
            } else {
              dst.textContent = '✓ ' + (r.data.mesaj || 'Uygulandı');
            }
            setTimeout(function () {
              onayModul.kapat();
              detayYukle();
              belgeModul.yukle();
            }, 1500);
            return;
          }

          // Basarisiz - buton eski haline
          btn.disabled = false;
          if (metin) metin.textContent = eskiMetin;
          if (sp) sp.classList.add('cps-ith-gizle');

          if (r.data && r.data.duplicate) {
            dst.className = 'cps-ith-kayit-durum hata';
            dst.textContent = '⚠ ' + (r.data.duplicate_uyari ||
                                      'Bu referans zaten işlenmiş. Override moduna geçiliyor...');
            onayModul._altBarAyarla(true, isOneriMod);
            return;
          }

          var hata = (r.data && (r.data.hata || r.data.mesaj)) || 'Uygulanamadı';
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '✗ ' + hata;
        })
        .catch(function (e) {
          btn.disabled = false;
          if (metin) metin.textContent = eskiMetin;
          if (sp) sp.classList.add('cps-ith-gizle');
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '✗ Bağlantı hatası';
        });
    },

    reddet: function () {
      var bid = onayModul._aktif_belge_id;
      if (!bid) return;

      var btn = $('cps-ith-onay-reddet');
      var dst = $('cps-ith-onay-durum');
      if (!btn || !dst) return;

      // Iki tikli mantik: ilk tik onay ister, ikinci tik reddeder
      if (!btn.dataset.onayBekliyor) {
        btn.dataset.onayBekliyor = '1';
        var eskiMetin = btn.textContent;
        btn.dataset.eskiMetin = eskiMetin;
        btn.textContent = 'Emin misiniz? Tekrar basın';
        btn.classList.add('cps-ith-btn-tehlike');
        dst.className = 'cps-ith-kayit-durum hata';
        dst.textContent = '⚠ Reddet butonuna tekrar basarsanız önizleme silinir';

        // 4 saniye sonra otomatik iptal
        setTimeout(function () {
          if (btn.dataset.onayBekliyor === '1') {
            btn.dataset.onayBekliyor = '';
            btn.textContent = btn.dataset.eskiMetin || 'Reddet';
            btn.classList.remove('cps-ith-btn-tehlike');
            dst.className = 'cps-ith-kayit-durum';
            dst.textContent = '';
          }
        }, 4000);
        return;
      }

      // Ikinci tik - gercek reddet
      btn.dataset.onayBekliyor = '';
      btn.disabled = true;
      btn.textContent = 'Reddediliyor...';
      dst.className = 'cps-ith-kayit-durum';
      dst.textContent = '';

      api.post('/api/ithalat/belge/' + bid + '/parse-onay/reddet', {})
        .then(function (r) {
          if (r.ok && r.data && r.data.ok) {
            dst.className = 'cps-ith-kayit-durum ok';
            dst.textContent = '✓ Reddedildi';
            setTimeout(function () {
              onayModul.kapat();
              belgeModul.yukle();
            }, 700);
          } else {
            btn.disabled = false;
            btn.textContent = btn.dataset.eskiMetin || 'Reddet';
            btn.classList.remove('cps-ith-btn-tehlike');
            dst.className = 'cps-ith-kayit-durum hata';
            dst.textContent = '✗ ' + ((r.data && r.data.hata) || 'Hata');
          }
        })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = btn.dataset.eskiMetin || 'Reddet';
          btn.classList.remove('cps-ith-btn-tehlike');
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '✗ Bağlantı hatası';
        });
    },

    bagla: function () {
      var kapat = $('cps-ith-onay-kapat');
      if (kapat) kapat.addEventListener('click', onayModul.kapat);

      var back = $('cps-ith-onay-modal-backdrop');
      if (back) back.addEventListener('click', onayModul.kapat);

      var uygula = $('cps-ith-onay-uygula');
      if (uygula) uygula.addEventListener('click', function () {
        onayModul.uygula();
      });

      var reddet = $('cps-ith-onay-reddet');
      if (reddet) reddet.addEventListener('click', onayModul.reddet);

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          var m = $('cps-ith-onay-modal');
          if (m && !m.classList.contains('cps-ith-gizle')) {
            onayModul.kapat();
          }
        }
      });
    },
  };


