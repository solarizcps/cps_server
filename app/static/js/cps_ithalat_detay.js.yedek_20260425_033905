      var sebep = prompt('Iptal sebebi (opsiyonel):', '');
      if (sebep === null) return;
      api.post('/api/ithalat/odeme-plan/' + plan_id + '/iptal', { sebep: sebep })
        .then(function (r) {
          if (r.ok && r.data.ok) detayYukle();
          else alert('Iptal edilemedi: ' + (r.data.hata || 'hata'));
        });
