  // YENI: Tasima tipi ikon ve renk sinifi
  var TASIMA_IKON = {
    'AIR':    { ikon: '✈️', etiket: 'Hava',  sinif: 'cps-ith-tasima-air'   },
    'SEA':    { ikon: '🚢', etiket: 'Deniz', sinif: 'cps-ith-tasima-sea'   },
    'TRUCK':  { ikon: '🚚', etiket: 'Kara',  sinif: 'cps-ith-tasima-truck' },
    'RAIL':   { ikon: '🚆', etiket: 'Tren',  sinif: 'cps-ith-tasima-rail'  },
    'EXPRESS': { ikon: '📦', etiket: 'Express', sinif: 'cps-ith-tasima-express' },
  };

  // YENI: Urun tipi ikon altyapisi (ileride kullanim icin hazir)
  var URUN_TIP_IKON = {
    'ISIKLI':   { ikon: '💡', etiket: 'Işıklı',    sinif: 'cps-ith-urun-isikli'    },
    'TERLIK':   { ikon: '🩴', etiket: 'Terlik',    sinif: 'cps-ith-urun-terlik'    },
    'SPOR':     { ikon: '👟', etiket: 'Spor',      sinif: 'cps-ith-urun-spor'      },
    'SANDALET': { ikon: '👡', etiket: 'Sandalet',  sinif: 'cps-ith-urun-sandalet'  },
    'BOT':      { ikon: '🥾', etiket: 'Bot',       sinif: 'cps-ith-urun-bot'       },
    'DIGER':    { ikon: '📦', etiket: 'Diğer',     sinif: 'cps-ith-urun-diger'     },
  };

  /**
   * Tasima tipini ikon+etiketle badge olarak render et.
   * Donus: HTMLSpanElement | null
   */
  function tasimaBadgeOlustur(tip) {
    if (!tip) return null;
    var bilgi = TASIMA_IKON[tip];
    if (!bilgi) {
      // Bilinmeyen tip
      bilgi = { ikon: '🚛', etiket: tip, sinif: 'cps-ith-tasima-diger' };
    }
    var span = document.createElement('span');
    span.className = 'cps-ith-tasima-badge ' + bilgi.sinif;
    span.title = bilgi.etiket + ' taşıma';
    span.innerHTML = '<span class="cps-ith-tasima-ikon">' + bilgi.ikon + '</span>' +
                     '<span class="cps-ith-tasima-ad">' + bilgi.etiket + '</span>';
    return span;
  }

  /**
   * Urun tipi badge (ileride kullanilacak altyapi).
   * Veri yoksa null doner - cagiran kontrol etmeli.
   */
  function urunTipiBadgeOlustur(tip) {
    if (!tip) return null;
    var bilgi = URUN_TIP_IKON[String(tip).toUpperCase()];
    if (!bilgi) return null;
    var span = document.createElement('span');
    span.className = 'cps-ith-urun-tip-badge ' + bilgi.sinif;
    span.title = bilgi.etiket;
    span.innerHTML = '<span class="cps-ith-urun-tip-ikon">' + bilgi.ikon + '</span>' +
                     '<span class="cps-ith-urun-tip-ad">' + bilgi.etiket + '</span>';
    return span;
  }

  var PARA_SIRASI = ['USD', 'EUR', 'TRY', 'CNY', 'GBP'];


  // =====================================================================
  // YARDIMCILAR
  // =====================================================================
  function $(id) { return document.getElementById(id); }
  function $$(sel, root) { return (root || document).querySelectorAll(sel); }

  function gosterGizle(el, goster) {
    if (!el) return;
    if (goster) el.classList.remove('cps-ith-gizle');
    else        el.classList.add('cps-ith-gizle');
  }

  function metin(el, v) {
    if (!el) return;
    el.textContent = (v == null || v === '') ? '—' : String(v);
  }

  function paraFmt(tutar, para) {
    if (tutar == null || isNaN(tutar)) return '—';
    var num = Number(tutar);
    var abs = Math.abs(num);
    var g;
    if (abs >= 1000000)      g = (num / 1000000).toFixed(2) + 'M';
    else if (abs >= 10000)   g = (num / 1000).toFixed(1) + 'K';
    else                     g = num.toLocaleString('tr-TR', {
      minimumFractionDigits: 0, maximumFractionDigits: 2,
    });
    return para ? g + ' ' + para : g;
  }

  function tamParaFmt(tutar, para) {
    if (tutar == null || isNaN(tutar)) return '—';
    var s = Number(tutar).toLocaleString('tr-TR', {
      minimumFractionDigits: 2, maximumFractionDigits: 2,
    });
    return para ? s + ' ' + para : s;
  }

  function sayiFmt(n, basamak) {
    basamak = basamak != null ? basamak : 0;
    if (n == null || isNaN(n)) return '—';
    return Number(n).toLocaleString('tr-TR', {
      minimumFractionDigits: basamak, maximumFractionDigits: basamak,
    });
  }

  function yuzdeFmt(y) {
    if (y == null || isNaN(y)) return '';
    var n = Number(y);
    return (n > 0 ? '+' : '') + n.toFixed(1) + '%';
  }

  function tarihFmt(iso) {
    if (!iso) return '';
    try {
      var p = String(iso).substring(0, 10).split('-');
      if (p.length !== 3) return iso;
      return p[2] + '.' + p[1] + '.' + p[0].substring(2);
    } catch (e) { return iso; }
  }

  function tarihSaatFmt(iso) {
    if (!iso) return '';
    var t = tarihFmt(iso);
    try {
      var s = String(iso);
      if (s.length >= 16) return t + ' ' + s.substring(11, 16);
    } catch (e) {}
    return t;
  }

  function gunFarki(iso) {
    if (!iso) return null;
    try {
      var t = new Date(iso);
      var b = new Date();
      t.setHours(0, 0, 0, 0);
      b.setHours(0, 0, 0, 0);
      return Math.round((t - b) / (1000 * 60 * 60 * 24));
    } catch (e) { return null; }
  }


  // =====================================================================
  // API
  // =====================================================================
  var api = {
    get: function (url) {
      return fetch(url, {
        method: 'GET',
        credentials: 'same-origin',
        headers: { 'Accept': 'application/json' },
      }).then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      });
    },
    post: function (url, data) {
      return fetch(url, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data || {}),
      }).then(function (r) {
        return r.json().then(function (j) {
          return { ok: r.ok, status: r.status, data: j };
        });
      });
    },
    upload: function (url, formData) {
      return fetch(url, {
        method: 'POST',
        credentials: 'same-origin',
        body: formData,
      }).then(function (r) {
        return r.json().then(function (j) {
          return { ok: r.ok, status: r.status, data: j };
        });
      });
    },
  };

  function url_detay()     { return '/api/ithalat/parti/' + PARTI_ID; }
  function url_guncelle()  { return '/api/ithalat/parti/' + PARTI_ID + '/guncelle'; }
  function url_durum()     { return '/api/ithalat/parti/' + PARTI_ID + '/durum'; }
  function url_belgeler()  { return '/api/ithalat/parti/' + PARTI_ID + '/belgeler'; }
  function url_belge_up()  { return '/api/ithalat/parti/' + PARTI_ID + '/belge/yukle'; }
  function url_urun_kart(arama, bu_parti_id) {
    var u = '/api/ithalat/urun/kart?arama=' + encodeURIComponent(arama);
    if (bu_parti_id) u += '&bu_parti_id=' + encodeURIComponent(bu_parti_id);
    return u;
  }


  // =====================================================================
  // DETAY YUKLE + SAYFA DOLDUR
  // =====================================================================
  function detayYukle() {
    gosterGizle($('cps-ith-detay-yukleniyor'), true);
    gosterGizle($('cps-ith-detay-hata'), false);

    return api.get(url_detay()).then(function (d) {
      DETAY_VERI = d;
      sayfayiDoldur(d);
      gosterGizle($('cps-ith-detay-yukleniyor'), false);
    }).catch(function (e) {
      console.error('[cps-ith-detay] yukleme hatasi:', e);
      gosterGizle($('cps-ith-detay-yukleniyor'), false);
      gosterGizle($('cps-ith-detay-hata'), true);
    });
  }

  function sayfayiDoldur(d) {
    if (!d || !d.parti) return;
    var p = d.parti;
    var para = d.para_birimi || 'USD';

    metin($('cps-ith-detay-kod'), p.Kod);
    metin($('cps-ith-detay-baslik'), p.Baslik);
    metin($('cps-ith-detay-tedarikci'), p.TedarikciAd || p.TedarikciKod || '—');
    metin($('cps-ith-detay-para'), p.ParaBirimi);

    var durumEl = $('cps-ith-detay-durum');
    if (durumEl) {
      var dm = DURUM_MAP[p.Durum] || { etiket: p.Durum, sinif: '' };
      durumEl.className = 'cps-ith-durum-etiket ' + dm.sinif;
      durumEl.textContent = dm.etiket;
    }

    metin($('cps-ith-k-tahmini'),     paraFmt(d.tahmini_toplam, para));
    metin($('cps-ith-k-gerceklesen'), paraFmt(d.gerceklesen_toplam, para));
    metin($('cps-ith-k-etkin'),       paraFmt(d.etkin_toplam, para));

    if (d.cift_maliyet != null) {
      $('cps-ith-k-cift').textContent = Number(d.cift_maliyet).toFixed(2);
      $('cps-ith-k-cift-alt').textContent = para + '/çift';
    } else {
      $('cps-ith-k-cift').textContent = '—';
      $('cps-ith-k-cift-alt').textContent = '—';
    }

    var sapmaEl = $('cps-ith-k-sapma');
    if (sapmaEl) {
      sapmaEl.className = 'cps-ith-kpi-deger';
      if (d.sapma_yuzde != null) {
        sapmaEl.textContent = yuzdeFmt(d.sapma_yuzde);
        var abs = Math.abs(d.sapma_yuzde);
        if (abs > 10) sapmaEl.classList.add('cps-ith-sapma-kritik');
        else if (abs > 5) sapmaEl.classList.add('cps-ith-sapma-uyari');
      } else {
        sapmaEl.textContent = '—';
      }
    }

    var rM = $('cps-ith-rozet-maliyet');
    if (rM) rM.textContent = (d.kalemler || []).length || '';
    var rO = $('cps-ith-rozet-odeme');
    if (rO) rO.textContent = (d.odeme_planlari || []).length || '';

    genelModul.doldur(p);
    maliyetModul.doldur(d);
    odemeModul.doldur(d);
    durumModul.doldur(d);
  }


  // =====================================================================
  // GENEL MODUL
  // =====================================================================
  var genelModul = {
    doldur: function (parti) {
      $('gn-kod').value = parti.Kod || '';
      $('gn-baslik').value = parti.Baslik || '';
      $('gn-tedarikci-kod').value = parti.TedarikciKod || '';
      $('gn-tedarikci-ad').value = parti.TedarikciAd || '';
      $('gn-para').value = parti.ParaBirimi || '';
      $('gn-yukleme').value = (parti.YuklemeTarih || '').substring(0, 10);
      $('gn-varis').value = (parti.TahminiVarisTarih || '').substring(0, 10);
      $('gn-varis-g').value = (parti.GerceklesenVarisTarih || '').substring(0, 10);
      $('gn-kg').value = parti.ToplamKg != null ? parti.ToplamKg : '';
      $('gn-cift').value = parti.ToplamCift != null ? parti.ToplamCift : '';
      $('gn-aciklama').value = parti.Aciklama || '';
    },

    kaydet: function () {
      var btn = $('cps-ith-genel-kaydet');
      var dst = $('cps-ith-genel-durum');
      btn.disabled = true;
      dst.className = 'cps-ith-kayit-durum';
      dst.textContent = 'Kaydediliyor...';

      var veri = {
        baslik: $('gn-baslik').value.trim(),
        tedarikci_kod: $('gn-tedarikci-kod').value.trim(),
        tedarikci_ad: $('gn-tedarikci-ad').value.trim(),
        yukleme_tarih: $('gn-yukleme').value,
        tahmini_varis_tarih: $('gn-varis').value,
        gerceklesen_varis_tarih: $('gn-varis-g').value,
        toplam_kg: $('gn-kg').value,
        toplam_cift: $('gn-cift').value,
        aciklama: $('gn-aciklama').value.trim(),
      };

      return api.post(url_guncelle(), veri).then(function (r) {
        btn.disabled = false;
        if (r.ok && r.data.ok) {
          dst.className = 'cps-ith-kayit-durum ok';
          dst.textContent = '✓ Kaydedildi';
          setTimeout(function () { dst.textContent = ''; }, 2500);
          detayYukle();
        } else {
          dst.className = 'cps-ith-kayit-durum hata';
          dst.textContent = '✗ ' + (r.data.hata || 'Hata');
        }
      }).catch(function () {
        btn.disabled = false;
        dst.className = 'cps-ith-kayit-durum hata';
        dst.textContent = '✗ Kaydedilemedi';
      });
    },

    bagla: function () {
      var btn = $('cps-ith-genel-kaydet');
      if (btn) btn.addEventListener('click', this.kaydet);
    },
  };


  // =====================================================================
  // MALIYET MODUL
  // =====================================================================
  var maliyetModul = {
    doldur: function (d) {
      maliyetModul.paraToplamKartlariDoldur(d);
      maliyetModul.tipOzetDoldur(d);
      maliyetModul.sapmaTablosuDoldur(d);
      maliyetModul.kalemTablosuDoldur(d);
      // YENI: Urun kartlari
      urunModul.urunKartlariDoldur(d);
    },

    paraToplamKartlariDoldur: function (d) {
      var container = $('cps-ith-para-toplam');
      if (!container) return;
      container.innerHTML = '';

      var kalemler = (d.kalemler || []).filter(function (k) { return !k.Iptal; });
      var parti = d.parti || {};
      var adet = Number(parti.ToplamCift) || 0;

      if (!kalemler.length) {
        gosterGizle(container, false);
        return;
      }
      gosterGizle(container, true);

      var toplamlar = {};
      kalemler.forEach(function (k) {
        var para = k.ParaBirimi || 'USD';
        var tip = k.Tip || 'DIGER';
        if (!toplamlar[para]) toplamlar[para] = {};
        if (!toplamlar[para][tip]) toplamlar[para][tip] = { tahmini: 0, gerceklesen: 0 };
        var tutar = Number(k.Tutar) || 0;
        if ((k.Kaynak || '').toUpperCase() === 'GERCEKLESEN') {
          toplamlar[para][tip].gerceklesen += tutar;
        } else {
          toplamlar[para][tip].tahmini += tutar;
        }
      });

      var etkinToplamlar = {};
      Object.keys(toplamlar).forEach(function (para) {
        var toplam = 0;
        Object.keys(toplamlar[para]).forEach(function (tip) {
          var t = toplamlar[para][tip];
          if (t.gerceklesen > 0) toplam += t.gerceklesen;
          else                    toplam += t.tahmini;
        });
        etkinToplamlar[para] = toplam;
      });

      var paralar = Object.keys(etkinToplamlar);
      paralar.sort(function (a, b) {
        var ia = PARA_SIRASI.indexOf(a); if (ia === -1) ia = 99;
        var ib = PARA_SIRASI.indexOf(b); if (ib === -1) ib = 99;
        return ia - ib;
      });

      paralar.forEach(function (para) {
        var toplam = etkinToplamlar[para];
        var cift = adet > 0 ? (toplam / adet) : null;
        container.appendChild(maliyetModul._toplamKart(para, toplam));
        container.appendChild(maliyetModul._ciftKart(para, cift, adet));
      });
    },

    _toplamKart: function (para, tutar) {
      var k = document.createElement('div');
      k.className = 'cps-ith-para-kart cps-ith-para-kart-' + (para.toLowerCase());
      var et = document.createElement('div');
      et.className = 'cps-ith-para-kart-etiket';
      et.textContent = 'TOPLAM ' + para;
      k.appendChild(et);
      var dg = document.createElement('div');
      dg.className = 'cps-ith-para-kart-deger';
      dg.textContent = tamParaFmt(tutar, para);
      k.appendChild(dg);
      var al = document.createElement('div');
      al.className = 'cps-ith-para-kart-alt';
      al.textContent = 'etkin toplam';
      k.appendChild(al);
      return k;
    },

    _ciftKart: function (para, cift, adet) {
      var k = document.createElement('div');
      k.className = 'cps-ith-para-kart cps-ith-para-kart-cift cps-ith-para-kart-' + (para.toLowerCase());
      var et = document.createElement('div');
      et.className = 'cps-ith-para-kart-etiket';
      et.textContent = para + ' / ÇİFT';
      k.appendChild(et);
      var dg = document.createElement('div');
      dg.className = 'cps-ith-para-kart-deger';
      if (cift != null) {
        dg.textContent = Number(cift).toLocaleString('tr-TR', {
          minimumFractionDigits: 2, maximumFractionDigits: 2,
        });
      } else {
        dg.textContent = '—';
        dg.classList.add('cps-ith-para-kart-deger-bos');
      }
      k.appendChild(dg);
      var al = document.createElement('div');
      al.className = 'cps-ith-para-kart-alt';
      if (adet > 0) al.textContent = sayiFmt(adet, 0) + ' çift';
      else {
        al.textContent = 'Çift maliyet hesaplanamadı';
        al.classList.add('cps-ith-para-kart-alt-uyari');
      }
      k.appendChild(al);
      return k;
    },

    tipOzetDoldur: function (d) {
      var tipOzet = $('cps-ith-tip-ozet');
      if (!tipOzet || !d.tip_detay) return;
      tipOzet.innerHTML = '';
      d.tip_detay.forEach(function (t) {
        var kart = document.createElement('div');
        kart.className = 'cps-ith-tip-kart';
        if (t.bekliyor) kart.classList.add('bekliyor');
        if (t.sapma_yuzde != null) {
          var abs = Math.abs(t.sapma_yuzde);
          if (abs > 10)      kart.classList.add('sapma-kritik');
          else if (abs > 5)  kart.classList.add('sapma-uyari');
        }
        var ad = document.createElement('div');
        ad.className = 'cps-ith-tip-kart-ad';
        ad.textContent = TIP_ETIKET[t.tip] || t.tip;
        kart.appendChild(ad);
        var deger = document.createElement('div');
        deger.className = 'cps-ith-tip-kart-deger';
        deger.textContent = paraFmt(t.etkin, d.para_birimi);
        kart.appendChild(deger);
        var alt = document.createElement('div');
        alt.className = 'cps-ith-tip-kart-alt';
        if (t.bekliyor)
          alt.textContent = 'Gerceklesen bekliyor · T: ' + paraFmt(t.tahmini);
        else if (t.sapma_yuzde != null && t.sapma_yuzde !== 0)
          alt.textContent = 'Sapma ' + yuzdeFmt(t.sapma_yuzde);
        else
          alt.textContent = 'T: ' + paraFmt(t.tahmini) + ' · G: ' + paraFmt(t.gerceklesen);
        kart.appendChild(alt);
        tipOzet.appendChild(kart);
      });
    },

    sapmaTablosuDoldur: function (d) {
      var tbody = $('cps-ith-sapma-tbody');
      var bos = $('cps-ith-sapma-bos');
      if (!tbody) return;
      tbody.innerHTML = '';

      var kalemler = (d.kalemler || []).filter(function (k) { return !k.Iptal; });
      if (!kalemler.length) { gosterGizle(bos, true); return; }
      gosterGizle(bos, false);

      var gruplar = {};
      kalemler.forEach(function (k) {
        var tip = k.Tip || 'DIGER';
        if (!gruplar[tip]) gruplar[tip] = { tahmini: [], gerceklesen: [] };
        var kayit = { tutar: Number(k.Tutar) || 0, para: k.ParaBirimi || 'USD' };
        if ((k.Kaynak || '').toUpperCase() === 'GERCEKLESEN') {
          gruplar[tip].gerceklesen.push(kayit);
        } else {
          gruplar[tip].tahmini.push(kayit);
        }
      });

      var satirlar = [];
      Object.keys(gruplar).forEach(function (tip) {
        var g = gruplar[tip];
        var tahmini_para = maliyetModul._paraToplam(g.tahmini);
        var gerceklesen_para = maliyetModul._paraToplam(g.gerceklesen);
        var tahmini_paralar = Object.keys(tahmini_para);
        var gerceklesen_paralar = Object.keys(gerceklesen_para);

        var t_var = tahmini_paralar.length > 0;
        var g_var = gerceklesen_paralar.length > 0;
        var tek_para = null;
        var karisik = false;

        if (t_var && g_var) {
          if (tahmini_paralar.length === 1 && gerceklesen_paralar.length === 1 &&
              tahmini_paralar[0] === gerceklesen_paralar[0]) {
            tek_para = tahmini_paralar[0];
          } else { karisik = true; }
        } else if (t_var) {
          if (tahmini_paralar.length === 1) tek_para = tahmini_paralar[0];
          else karisik = true;
        } else if (g_var) {
          if (gerceklesen_paralar.length === 1) tek_para = gerceklesen_paralar[0];
          else karisik = true;
        }

        var oncelik;
        var sapma = null;
        if (karisik) { oncelik = 3; }
        else if (!t_var && g_var) { oncelik = 4; }
        else if (t_var && !g_var) { oncelik = 2; }
        else {
          var t = tahmini_para[tek_para]; var gr = gerceklesen_para[tek_para];
          if (t > 0) {
            sapma = ((gr - t) / t) * 100;
            var abs = Math.abs(sapma);
            if (abs > 10) oncelik = 0; else if (abs > 5) oncelik = 1;
            else oncelik = 3;
          } else { oncelik = 3; }
        }
        satirlar.push({ tip: tip, tahmini_para: tahmini_para, gerceklesen_para: gerceklesen_para,
                        tek_para: tek_para, karisik: karisik, sapma: sapma, oncelik: oncelik });
      });

      satirlar.sort(function (a, b) {
        if (a.oncelik !== b.oncelik) return a.oncelik - b.oncelik;
        var sa = a.sapma != null ? Math.abs(a.sapma) : -1;
        var sb = b.sapma != null ? Math.abs(b.sapma) : -1;
        return sb - sa;
      });
      satirlar.forEach(function (r) { tbody.appendChild(maliyetModul._sapmaSatiri(r)); });
    },

    _paraToplam: function (kayitlar) {
      var map = {};
      kayitlar.forEach(function (k) {
        if (!map[k.para]) map[k.para] = 0;
        map[k.para] += k.tutar;
      });
      return map;
    },

    _sapmaSatiri: function (r) {
      var tr = document.createElement('tr');
      tr.className = 'cps-ith-sapma-satir';
      if (r.oncelik === 0) tr.classList.add('cps-ith-sapma-kritik-satir');
      else if (r.oncelik === 1) tr.classList.add('cps-ith-sapma-uyari-satir');
      else if (r.oncelik === 2) tr.classList.add('cps-ith-sapma-bekliyor-satir');
      else if (r.oncelik === 4) tr.classList.add('cps-ith-sapma-yeni-satir');
      if (r.karisik) tr.classList.add('cps-ith-sapma-mix-satir');

      var tdTip = document.createElement('td');
      tdTip.textContent = TIP_ETIKET[r.tip] || r.tip;
      tdTip.className = 'cps-ith-sapma-tip';
      tr.appendChild(tdTip);

      var tdT = document.createElement('td');
      tdT.className = 'cps-ith-th-sag';
      maliyetModul._paraHucreDoldur(tdT, r.tahmini_para);
      tr.appendChild(tdT);

      var tdG = document.createElement('td');
      tdG.className = 'cps-ith-th-sag';
      maliyetModul._paraHucreDoldur(tdG, r.gerceklesen_para);
      tr.appendChild(tdG);

      var tdE = document.createElement('td');
      tdE.className = 'cps-ith-th-sag';
      var etkinMap = Object.keys(r.gerceklesen_para).length > 0 ? r.gerceklesen_para : r.tahmini_para;
      maliyetModul._paraHucreDoldur(tdE, etkinMap);
      tr.appendChild(tdE);

      var tdFark = document.createElement('td');
      tdFark.className = 'cps-ith-th-sag';
      if (r.karisik) {
        tdFark.textContent = '—';
        tdFark.classList.add('cps-ith-sapma-mix-hucre');
      } else if (r.oncelik === 2) {
        tdFark.textContent = '—';
      } else if (r.oncelik === 4) {
        var gpara = Object.keys(r.gerceklesen_para)[0];
        var gv = r.gerceklesen_para[gpara];
        tdFark.textContent = '+' + tamParaFmt(gv, gpara);
        tdFark.classList.add('cps-ith-sapma-yeni-hucre');
      } else if (r.tek_para) {
        var t = r.tahmini_para[r.tek_para] || 0;
        var gr = r.gerceklesen_para[r.tek_para] || 0;
        var fark = gr - t;
        var isaret = fark > 0 ? '+' : (fark < 0 ? '' : '');
        tdFark.textContent = isaret + tamParaFmt(fark, r.tek_para);
        if (r.oncelik === 0) tdFark.classList.add('cps-ith-sapma-kritik');
        else if (r.oncelik === 1) tdFark.classList.add('cps-ith-sapma-uyari');
      } else { tdFark.textContent = '—'; }
      tr.appendChild(tdFark);

      var tdSapma = document.createElement('td');
      tdSapma.className = 'cps-ith-th-sag';
      if (r.sapma != null) {
        tdSapma.textContent = yuzdeFmt(r.sapma);
        if (r.oncelik === 0) tdSapma.classList.add('cps-ith-sapma-kritik');
        else if (r.oncelik === 1) tdSapma.classList.add('cps-ith-sapma-uyari');
      } else { tdSapma.textContent = '—'; }
      tr.appendChild(tdSapma);

      var tdDurum = document.createElement('td');
      tdDurum.className = 'cps-ith-sapma-durum';
      maliyetModul._durumHucreDoldur(tdDurum, r);
      tr.appendChild(tdDurum);
      return tr;
    },

    _paraHucreDoldur: function (td, paraMap) {
      var paralar = Object.keys(paraMap);
      if (paralar.length === 0) { td.textContent = '—'; return; }
      td.innerHTML = '';
      paralar.forEach(function (p) {
        var satir = document.createElement('div');
        satir.className = 'cps-ith-sapma-para-satir';
        satir.textContent = tamParaFmt(paraMap[p], p);
        td.appendChild(satir);
      });
    },

    _durumHucreDoldur: function (td, r) {
      var et = document.createElement('span');
      et.className = 'cps-ith-durum-etiket';
      if (r.karisik) {
        et.textContent = '⚠ Karışık Para Birimi';
        et.classList.add('cps-ith-d-teslim');
        td.appendChild(et);
        var alt = document.createElement('div');
        alt.className = 'cps-ith-sapma-alt-not';
        alt.textContent = 'Fark hesaplanamadı (farklı para birimi)';
        td.appendChild(alt);
        return;
      }
      if (r.oncelik === 0) { et.textContent = 'Kritik Sapma'; et.classList.add('cps-ith-d-iptal'); }
      else if (r.oncelik === 1) { et.textContent = 'Uyarı'; et.classList.add('cps-ith-d-teslim'); }
      else if (r.oncelik === 2) { et.textContent = 'Gerçekleşen Bekliyor'; et.classList.add('cps-ith-d-taslak'); }
      else if (r.oncelik === 4) { et.textContent = 'Tahmini Yok (Yeni)'; et.classList.add('cps-ith-d-aktif'); }
      else { et.textContent = 'Normal'; et.classList.add('cps-ith-d-kapali'); }
      td.appendChild(et);
    },

    kalemTablosuDoldur: function (d) {
      var tbody = $('cps-ith-kalem-tbody');
      var bos = $('cps-ith-kalem-bos');
      if (!tbody) return;
      tbody.innerHTML = '';
      var kalemler = d.kalemler || [];
      if (!kalemler.length) { gosterGizle(bos, true); return; }
      gosterGizle(bos, false);

      kalemler.forEach(function (k) {
        var tr = document.createElement('tr');
        function td(html) {
          var c = document.createElement('td');
          if (typeof html === 'string') c.textContent = html;
          else c.appendChild(html);
          return c;
        }
        tr.appendChild(td(TIP_ETIKET[k.Tip] || k.Tip));
        tr.appendChild(td(k.Kaynak === 'GERCEKLESEN' ? 'Gerçekleşen' : 'Tahmini'));
        var tutarTd = td(tamParaFmt(k.Tutar));
        tutarTd.className = 'cps-ith-th-sag';
        tr.appendChild(tutarTd);
        tr.appendChild(td(k.ParaBirimi || '—'));
        var kurTd = td(k.KurDegeri != null ? Number(k.KurDegeri).toFixed(4) : '—');
        kurTd.className = 'cps-ith-th-sag';
        tr.appendChild(kurTd);
        tr.appendChild(td(k.FaturaNo || '—'));
        tr.appendChild(td(k.CariAd || k.CariKod || '—'));
        tr.appendChild(td(k.Aciklama || '—'));

        var aksiyon = document.createElement('div');
        aksiyon.className = 'cps-ith-kalem-aksiyon';
        var silBtn = document.createElement('button');
        silBtn.type = 'button';
        silBtn.className = 'cps-ith-btn-ikon';
        silBtn.textContent = 'Sil';
        silBtn.addEventListener('click', function () { maliyetModul.kalemSil(k.Id); });
        aksiyon.appendChild(silBtn);
        var aksTd = td(aksiyon);
        aksTd.className = 'cps-ith-th-sag';
        tr.appendChild(aksTd);
        tbody.appendChild(tr);
      });
    },

    formuAc: function () {
      $('km-tip').value = 'FOB';
      $('km-kaynak').value = 'TAHMINI';
      $('km-tutar').value = '';
      $('km-para').value = (DETAY_VERI && DETAY_VERI.para_birimi) || 'USD';
      $('km-kur').value = '';
      $('km-aciklama').value = '';
      $('km-fatura-no').value = '';
      $('km-fatura-tarih').value = '';
      $('km-cari-kod').value = '';
      $('km-cari-ad').value = '';
      gosterGizle($('cps-ith-kalem-form'), true);
      $('km-tutar').focus();
    },

    formuKapat: function () { gosterGizle($('cps-ith-kalem-form'), false); },

    kalemKaydet: function () {
      var tutar = parseFloat($('km-tutar').value);
      if (isNaN(tutar) || tutar < 0) { alert('Tutar zorunlu (pozitif sayi).'); return; }
      var veri = {
        parti_id: PARTI_ID,
        tip: $('km-tip').value,
        kaynak: $('km-kaynak').value,
        tutar: tutar,
        para_birimi: $('km-para').value,
        manuel_kur: $('km-kur').value || null,
        aciklama: $('km-aciklama').value.trim(),
        fatura_no: $('km-fatura-no').value.trim(),
        fatura_tarih: $('km-fatura-tarih').value,
        cari_kod: $('km-cari-kod').value.trim(),
        cari_ad: $('km-cari-ad').value.trim(),
      };
      return api.post('/api/ithalat/maliyet/ekle', veri).then(function (r) {
        if (r.ok && r.data.ok) { maliyetModul.formuKapat(); detayYukle(); }
        else alert('Eklenemedi: ' + (r.data.hata || 'hata'));
      }).catch(function () { alert('Baglanti hatasi'); });
    },

    kalemSil: function (kalem_id) {
      if (!confirm('Bu maliyet kalemini silmek istediginize emin misiniz?')) return;
      api.post('/api/ithalat/maliyet/' + kalem_id + '/sil', {}).then(function (r) {
        if (r.ok && r.data.ok) detayYukle();
        else alert('Silinemedi: ' + (r.data.hata || 'hata'));
      }).catch(function () { alert('Baglanti hatasi'); });
    },

    bagla: function () {
      var ekleBtn = $('cps-ith-btn-kalem-ekle');
      if (ekleBtn) ekleBtn.addEventListener('click', this.formuAc);
      var iptalBtn = $('cps-ith-kalem-iptal');
      if (iptalBtn) iptalBtn.addEventListener('click', this.formuKapat);
      var kaydetBtn = $('cps-ith-kalem-kaydet');
      if (kaydetBtn) kaydetBtn.addEventListener('click', this.kalemKaydet);
    },
  };


  // =====================================================================
  // URUN MODUL - KIYAS ODAKLI VERSION
  // =====================================================================
  var urunModul = {
    URUN_REGEX: /Urun:\s*([A-Z0-9][A-Z0-9\-_]*)/i,

    /**
     * Parti detay verisi gelince cagrilir.
     * FOB kalemlerinden urun kodlarini cikart, her biri icin mini kart olustur.
     * Her API cagrisinda 'bu_parti_id' parametresi gonderilir - boylece
     * sapma ve kiyaslama sunucudan hazir gelir.
     */
    urunKartlariDoldur: function (d) {
      var container = $('cps-ith-urun-kartlari');
      var bos = $('cps-ith-urun-bos');
      if (!container) return;
      container.innerHTML = '';

      var kalemler = (d.kalemler || []).filter(function (k) { return !k.Iptal; });

      var urunKodlari = [];
      var gorulen = {};
      kalemler.forEach(function (k) {
        if ((k.Tip || '').toUpperCase() !== 'FOB') return;
        var ac = k.Aciklama || '';
        var m = ac.match(urunModul.URUN_REGEX);
        if (m && m[1]) {
          var kod = m[1];
          if (!gorulen[kod]) {
            gorulen[kod] = true;
            urunKodlari.push(kod);
          }
        }
      });

      if (urunKodlari.length === 0) {
        gosterGizle(bos, true);
        return;
      }
      gosterGizle(bos, false);

      urunKodlari.forEach(function (kod) {
        var kart = urunModul._miniKartIskelet(kod);
        container.appendChild(kart);
        urunModul._miniKartiDoldur(kart, kod);
      });
    },

    _miniKartIskelet: function (kod) {
      var k = document.createElement('div');
      k.className = 'cps-ith-urun-kart';
      k.dataset.urun = kod;

      var ust = document.createElement('div');
      ust.className = 'cps-ith-urun-kart-ust';
      var kodEl = document.createElement('div');
      kodEl.className = 'cps-ith-urun-kart-kod';
      kodEl.textContent = kod;
      ust.appendChild(kodEl);
      var rozet = document.createElement('span');
      rozet.className = 'cps-ith-urun-kart-rozet';
      rozet.textContent = '...';
      ust.appendChild(rozet);
      k.appendChild(ust);

      // Govde - yukleniyor placeholder
      var govde = document.createElement('div');
      govde.className = 'cps-ith-urun-kart-govde';
      govde.innerHTML = '<div class="cps-ith-urun-kart-yukleniyor">Yükleniyor...</div>';
      k.appendChild(govde);

      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cps-ith-btn cps-ith-btn-ghost cps-ith-btn-sm cps-ith-urun-kart-btn';
      btn.textContent = 'Detay Göster →';
      btn.addEventListener('click', function () {
        urunModul.detayModalAc(kod);
      });
      k.appendChild(btn);
      return k;
    },

    _miniKartiDoldur: function (kart, kod) {
      api.get(url_urun_kart(kod, PARTI_ID)).then(function (veri) {
        if (!veri) return urunModul._miniKartHata(kart, 'Veri yok');

        var rozet = kart.querySelector('.cps-ith-urun-kart-rozet');
        var govde = kart.querySelector('.cps-ith-urun-kart-govde');

        if (!veri.bulundu) {
          rozet.textContent = '0';
          govde.innerHTML = '<div class="cps-ith-urun-kart-bos-mesaj">Hiç alım yok</div>';
          kart.classList.add('cps-ith-urun-kart-bos');
          return;
        }

        rozet.textContent = veri.toplam_alim;
        rozet.className = 'cps-ith-urun-kart-rozet cps-ith-urun-kart-rozet-dolu';

        var kiyas = veri.kiyas || {};
        var bu = kiyas.bu_parti || {};
        var onceki = kiyas.onceki_ortalama || {};

        // KARAR TRY BAZLI (ana metrik)
        // Eger TRY yoksa USD'ye dus
        var sapma_karar = kiyas.sapma_try;
        var sapma_karar_para = 'TRY';
        if (sapma_karar == null) {
          sapma_karar = kiyas.sapma_usd;
          sapma_karar_para = 'USD';
        }

        // ±5% araliginda "normal" kabul et
        var sapma_yon;
        if (sapma_karar == null) {
          sapma_yon = null;
        } else if (Math.abs(sapma_karar) <= 5) {
          sapma_yon = 'normal';
        } else if (sapma_karar > 0) {
          sapma_yon = 'pahali';
        } else {
          sapma_yon = 'ucuz';
        }

        var yeterli = kiyas.yeterli_veri === true;

        // YENI: Kriter etiketi - kart basligina ekle
        var ustEl = kart.querySelector('.cps-ith-urun-kart-ust');
        if (ustEl && kiyas.kriter) {
          var krEt = document.createElement('span');
          krEt.className = 'cps-ith-urun-kart-kriter ' +
            (GUVENILIRLIK_SINIF[kiyas.guvenilirlik] || '');
          krEt.textContent = KRITER_KISA_ETIKET[kiyas.kriter] || kiyas.kriter;
          krEt.title = kiyas.kriter_aciklama || '';
          // Rozet'ten once ekle
          ustEl.insertBefore(krEt, rozet);
        }

        // Govdeyi baştan kur
        govde.innerHTML = '';

        // 1. satir: Bu parti cift maliyet (USD + TRY birlikte)
        var s1 = document.createElement('div');
        s1.className = 'cps-ith-urun-kart-satir';
        var s1e = document.createElement('span');
        s1e.className = 'cps-ith-urun-kart-et';
        s1e.textContent = 'Bu parti:';
        s1.appendChild(s1e);
        var s1d = document.createElement('span');
        s1d.className = 'cps-ith-urun-kart-dv';
        var s1Parts = [];
        if (bu.cift_maliyet_usd != null) {
          s1Parts.push('<strong>' + Number(bu.cift_maliyet_usd).toFixed(2) + '</strong> USD');
        }
        if (bu.cift_maliyet_try != null) {
          s1Parts.push('<strong>' + Number(bu.cift_maliyet_try).toFixed(2) + '</strong> TRY');
        }
        s1d.innerHTML = s1Parts.length ? s1Parts.join(' · ') : '—';
        s1.appendChild(s1d);
        govde.appendChild(s1);

        if (yeterli && (onceki.cift_maliyet_usd != null || onceki.cift_maliyet_try != null)) {
          // 2. satir: Önceki ortalama (USD + TRY birlikte)
          var s2 = document.createElement('div');
          s2.className = 'cps-ith-urun-kart-satir';
          var s2e = document.createElement('span');
          s2e.className = 'cps-ith-urun-kart-et';
          s2e.textContent = 'Önceki ort:';
          s2.appendChild(s2e);
          var s2d = document.createElement('span');
          s2d.className = 'cps-ith-urun-kart-dv';
          var s2Parts = [];
          if (onceki.cift_maliyet_usd != null) {
            s2Parts.push(Number(onceki.cift_maliyet_usd).toFixed(2) + ' USD');
          }
          if (onceki.cift_maliyet_try != null) {
            s2Parts.push(Number(onceki.cift_maliyet_try).toFixed(2) + ' TRY');
          }
          s2d.innerHTML = s2Parts.length ? s2Parts.join(' · ') : '—';
          s2.appendChild(s2d);
          govde.appendChild(s2);

          // 3. satir: KARAR SAPMA (TRY bazli - ana metrik)
          if (sapma_karar != null) {
            var s3 = document.createElement('div');
            s3.className = 'cps-ith-urun-kart-sapma';
            var isaret = sapma_karar > 0 ? '+' : '';
            var etiket = 'TRY sapma: ' + isaret + sapma_karar.toFixed(1) + '%';
            if (sapma_karar_para === 'USD') {
              // TRY yok, USD'ye dustuk
              etiket = 'USD sapma: ' + isaret + sapma_karar.toFixed(1) + '% (TRY yok)';
            }
            var abs = Math.abs(sapma_karar);

            if (sapma_yon === 'normal') {
              s3.classList.add('cps-ith-urun-sapma-esit');
              etiket += '  ⚪ normal (±5%)';
            } else if (sapma_yon === 'pahali') {
              if (abs > 10) s3.classList.add('cps-ith-urun-sapma-kritik-pahali');
              else s3.classList.add('cps-ith-urun-sapma-uyari-pahali');
              etiket += '  🔴 pahalı';
            } else if (sapma_yon === 'ucuz') {
              if (abs > 10) s3.classList.add('cps-ith-urun-sapma-kritik-ucuz');
              else s3.classList.add('cps-ith-urun-sapma-uyari-ucuz');
              etiket += '  🟢 ucuz';
            }
            s3.textContent = etiket;
            govde.appendChild(s3);

            // 4. satir: USD referans (karar TRY ile verdiyse, USD de bilgi amacli)
            if (sapma_karar_para === 'TRY' && kiyas.sapma_usd != null) {
              var s4 = document.createElement('div');
              s4.className = 'cps-ith-urun-kart-sapma-ref';
              var uz_isaret = kiyas.sapma_usd > 0 ? '+' : '';
              s4.textContent = '(USD referans: ' + uz_isaret +
                               Number(kiyas.sapma_usd).toFixed(1) + '%)';
              govde.appendChild(s4);
            }
          }
        } else {
          // Kiyas icin yetersiz veri
          var s2 = document.createElement('div');
          s2.className = 'cps-ith-urun-kart-satir cps-ith-urun-kart-tek-alim';
          s2.textContent = 'Kıyas yok (tek alım)';
          govde.appendChild(s2);
        }
      }).catch(function (e) {
        console.warn('[urun-kart] fetch hata:', e);
        urunModul._miniKartHata(kart, 'Veri alınamadı');
      });
    },

    _miniKartHata: function (kart, mesaj) {
      var govde = kart.querySelector('.cps-ith-urun-kart-govde');
      if (govde) govde.innerHTML = '<div class="cps-ith-urun-kart-bos-mesaj">' + mesaj + '</div>';
      kart.classList.add('cps-ith-urun-kart-hata');
    },

    /**
     * "Detay Göster" butonu - modal aç, API'den kiyasli veriyi çek.
     */
    detayModalAc: function (kod) {
      var modal = $('cps-ith-urun-modal');
      var baslikEl = $('cps-ith-modal-urun');
      var altEl = $('cps-ith-modal-alt');
      var icerikEl = $('cps-ith-modal-icerik');
      if (!modal) return;

      baslikEl.textContent = kod;
      altEl.textContent = 'Yükleniyor...';
      icerikEl.innerHTML = '<div class="cps-ith-tablo-durum">' +
                           '<span class="cps-ith-spinner"></span> Yukleniyor...</div>';

      gosterGizle(modal, true);
      document.body.style.overflow = 'hidden';

      api.get(url_urun_kart(kod, PARTI_ID)).then(function (veri) {
        urunModul._modalDoldur(veri, kod);
      }).catch(function (e) {
        icerikEl.innerHTML = '<div class="cps-ith-tablo-durum cps-ith-hata">' +
                             'Veri alınamadı: ' + (e.message || '') + '</div>';
      });
    },

    detayModalKapat: function () {
      var modal = $('cps-ith-urun-modal');
      gosterGizle(modal, false);
      document.body.style.overflow = '';
    },

    _modalDoldur: function (veri, kod) {
      var altEl = $('cps-ith-modal-alt');
      var icerikEl = $('cps-ith-modal-icerik');

      if (!veri || !veri.bulundu) {
        altEl.textContent = 'Hiç alım yok';
        icerikEl.innerHTML = '<div class="cps-ith-tablo-durum">' +
          (veri && veri.mesaj ? veri.mesaj : 'Bu ürün için veri yok.') +
          '</div>';
        return;
      }

      // Alt bilgi
      var altParts = [];
      altParts.push(veri.toplam_alim + ' alım');
      if (veri.son_alim_tarihi) altParts.push('Son: ' + tarihFmt(veri.son_alim_tarihi));
      if (veri.strateji) altParts.push('Arama: ' + (STRATEJI_ETIKET[veri.strateji] || veri.strateji));
      altEl.textContent = altParts.join(' · ');

      // Icerigi kur
      icerikEl.innerHTML = '';

      // 1. Kiyas ozeti (en ustte, en onemli)
      icerikEl.appendChild(urunModul._modalKiyasOzeti(veri.kiyas, veri.toplam_alim));

      // 2. Tum alimlar ortalamasi (mevcut)
      icerikEl.appendChild(urunModul._modalOrtalama(veri.ortalama));

      // 3. Parti tablosu (fark % kolonu ile)
      icerikEl.appendChild(urunModul._modalPartiler(veri.partiler, veri.bu_parti_id));

      // 4. Kirilimlar
      icerikEl.appendChild(urunModul._modalKirilimlar(veri.tedarikci_kirilim, veri.tasima_kirilim));
    },

    _modalKiyasOzeti: function (kiyas, toplam_alim) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum cps-ith-modal-kiyas-bolum';
      var b = document.createElement('h4');
      b.className = 'cps-ith-modal-bolum-baslik';
      b.textContent = 'Kıyas Özeti';
      d.appendChild(b);

      if (!kiyas) {
        d.innerHTML += '<div class="cps-ith-modal-bos">Kıyas verisi yok</div>';
        return d;
      }

      // YENI: Kiyas kriteri bilgi bandi (en ustte, en onemli)
      if (kiyas.kriter) {
        var band = document.createElement('div');
        band.className = 'cps-ith-kriter-band ' +
          (GUVENILIRLIK_SINIF[kiyas.guvenilirlik] || '');

        var baslik = document.createElement('div');
        baslik.className = 'cps-ith-kriter-band-baslik';
        var ikon = '🎯';
        if (kiyas.guvenilirlik === 'yuksek') ikon = '✅';
        else if (kiyas.guvenilirlik === 'orta') ikon = '🎯';
        else if (kiyas.guvenilirlik === 'dusuk') ikon = '⚠️';
        else if (kiyas.guvenilirlik === 'yok') ikon = 'ℹ️';
        baslik.textContent = ikon + ' Kıyas kriteri: ' +
          (KRITER_KISA_ETIKET[kiyas.kriter] || kiyas.kriter);
        band.appendChild(baslik);

        if (kiyas.kriter_aciklama) {
          var ac = document.createElement('div');
          ac.className = 'cps-ith-kriter-band-aciklama';
          ac.textContent = kiyas.kriter_aciklama;
          band.appendChild(ac);
        }

        // Detay satiri - sayilarla
        var detay = document.createElement('div');
        detay.className = 'cps-ith-kriter-band-detay';
        var parcalar = [];
        if (kiyas.bu_parti_gtip) {
          parcalar.push('Bu parti GTIP: ' + kiyas.bu_parti_gtip);
        } else if (toplam_alim > 0 && kiyas.kriter &&
                   kiyas.kriter.indexOf('urun_kodu') === 0) {
          parcalar.push('Bu parti GTIP yok');
        }
        if (kiyas.gtip_eslesme_sayisi > 0) {
          parcalar.push(kiyas.gtip_eslesme_sayisi + ' partide GTIP aynı');
        }
        if (kiyas.farkli_gtip_sayisi > 0) {
          parcalar.push('⚠ ' + kiyas.farkli_gtip_sayisi + ' partide GTIP farklı');
        }
        if (kiyas.gtip_olmayan_sayisi > 0) {
          parcalar.push(kiyas.gtip_olmayan_sayisi + ' partide GTIP yok');
        }
        if (kiyas.farkli_tedarikci_sayisi > 1) {
          parcalar.push(kiyas.farkli_tedarikci_sayisi + ' farklı tedarikçi');
        } else if (kiyas.farkli_tedarikci_sayisi === 1) {
          parcalar.push('Tek tedarikçi');
        }
        detay.textContent = parcalar.join(' · ');
        if (parcalar.length > 0) band.appendChild(detay);

        d.appendChild(band);
      }

      var bu = kiyas.bu_parti;
      var onceki = kiyas.onceki_ortalama;
      var minP = kiyas.min_parti;
      var maxP = kiyas.max_parti;
      var yeterli = kiyas.yeterli_veri === true;

      if (!bu) {
        // Bu parti bu urunde yok (olmamasi lazim ama fail-safe)
        d.innerHTML += '<div class="cps-ith-modal-bos">Bu parti referans alınamadı</div>';
        return d;
      }

      if (!yeterli) {
        // Tek alim varsa
        var uyari = document.createElement('div');
        uyari.className = 'cps-ith-modal-kiyas-tek';
        uyari.textContent = '⚠ Bu ürün için geçmiş alım bulunamadı. ' +
                            'Sadece bu partide yer alıyor, kıyaslama yapılamaz.';
        d.appendChild(uyari);
        // Yine de bu parti bilgisini goster
        var grid1 = document.createElement('div');
        grid1.className = 'cps-ith-modal-kiyas-grid';
        grid1.appendChild(urunModul._kiyasMetrik('Bu parti', bu.kod,
          bu.cift_maliyet_usd, 'USD/çift', bu.tarih, 'bu'));
        d.appendChild(grid1);
        return d;
      }

      // Normal kiyas gridi - 4 kart
      var grid = document.createElement('div');
      grid.className = 'cps-ith-modal-kiyas-grid';

      // Bu parti - TRY bazli sapma (ana karar metrigi), USD referans
      var sapmaKarar_try = kiyas.sapma_try;
      var sapmaKarar_yon_try = null;
      if (sapmaKarar_try != null) {
        if (Math.abs(sapmaKarar_try) <= 5) sapmaKarar_yon_try = 'normal';
        else if (sapmaKarar_try > 0) sapmaKarar_yon_try = 'pahali';
        else sapmaKarar_yon_try = 'ucuz';
      }

      grid.appendChild(urunModul._kiyasMetrik(
        'Bu parti', bu.kod,
        bu.cift_maliyet_usd, 'USD/çift', bu.tarih, 'bu',
        {
          sapma_try: sapmaKarar_try,
          sapma_yon_try: sapmaKarar_yon_try,
          sapma_usd: kiyas.sapma_usd,
        },
      ));

      // Onceki ortalama
      grid.appendChild(urunModul._kiyasMetrik(
        'Önceki ortalama', (onceki.dahil_edilen_alim_usd || 0) + ' alım',
        onceki.cift_maliyet_usd, 'USD/çift', null, 'onceki',
      ));

      // Min
      if (minP) {
        grid.appendChild(urunModul._kiyasMetrik(
          'En düşük', minP.kod,
          minP.cift_maliyet_usd, 'USD/çift', minP.tarih, 'min',
        ));
      }

      // Max
      if (maxP) {
        grid.appendChild(urunModul._kiyasMetrik(
          'En yüksek', maxP.kod,
          maxP.cift_maliyet_usd, 'USD/çift', maxP.tarih, 'max',
        ));
      }

      d.appendChild(grid);

      // TRY bilgisi eklenmeli mi?
      if (bu.cift_maliyet_try != null && onceki.cift_maliyet_try != null) {
        var tryBar = document.createElement('div');
        tryBar.className = 'cps-ith-modal-kiyas-try';
        var metin = 'TRY: Bu parti ' + Number(bu.cift_maliyet_try).toFixed(2) +
                    ' / Önceki ort ' + Number(onceki.cift_maliyet_try).toFixed(2);
        if (kiyas.sapma_try != null) {
          var iz = kiyas.sapma_try > 0 ? '+' : '';
          metin += '  ·  Sapma: ' + iz + Number(kiyas.sapma_try).toFixed(1) + '%';
        }
        tryBar.textContent = metin;
        d.appendChild(tryBar);
      }

      // Para birimi karisik uyarisi
      if (kiyas.para_birimi_karisik) {
        var pbU = document.createElement('div');
        pbU.className = 'cps-ith-modal-kiyas-uyari';
        pbU.textContent = '⚠ Karışık para birimleri tespit edildi — USD ile TRY kıyaslaması güvenilir olmayabilir.';
        d.appendChild(pbU);
      }

      return d;
    },

    _kiyasMetrik: function (etiket, altBilgi, deger, birim, tarih, tip, sapmaBilgi) {
      var k = document.createElement('div');
      k.className = 'cps-ith-modal-kiyas-kart cps-ith-modal-kiyas-kart-' + tip;

      var et = document.createElement('div');
      et.className = 'cps-ith-modal-kiyas-et';
      et.textContent = etiket;
      k.appendChild(et);

      var dv = document.createElement('div');
      dv.className = 'cps-ith-modal-kiyas-dv';
      if (deger != null) {
        dv.innerHTML = '<strong>' + Number(deger).toFixed(2) + '</strong>' +
          ' <span class="cps-ith-modal-kiyas-br">' + birim + '</span>';
      } else {
        dv.textContent = '—';
      }
      k.appendChild(dv);

      var alt = document.createElement('div');
      alt.className = 'cps-ith-modal-kiyas-alt';
      var altParts = [];
      if (altBilgi) altParts.push(altBilgi);
      if (tarih) altParts.push(tarihFmt(tarih));
      alt.textContent = altParts.join(' · ');
      k.appendChild(alt);

      // Sapma (sadece 'bu' tipinde)
      if (sapmaBilgi) {
        var sapma_try = sapmaBilgi.sapma_try;
        var sapma_usd = sapmaBilgi.sapma_usd;
        var sapma_yon = sapmaBilgi.sapma_yon_try;

        // TRY karar kabul et, yoksa USD'ye dus
        if (sapma_try == null && sapma_usd != null) {
          sapma_try = sapma_usd;
          if (Math.abs(sapma_try) <= 5) sapma_yon = 'normal';
          else if (sapma_try > 0) sapma_yon = 'pahali';
          else sapma_yon = 'ucuz';
        }

        if (sapma_try != null) {
          var sp = document.createElement('div');
          sp.className = 'cps-ith-modal-kiyas-sapma';
          var iz = sapma_try > 0 ? '+' : '';
          var icerik = iz + Number(sapma_try).toFixed(1) + '% TRY';
          var abs = Math.abs(sapma_try);

          if (sapma_yon === 'normal') {
            icerik += ' ⚪ normal (±5%)';
            sp.classList.add('cps-ith-modal-sapma-normal');
          } else if (sapma_yon === 'pahali') {
            icerik += ' 🔴 pahalı';
            if (abs > 15) sp.classList.add('cps-ith-modal-sapma-kritik');
            else sp.classList.add('cps-ith-modal-sapma-uyari');
          } else if (sapma_yon === 'ucuz') {
            icerik += ' 🟢 ucuz';
            if (abs > 15) sp.classList.add('cps-ith-modal-sapma-ucuz');
            else sp.classList.add('cps-ith-modal-sapma-hafif-ucuz');
          }
          sp.textContent = icerik;
          k.appendChild(sp);

          // USD referans satiri
          if (sapma_usd != null) {
            var spRef = document.createElement('div');
            spRef.className = 'cps-ith-modal-kiyas-sapma-ref';
            var izRef = sapma_usd > 0 ? '+' : '';
            spRef.textContent = 'USD referans: ' + izRef +
                                Number(sapma_usd).toFixed(1) + '%';
            k.appendChild(spRef);
          }
        }
      }

      return k;
    },

    _modalOrtalama: function (ort) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum';
      var b = document.createElement('h4');
      b.className = 'cps-ith-modal-bolum-baslik';
      b.textContent = 'Tüm Alımlar Ortalaması (bu parti dahil)';
      d.appendChild(b);

      if (!ort) {
        d.innerHTML += '<div class="cps-ith-modal-bos">Hesaplama yapılamadı</div>';
        return d;
      }

      var grid = document.createElement('div');
      grid.className = 'cps-ith-modal-ortalama-grid';

      function metrik(etiket, deger, birim, alt) {
        var k = document.createElement('div');
        k.className = 'cps-ith-modal-metrik';
        var et = document.createElement('div');
        et.className = 'cps-ith-modal-metrik-et';
        et.textContent = etiket;
        k.appendChild(et);
        var dv = document.createElement('div');
        dv.className = 'cps-ith-modal-metrik-dv';
        if (deger == null) {
          dv.textContent = '—';
          dv.classList.add('cps-ith-modal-metrik-dv-bos');
        } else {
          dv.innerHTML = '<strong>' + Number(deger).toFixed(2) + '</strong> ' +
                         '<span class="cps-ith-modal-metrik-br">' + birim + '</span>';
        }
        k.appendChild(dv);
        if (alt) {
          var al = document.createElement('div');
          al.className = 'cps-ith-modal-metrik-alt';
          al.textContent = alt;
          k.appendChild(al);
        }
        return k;
      }

      grid.appendChild(metrik('Çift Maliyet USD', ort.cift_maliyet_usd, 'USD/çift',
        ort.dahil_edilen_alim + ' alım (tümü)'));
      grid.appendChild(metrik('Çift Maliyet TRY', ort.cift_maliyet_try, 'TRY/çift',
        (ort.cift_maliyet_try_dahil || 0) + ' alımdan'));
      grid.appendChild(metrik('FOB Birim USD', ort.fob_birim_usd, 'USD/çift',
        (ort.fob_dahil_alim || 0) + ' alımdan'));
      grid.appendChild(metrik('Navlun Çift USD', ort.navlun_cift_usd, 'USD/çift',
        (ort.navlun_dahil_alim || 0) + ' alımdan'));

      d.appendChild(grid);

      if (ort.toplam_cift) {
        var alt = document.createElement('div');
        alt.className = 'cps-ith-modal-ortalama-alt';
        alt.textContent = 'Toplam ' + sayiFmt(ort.toplam_cift, 0) + ' çift · ' +
                          ort.dahil_edilen_alim + ' alım';
        d.appendChild(alt);
      }
      return d;
    },

    _modalPartiler: function (partiler, bu_parti_id) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum';
      var b = document.createElement('h4');
      b.className = 'cps-ith-modal-bolum-baslik';
      b.textContent = 'Alım Geçmişi';
      d.appendChild(b);

      if (!partiler || !partiler.length) {
        d.innerHTML += '<div class="cps-ith-modal-bos">Parti yok</div>';
        return d;
      }

      var tbl = document.createElement('table');
      tbl.className = 'cps-ith-tablo cps-ith-tablo-alt cps-ith-modal-partiler-tablo';
      tbl.innerHTML = '<thead><tr>' +
        '<th>Parti</th>' +
        '<th>Tarih</th>' +
        '<th>Tedarikçi</th>' +
        '<th>GTIP</th>' +
        '<th class="cps-ith-th-sag">Çift</th>' +
        '<th class="cps-ith-th-sag">USD/Çift</th>' +
        '<th class="cps-ith-th-sag">TRY/Çift</th>' +
        '<th>Taşıma</th>' +
        '<th class="cps-ith-th-sag">Fark %</th>' +
        '</tr></thead>';
      var tbody = document.createElement('tbody');

      partiler.forEach(function (p) {
        var tr = document.createElement('tr');
        // Bu parti ise satiri vurgula
        if (bu_parti_id && p.parti_id === bu_parti_id) {
          tr.classList.add('cps-ith-modal-bu-parti-satir');
        }
        // En dusuk/yuksek isaretle
        if (p.en_dusuk_mu) tr.classList.add('cps-ith-modal-min-satir');
        if (p.en_yuksek_mu) tr.classList.add('cps-ith-modal-max-satir');

        function td(t, cls) {
          var c = document.createElement('td');
          c.textContent = (t == null || t === '') ? '—' : String(t);
          if (cls) c.className = cls;
          return c;
        }

        // Parti kod + etiketler (bu parti, min, max)
        var kodTd = document.createElement('td');
        var a = document.createElement('a');
        a.href = '/ithalat/parti/' + p.parti_id;
        a.target = '_blank';
        a.textContent = p.kod;
        a.className = 'cps-ith-modal-parti-link';
        kodTd.appendChild(a);
        if (bu_parti_id && p.parti_id === bu_parti_id) {
          var bm = document.createElement('span');
          bm.className = 'cps-ith-modal-parti-etiket cps-ith-parti-et-bu';
          bm.textContent = ' BU PARTİ';
          kodTd.appendChild(bm);
        }
        if (p.en_dusuk_mu && !(bu_parti_id && p.parti_id === bu_parti_id)) {
          var mn = document.createElement('span');
          mn.className = 'cps-ith-modal-parti-etiket cps-ith-parti-et-min';
          mn.textContent = ' EN DÜŞÜK';
          kodTd.appendChild(mn);
        }
        if (p.en_yuksek_mu && !(bu_parti_id && p.parti_id === bu_parti_id)) {
          var mx = document.createElement('span');
          mx.className = 'cps-ith-modal-parti-etiket cps-ith-parti-et-max';
          mx.textContent = ' EN YÜKSEK';
          kodTd.appendChild(mx);
        }
        tr.appendChild(kodTd);

        tr.appendChild(td(tarihFmt(p.tarih)));
        tr.appendChild(td(p.tedarikci_ad));

        // GTIP hucresi - bu parti ile ayni mi kontrol et
        var gtipTd = document.createElement('td');
        if (p.gtip) {
          var gtipSpan = document.createElement('span');
          gtipSpan.textContent = p.gtip;
          gtipSpan.className = 'cps-ith-modal-gtip';
          gtipTd.appendChild(gtipSpan);
        } else {
          gtipTd.textContent = '—';
          gtipTd.className = 'cps-ith-modal-gtip-yok';
        }
        tr.appendChild(gtipTd);

        tr.appendChild(td(sayiFmt(p.toplam_cift, 0), 'cps-ith-th-sag'));
        tr.appendChild(td(p.cift_maliyet_usd != null ?
          Number(p.cift_maliyet_usd).toFixed(2) : '—', 'cps-ith-th-sag'));
        tr.appendChild(td(p.cift_maliyet_try != null ?
          Number(p.cift_maliyet_try).toFixed(2) : '—', 'cps-ith-th-sag'));

        // Tasima hucresi - ikonlu badge
        var tasTd = document.createElement('td');
        var tasBadge = tasimaBadgeOlustur(p.tasima_tipi);
        if (tasBadge) {
          tasTd.appendChild(tasBadge);
        } else {
          tasTd.textContent = '—';
          tasTd.className = 'cps-ith-modal-gtip-yok';
        }
        tr.appendChild(tasTd);

        // Fark % hucresi
        var farkTd = document.createElement('td');
        farkTd.className = 'cps-ith-th-sag';
        if (p.fark_yuzde != null) {
          var iz = p.fark_yuzde > 0 ? '+' : '';
          farkTd.textContent = iz + Number(p.fark_yuzde).toFixed(1) + '%';
          var abs = Math.abs(p.fark_yuzde);
          if (p.fark_yon === 'pahali') {
            if (abs > 10) farkTd.classList.add('cps-ith-modal-fark-kritik-pahali');
            else if (abs > 5) farkTd.classList.add('cps-ith-modal-fark-uyari-pahali');
          } else if (p.fark_yon === 'ucuz') {
            if (abs > 10) farkTd.classList.add('cps-ith-modal-fark-ucuz');
            else if (abs > 5) farkTd.classList.add('cps-ith-modal-fark-hafif-ucuz');
          }
        } else {
          farkTd.textContent = '—';
        }
        tr.appendChild(farkTd);

        tbody.appendChild(tr);
      });
      tbl.appendChild(tbody);
      d.appendChild(tbl);
      return d;
    },

    _modalKirilimlar: function (tedarikci, tasima) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum cps-ith-modal-kirilim-grid';

      // Tedarikci
      var sol = document.createElement('div');
      var b1 = document.createElement('h4');
      b1.className = 'cps-ith-modal-bolum-baslik';
      b1.textContent = 'Tedarikçi Kırılımı';
      sol.appendChild(b1);
      if (tedarikci && tedarikci.length) {
        var ul1 = document.createElement('ul');
        ul1.className = 'cps-ith-modal-kirilim-liste';
        tedarikci.forEach(function (t) {
          var li = document.createElement('li');
          var sol2 = document.createElement('span');
          sol2.textContent = t.ad;
          li.appendChild(sol2);
          var sag = document.createElement('span');
          sag.className = 'cps-ith-modal-kirilim-sag';
          var parca = t.alim_sayisi + ' alım';
          if (t.ort_cift_usd != null) parca += ' · ort ' + Number(t.ort_cift_usd).toFixed(2) + ' USD';
          sag.textContent = parca;
          li.appendChild(sag);
          ul1.appendChild(li);
        });
        sol.appendChild(ul1);
      } else {
        sol.innerHTML += '<div class="cps-ith-modal-bos">—</div>';
      }
      d.appendChild(sol);

      // Tasima
      var sag1 = document.createElement('div');
      var b2 = document.createElement('h4');
      b2.className = 'cps-ith-modal-bolum-baslik';
      b2.textContent = 'Taşıma Kırılımı';
      sag1.appendChild(b2);
      if (tasima && tasima.length) {
        var ul2 = document.createElement('ul');
        ul2.className = 'cps-ith-modal-kirilim-liste';
        tasima.forEach(function (t) {
          var li = document.createElement('li');
          var sol2 = document.createElement('span');
          // Tasima badge
          var tasBadge = tasimaBadgeOlustur(t.tip);
          if (tasBadge) {
            sol2.appendChild(tasBadge);
          } else {
            sol2.textContent = t.tip;
          }
          li.appendChild(sol2);
          var sag2 = document.createElement('span');
          sag2.className = 'cps-ith-modal-kirilim-sag';
          var parca = t.alim_sayisi + ' alım';
          if (t.ort_navlun_cift_usd != null) {
            parca += ' · navlun ' + Number(t.ort_navlun_cift_usd).toFixed(2) + ' USD/çift';
          }
          sag2.textContent = parca;
          li.appendChild(sag2);
          ul2.appendChild(li);
        });
        sag1.appendChild(ul2);
      } else {
        sag1.innerHTML += '<div class="cps-ith-modal-bos">Taşıma verisi yok</div>';
      }
      d.appendChild(sag1);
      return d;
    },

    bagla: function () {
      var kapat = $('cps-ith-modal-kapat');
      if (kapat) kapat.addEventListener('click', urunModul.detayModalKapat);
      var back = $('cps-ith-modal-backdrop');
      if (back) back.addEventListener('click', urunModul.detayModalKapat);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          var modal = $('cps-ith-urun-modal');
          if (modal && !modal.classList.contains('cps-ith-gizle')) {
            urunModul.detayModalKapat();
          }
        }
      });
    },
  };


  // =====================================================================
  // ONAY MODUL - Parse preview (guven skoru sistemi, Faz 1+2)
  // =====================================================================
  var onayModul = {
    _aktif_belge_id: null,

    /**
     * Preview modalini ac - belge_id icin API'den veriyi cek
     */
    ac: function (belge_id) {
      if (!belge_id) return;
      var modal = $('cps-ith-onay-modal');
      if (!modal) return;

      onayModul._aktif_belge_id = belge_id;

      var baslikEl = $('cps-ith-onay-baslik');
      var altEl = $('cps-ith-onay-alt');
      var icerikEl = $('cps-ith-onay-icerik');

      baslikEl.textContent = 'Belge Önizleme';
      altEl.textContent = 'Yükleniyor...';
      icerikEl.innerHTML = '<div class="cps-ith-tablo-durum">' +
        '<span class="cps-ith-spinner"></span> Yukleniyor...</div>';
      onayModul._durumTemizle();
      onayModul._aksiyonlarAc();

      modal.classList.remove('cps-ith-gizle');
      document.body.style.overflow = 'hidden';

      api.get('/api/ithalat/belge/' + belge_id + '/parse-onay')
        .then(function (veri) {
          if (!veri || !veri.ok) {
            // Debug bilgisi varsa teknik detay goster
            var hata = (veri && veri.hata) || 'Veri alınamadı';
            if (veri && veri.debug) {
              onayModul._hataDetayli(hata, veri.debug, belge_id);
            } else {
              onayModul._hata(hata);
            }
            return;
          }
          onayModul._doldur(veri);
        })
        .catch(function (e) {
          onayModul._hata('Bağlantı hatası: ' + (e.message || ''));
        });
    },

    kapat: function () {
      var modal = $('cps-ith-onay-modal');
      if (modal) modal.classList.add('cps-ith-gizle');
      document.body.style.overflow = '';
      onayModul._aktif_belge_id = null;
    },

    _hata: function (mesaj) {
      var icerikEl = $('cps-ith-onay-icerik');
      icerikEl.innerHTML = '<div class="cps-ith-tablo-durum cps-ith-hata">' +
        '✗ ' + mesaj + '</div>';
      onayModul._aksiyonlarGizle();
    },

    _hataDetayli: function (mesaj, debug, belge_id) {
      var icerikEl = $('cps-ith-onay-icerik');
      var html = '<div class="cps-ith-onay-hata-detay">';
      html += '<div class="cps-ith-onay-hata-baslik">✗ ' + mesaj + '</div>';
      html += '<div class="cps-ith-onay-hata-debug">';
      html += '<strong>Teknik Debug Bilgisi:</strong><br>';
      html += '<table class="cps-ith-onay-debug-tbl">';
      function satir(et, dv) {
        return '<tr><td>' + et + '</td><td><code>' +
               (dv == null ? '(yok)' : String(dv)) + '</code></td></tr>';
      }
      html += satir('belge_id',          belge_id);
      html += satir('beklenen_yol',      debug.beklenen_yol);
      html += satir('klasor',            debug.klasor);
      html += satir('klasor_var',        debug.klasor_var);
      html += satir('dosya_var',         debug.dosya_var);
      html += satir('dosya_boyut',       debug.dosya_boyut);
      html += satir('cwd',               debug.cwd);
      html += satir('parse_durum (DB)',  debug.parse_durum_db);
      html += satir('parse_mesaj (DB)',  debug.parse_mesaj_db);
      html += satir('belge_orig_ad',     debug.belge_orig_ad);
      html += satir('belge_disk_yol',    debug.belge_disk_yol);
      html += '</table>';
      html += '<div class="cps-ith-onay-hata-oneri">';
      html += '<strong>Çözüm önerisi:</strong><br>';
      if (debug.dosya_var === false && debug.klasor_var === true) {
        html += 'Klasör var ama JSON yok. Upload sırasında yazma hatası olmuş olabilir. ';
        html += 'Flask terminal log\'unda <code>parse_onay_kaydet</code> hatası arayın.';
      } else if (debug.klasor_var === false) {
        html += 'Klasör oluşturulamamış. İzin hatası olabilir. ';
        html += 'Klasör: <code>' + debug.klasor + '</code>';
      } else if (debug.parse_durum_db === 'UYGULANDI') {
        html += 'Bu belge zaten onaylanıp uygulanmış. Maliyet sekmesini kontrol edin.';
      } else if (debug.parse_durum_db === 'REDDEDILDI') {
        html += 'Bu belge reddedilmiş. Yeniden yüklemeniz gerekir.';
      } else {
        html += 'Sunucu log\'unu kontrol edin. Bir sonraki yüklemede düzelebilir.';
      }
      html += '</div>';
      html += '</div></div>';
      icerikEl.innerHTML = html;
      onayModul._aksiyonlarGizle();
    },

    _durumTemizle: function () {
      var d = $('cps-ith-onay-durum');
      if (d) { d.textContent = ''; d.className = 'cps-ith-kayit-durum'; }
    },

    _aksiyonlarAc: function () {
      var bar = $('cps-ith-onay-aksiyon-bar');
      if (bar) bar.classList.remove('cps-ith-gizle');
    },

    _aksiyonlarGizle: function () {
      var bar = $('cps-ith-onay-aksiyon-bar');
      if (bar) bar.classList.add('cps-ith-gizle');
    },

    _doldur: function (veri) {
      var baslikEl = $('cps-ith-onay-baslik');
      var altEl = $('cps-ith-onay-alt');
      var icerikEl = $('cps-ith-onay-icerik');

      baslikEl.textContent = veri.dosya_adi || 'Belge Önizleme';

      var altParts = [];
      var tipEtiket = BELGE_TIP_ETIKET[veri.belge_tipi] || veri.belge_tipi || '—';
      altParts.push(tipEtiket);
      if (veri.kaynak_ref) altParts.push('Ref: ' + veri.kaynak_ref);
      if (veri.olusma_tarih) altParts.push(tarihSaatFmt(veri.olusma_tarih));
      altEl.textContent = altParts.join(' · ');

      icerikEl.innerHTML = '';

      // Duplicate ise basta buyuk uyari kutusu
      if (veri.is_duplicate) {
        icerikEl.appendChild(onayModul._duplicateKutusu(veri));
      }

      // ==== ONERI AKISI - beyanname, maliyet_pdf ====
      // Oneri modu 2 durumda aktif olur:
      //  1) Parser oneri listesi dolu dondurdu (beyanname, bilir ktl fatura)
      //  2) Parser tanimadi -> guven_skoru null + kalemler bos (bilir gumruk fatura gibi)
      //     Bu durumda kullanici manuel satir ekleyerek maliyete yazar
      var oneriModu = (veri.oneriler && veri.oneriler.length > 0) ||
                      (veri.guven_skoru == null &&
                       (!veri.kalemler || veri.kalemler.length === 0) &&
                       Array.isArray(veri.oneriler));

      if (oneriModu) {
        // 1. Ust bilgi
        icerikEl.appendChild(onayModul._oneriBilgiKutusu(veri));

        // 2. Oneri tablosu - editable, checkbox'li
        icerikEl.appendChild(onayModul._oneriTablosu(veri));

        // 3. Notlar (varsa)
        if (veri.uyarilar && veri.uyarilar.length) {
          icerikEl.appendChild(onayModul._uyarilarOlustur(veri.uyarilar));
        }

        // Alt bar: "Secilenleri Maliyete Ekle" (oneri modu)
        onayModul._altBarAyarla(veri.is_duplicate === true, true);
        return;
      }

      // ==== STANDART AKIS - proforma/CI (guven skoru) ====
      // 1. Güven skoru kartı
      icerikEl.appendChild(onayModul._guvenKartiOlustur(veri));

      // 2. Karar metrikleri
      icerikEl.appendChild(onayModul._kararMetrikleri(veri));

      // 3. Tespit edilenler
      icerikEl.appendChild(onayModul._tespitOlustur(veri));

      // 4. Güven skoru detayı
      if (veri.guven_detay && veri.guven_detay.length) {
        icerikEl.appendChild(onayModul._detayListesiOlustur(veri.guven_detay));
      }

      // 5. Mantıksızlık uyarıları
      if (veri.mantiksizlik_uyarilari && veri.mantiksizlik_uyarilari.length) {
        icerikEl.appendChild(onayModul._mantiksizlikOlustur(veri.mantiksizlik_uyarilari));
      }

      // 6. Uyarılar
      if (veri.uyarilar && veri.uyarilar.length) {
        icerikEl.appendChild(onayModul._uyarilarOlustur(veri.uyarilar));
      }

      // 7. Okunan kalemler tablosu
      icerikEl.appendChild(onayModul._kalemlerTablosu(veri.kalemler));

      // 8. Ekstra kalemler
      if (veri.ekstra_kalemler && veri.ekstra_kalemler.length) {
        icerikEl.appendChild(onayModul._ekstraKalemler(veri.ekstra_kalemler));
      }

      // Alt bar
      onayModul._altBarAyarla(veri.is_duplicate === true, false);
    },

    /**
     * ONERI MODU - ust bilgi kutusu (meta + kaynak_ref + dosya)
     */
    _oneriBilgiKutusu: function (veri) {
      var d = document.createElement('div');
      d.className = 'cps-ith-onay-oneri-bilgi';

      var meta = veri.meta || {};
      var satirlar = [];
      if (meta.belge_tipi_etiket) {
        satirlar.push(['Belge Türü', meta.belge_tipi_etiket]);
      }
      if (meta.beyanname_no || veri.kaynak_ref) {
        satirlar.push(['Referans', meta.beyanname_no || veri.kaynak_ref]);
      }
      if (meta.fatura_no) {
        satirlar.push(['Fatura No', meta.fatura_no]);
      }
      if (meta.tescil_tarihi) {
        satirlar.push(['Tescil Tarihi', tarihFmt(meta.tescil_tarihi)]);
      }
      if (meta.firma_ad) {
        satirlar.push(['Firma', meta.firma_ad]);
      }
      if (meta.teslim_sekli) {
        satirlar.push(['Teslim Şekli', meta.teslim_sekli]);
      }
      if (meta.toplam_ifade) {
        satirlar.push(['Toplam', meta.toplam_ifade]);
      }
      if (meta.doviz_tutari && meta.doviz_para) {
        satirlar.push(['Fatura Bedeli',
          Number(meta.doviz_tutari).toLocaleString('tr-TR') + ' ' + meta.doviz_para]);
      }
      if (meta.kur) {
        satirlar.push(['Kur', meta.kur]);
      }

      if (!satirlar.length) {
        d.style.display = 'none';
        return d;
      }

      var baslik = document.createElement('div');
      baslik.className = 'cps-ith-onay-oneri-bilgi-baslik';
      baslik.textContent = 'Belge Bilgisi';
      d.appendChild(baslik);

      var grid = document.createElement('div');
      grid.className = 'cps-ith-onay-oneri-bilgi-grid';
      satirlar.forEach(function (s) {
        var et = document.createElement('div');
        et.className = 'cps-ith-onay-oneri-bilgi-et';
        et.textContent = s[0];
        grid.appendChild(et);
        var dv = document.createElement('div');
        dv.className = 'cps-ith-onay-oneri-bilgi-dv';
        dv.textContent = s[1];
        grid.appendChild(dv);
      });
      d.appendChild(grid);
      return d;
    },

    /**
     * ONERI MODU - kalemler tablosu, editable + checkbox
     */
    _oneriTablosu: function (veri) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum cps-ith-onay-oneri-bolum';

      var b = document.createElement('h4');
      b.className = 'cps-ith-modal-bolum-baslik';
      b.textContent = 'Maliyet Önerileri — seçin ve düzenleyin';
      d.appendChild(b);

      var info = document.createElement('div');
      info.className = 'cps-ith-onay-oneri-info';
      if (veri.oneriler && veri.oneriler.length > 0) {
        info.textContent = '⚠ Bu kalemler parser tarafından tespit edildi. ' +
          'Maliyete ekleneceklerden emin olun. Otomatik uygulanmaz. ' +
          'Gerekirse manuel satır da ekleyebilirsiniz.';
      } else {
        info.textContent = 'ℹ Parser bu belgeden kalem okuyamadı. ' +
          'Aşağıdaki butonla manuel olarak kalem ekleyebilirsiniz.';
      }
      d.appendChild(info);

      var tblWrap = document.createElement('div');
      tblWrap.className = 'cps-ith-onay-oneri-tbl-wrap';

      var tbl = document.createElement('table');
      tbl.className = 'cps-ith-tablo cps-ith-onay-oneri-tbl';
      tbl.id = 'cps-ith-onay-oneri-tbl';
      tbl.innerHTML =
        '<thead><tr>' +
        '<th class="cps-ith-onay-oneri-th-cb">✓</th>' +
        '<th>Açıklama</th>' +
        '<th class="cps-ith-th-sag">Tutar</th>' +
        '<th>Para</th>' +
        '<th>Tip</th>' +
        '<th>Kaynak</th>' +
        '<th class="cps-ith-onay-oneri-th-sil"></th>' +
        '</tr></thead>';

      var tbody = document.createElement('tbody');

      // Parser onerilerini ekle (her biri data-manuel="false")
      (veri.oneriler || []).forEach(function (o, idx) {
        var tr = onayModul._parserSatiri(o, idx);
        tbody.appendChild(tr);
      });

      tbl.appendChild(tbody);
      tblWrap.appendChild(tbl);
      d.appendChild(tblWrap);

      // YENI: Manuel satir ekle butonu
      var manuelBtnWrap = document.createElement('div');
      manuelBtnWrap.className = 'cps-ith-onay-oneri-manuel-ekle-wrap';
      var manuelBtn = document.createElement('button');
      manuelBtn.type = 'button';
      manuelBtn.className = 'cps-ith-onay-oneri-manuel-ekle-btn';
      manuelBtn.innerHTML = '<span>➕</span> Manuel Satır Ekle';
      manuelBtn.title = 'Parser okuyamadıysa veya eksik kalem varsa elle ekle';
      manuelBtn.addEventListener('click', onayModul._manuelSatirEkle);
      manuelBtnWrap.appendChild(manuelBtn);
      d.appendChild(manuelBtnWrap);

      // Alt toplam satiri
      var toplamDiv = document.createElement('div');
      toplamDiv.className = 'cps-ith-onay-oneri-toplam';
      toplamDiv.id = 'cps-ith-onay-oneri-toplam';
      d.appendChild(toplamDiv);

      // Ilk toplam hesapla (dom'a eklenmeden setTimeout ile)
      setTimeout(onayModul._oneriToplamGuncelle, 50);

      return d;
    },

    /**
     * Parser onerisi icin satir olustur (data-manuel="false").
     * Aciklama SPAN olarak gosterilir (duzenlenemez).
     */
    _parserSatiri: function (o, idx) {
      var GECERLI_TIPLER = ['GUMRUK', 'NAVLUN', 'SIGORTA', 'DEPOLAMA',
                            'LIMAN', 'KOMISYON', 'FOB', 'DIGER'];
      var GECERLI_PARALAR = ['TRY', 'USD', 'EUR', 'GBP', 'CNY'];

      var tr = document.createElement('tr');
      tr.dataset.idx = idx;
      tr.dataset.manuel = 'false';

      // Uyari satiri ise arka plan
      if (o.uyari === 'cok_yuksek') {
        tr.classList.add('cps-ith-onay-oneri-row-kritik');
      } else if (o.uyari === 'yuksek') {
        tr.classList.add('cps-ith-onay-oneri-row-yuksek');
      } else if (o.uyari === 'genel_toplam') {
        tr.classList.add('cps-ith-onay-oneri-row-toplam');
      }

      // Checkbox
      var cbTd = document.createElement('td');
      cbTd.className = 'cps-ith-onay-oneri-cb-td';
      var cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.className = 'cps-ith-onay-oneri-cb';
      cb.checked = (o.varsayilan_isaretli !== false);
      cb.addEventListener('change', onayModul._oneriToplamGuncelle);
      cbTd.appendChild(cb);
      tr.appendChild(cbTd);

      // Aciklama (readonly)
      var adTd = document.createElement('td');
      adTd.className = 'cps-ith-onay-oneri-ad';
      var adSpan = document.createElement('span');
      adSpan.className = 'cps-ith-onay-oneri-ad-text';
      adSpan.textContent = o.aciklama || '—';
      adTd.appendChild(adSpan);
      if (o.kaynak_satir) {
        adTd.title = 'Kaynak: ' + o.kaynak_satir;
      }
      if (o.uyari) {
        var uyariSp = document.createElement('div');
        uyariSp.className = 'cps-ith-onay-oneri-uyari-mini';
        if (o.uyari === 'cok_yuksek') {
          uyariSp.textContent = '🔴 Çok yüksek tutar - güvenlik kontrolü';
        } else if (o.uyari === 'yuksek') {
          uyariSp.textContent = '⚠ Yüksek tutar';
        } else if (o.uyari === 'genel_toplam') {
          uyariSp.textContent = 'ℹ Genel toplam - alt kalemlerle çakışma riski';
        } else if (o.uyari === 'belirsiz') {
          uyariSp.textContent = '? Tespit belirsiz';
        }
        adTd.appendChild(uyariSp);
      }
      tr.appendChild(adTd);

      // Tutar
      var tutarTd = document.createElement('td');
      tutarTd.className = 'cps-ith-th-sag';
      var tutarIn = document.createElement('input');
      tutarIn.type = 'number';
      tutarIn.step = '0.01';
      tutarIn.min = '0';
      tutarIn.className = 'cps-ith-onay-oneri-tutar-input';
      tutarIn.value = Number(o.tutar || 0).toFixed(2);
      tutarIn.addEventListener('input', onayModul._oneriToplamGuncelle);
      tutarTd.appendChild(tutarIn);
      tr.appendChild(tutarTd);

      // Para
      var paraTd = document.createElement('td');
      var paraSel = document.createElement('select');
      paraSel.className = 'cps-ith-onay-oneri-select cps-ith-onay-oneri-para';
      GECERLI_PARALAR.forEach(function (p) {
        var opt = document.createElement('option');
        opt.value = p;
        opt.textContent = p;
        if (p === (o.para_birimi || 'TRY').toUpperCase()) opt.selected = true;
        paraSel.appendChild(opt);
      });
      paraSel.addEventListener('change', onayModul._oneriToplamGuncelle);
      paraTd.appendChild(paraSel);
      tr.appendChild(paraTd);

      // Tip
      var tipTd = document.createElement('td');
      var tipSel = document.createElement('select');
      tipSel.className = 'cps-ith-onay-oneri-select cps-ith-onay-oneri-tip';
      GECERLI_TIPLER.forEach(function (t) {
        var opt = document.createElement('option');
        opt.value = t;
        opt.textContent = TIP_ETIKET[t] || t;
        if (t === (o.tip_onerisi || 'DIGER').toUpperCase()) opt.selected = true;
        tipSel.appendChild(opt);
      });
      tipTd.appendChild(tipSel);
      tr.appendChild(tipTd);

      // Kaynak
      var kTd = document.createElement('td');
      var kSel = document.createElement('select');
      kSel.className = 'cps-ith-onay-oneri-select cps-ith-onay-oneri-kaynak';
      [['GERCEKLESEN','Gerçekleşen'],['TAHMINI','Tahmini']].forEach(function (pair) {
        var opt = document.createElement('option');
        opt.value = pair[0];
        opt.textContent = pair[1];
        if (pair[0] === (o.kaynak_onerisi || 'GERCEKLESEN').toUpperCase()) {
          opt.selected = true;
        }
        kSel.appendChild(opt);
      });
      kTd.appendChild(kSel);
      tr.appendChild(kTd);

      // Sil sutunu (parser satirinda BOS - silme yok, checkbox'tan kaldir)
      var silTd = document.createElement('td');
      silTd.className = 'cps-ith-onay-oneri-sil-td';
      tr.appendChild(silTd);

      // Orijinal alt_kod'u sakla (beyanname icin)
      if (o.alt_kod) tr.dataset.altKod = o.alt_kod;

      return tr;
    },

    /**
     * YENI: Manuel satir ekle (data-manuel="true").
     * Aciklama INPUT olarak, Sil butonu var.
     */
    _manuelSatirEkle: function () {
      var GECERLI_TIPLER = ['GUMRUK', 'NAVLUN', 'SIGORTA', 'DEPOLAMA',
                            'LIMAN', 'KOMISYON', 'FOB', 'DIGER'];
      var GECERLI_PARALAR = ['TRY', 'USD', 'EUR', 'GBP', 'CNY'];

      var tbl = document.getElementById('cps-ith-onay-oneri-tbl');
      if (!tbl) return;
      var tbody = tbl.querySelector('tbody');
      if (!tbody) return;

      var tr = document.createElement('tr');
      tr.dataset.manuel = 'true';
      tr.classList.add('cps-ith-onay-oneri-row-manuel');

      // Checkbox (default isaretli)
      var cbTd = document.createElement('td');
      cbTd.className = 'cps-ith-onay-oneri-cb-td';
      var cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.className = 'cps-ith-onay-oneri-cb';
      cb.checked = true;
      cb.addEventListener('change', onayModul._oneriToplamGuncelle);
      cbTd.appendChild(cb);
      tr.appendChild(cbTd);

      // Aciklama - INPUT (manuel duzenlenebilir)
      var adTd = document.createElement('td');
      adTd.className = 'cps-ith-onay-oneri-ad';
      var adIn = document.createElement('input');
      adIn.type = 'text';
