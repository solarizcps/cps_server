        if (r.ok && r.data.ok) detayYukle();
        else alert('Iptal edilemedi: ' + (r.data.hata || 'hata'));
      });
    },

    bagla: function () {
      var ekleBtn = $('cps-ith-btn-plan-ekle');
      if (ekleBtn) ekleBtn.addEventListener('click', this.formuAc);
      var iptalBtn = $('cps-ith-plan-iptal');
      if (iptalBtn) iptalBtn.addEventListener('click', this.formuKapat);
      var kaydetBtn = $('cps-ith-plan-kaydet');
      if (kaydetBtn) kaydetBtn.addEventListener('click', this.planKaydet);
    },
  };


