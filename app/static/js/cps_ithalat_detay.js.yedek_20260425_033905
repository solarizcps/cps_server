    /**
     * YENI: Karar metrikleri - kullanicinin hemen goreceegi ozet
     * Toplam tutar, toplam çift, birim maliyet
     */
    _kararMetrikleri: function (veri) {
      var d = document.createElement('div');
      d.className = 'cps-ith-modal-bolum';
      var b = document.createElement('h4');
      b.className = 'cps-ith-modal-bolum-baslik';
      b.textContent = 'Karar Metrikleri';
      d.appendChild(b);

      var bilgi = veri.parti_bilgi || {};
      var toplam = bilgi.toplam_tutar;
      var cift = bilgi.toplam_cift;
      var birim = bilgi.birim_maliyet;
      var para = bilgi.para_birimi || 'USD';
      var komisyon = bilgi.komisyon_tutar;

      // Kalemlerden fallback hesapla (parti_bilgi'de yoksa)
      if (toplam == null && veri.kalemler) {
        toplam = 0;
        veri.kalemler.forEach(function (k) {
          var t = parseFloat(k.tutar);
          if (!isNaN(t)) toplam += t;
        });
      }
      if (cift == null && toplam != null && birim != null && birim > 0) {
        cift = Math.round(toplam / birim);
      }
      if (birim == null && toplam != null && cift != null && cift > 0) {
        birim = toplam / cift;
      }

      var grid = document.createElement('div');
      grid.className = 'cps-ith-onay-karar-grid';

      function metrik(etiket, deger, birim_str, vurgu) {
        var k = document.createElement('div');
        k.className = 'cps-ith-onay-karar-metrik';
        if (vurgu) k.classList.add('cps-ith-onay-karar-vurgu');
        var et = document.createElement('div');
        et.className = 'cps-ith-onay-karar-et';
        et.textContent = etiket;
        k.appendChild(et);
        var dv = document.createElement('div');
        dv.className = 'cps-ith-onay-karar-dv';
        if (deger == null) {
          dv.textContent = '—';
          dv.classList.add('cps-ith-onay-karar-bos');
        } else {
          dv.innerHTML = '<strong>' + deger + '</strong>' +
            (birim_str ? ' <span class="cps-ith-onay-karar-birim">' +
                         birim_str + '</span>' : '');
        }
        k.appendChild(dv);
        return k;
      }

      // Toplam tutar
      grid.appendChild(metrik(
        'Toplam Tutar',
        toplam != null ? Number(toplam).toLocaleString('tr-TR', {
          minimumFractionDigits: 2, maximumFractionDigits: 2
        }) : null,
        para
      ));

      // Toplam çift
      grid.appendChild(metrik(
        'Toplam Çift',
        cift != null ? Number(cift).toLocaleString('tr-TR') : null,
        'çift'
      ));

      // Birim maliyet - BÜYÜK VURGU
      grid.appendChild(metrik(
        'Çift Başı Maliyet',
        birim != null ? Number(birim).toFixed(2) : null,
        para + '/çift',
        true  // vurgu
      ));

      // Komisyon (varsa)
      if (komisyon && komisyon > 0) {
        grid.appendChild(metrik(
          'Komisyon',
          Number(komisyon).toLocaleString('tr-TR', {
            minimumFractionDigits: 2, maximumFractionDigits: 2
          }),
          para
        ));
      }

      d.appendChild(grid);
      return d;
    },

