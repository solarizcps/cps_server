  // ODEME MODUL
  // =====================================================================
  var odemeModul = {
    doldur: function (d) {
      var liste = $('cps-ith-plan-liste');
      var bos = $('cps-ith-plan-bos');
      if (!liste) return;
      liste.innerHTML = '';
      var planlar = d.odeme_planlari || [];
      var hareketler = d.hareketler || [];
      if (!planlar.length) { gosterGizle(bos, true); return; }
      gosterGizle(bos, false);
      planlar.forEach(function (p) {
        var kart = odemeModul.planKart(p, hareketler, d.para_birimi);
        liste.appendChild(kart);
      });
    },

    planKart: function (p, tumHareketler, partiPara) {
      var kart = document.createElement('div');
      kart.className = 'cps-ith-plan-kart';
      if (p.Gecikmis) kart.classList.add('gecikmis');
      if (p.Durum === 'IPTAL') kart.classList.add('iptal');
      if (p.Durum === 'ODENDI') kart.classList.add('odendi');

      var ust = document.createElement('div');
      ust.className = 'cps-ith-plan-ust';
      var sira = document.createElement('div');
      sira.className = 'cps-ith-plan-sira';
      sira.textContent = '#' + p.Sira;
      ust.appendChild(sira);

      var bilgi = document.createElement('div');
      bilgi.className = 'cps-ith-plan-bilgi';
      var ac = document.createElement('div');
      ac.className = 'cps-ith-plan-aciklama';
      ac.textContent = p.Aciklama || '—';
      bilgi.appendChild(ac);
      var meta = document.createElement('div');
      meta.className = 'cps-ith-plan-meta';
      var metaParts = [];
      if (p.OdemeTipi) metaParts.push(p.OdemeTipi);
      if (p.CariAd || p.CariKod) metaParts.push(p.CariAd || p.CariKod);
      meta.textContent = metaParts.join(' · ') || '—';
      bilgi.appendChild(meta);
      ust.appendChild(bilgi);

      var tarih = document.createElement('div');
      tarih.className = 'cps-ith-plan-tarih';
      if (p.Gecikmis) tarih.classList.add('gecikmis');
      tarih.textContent = tarihFmt(p.PlanlananTarih);
      var gf = gunFarki(p.PlanlananTarih);
      if (gf != null && (p.Durum === 'BEKLIYOR' || p.Durum === 'KISMEN_ODENDI')) {
        var ek = document.createElement('div');
        ek.className = 'cps-ith-plan-tutar-alt';
        if (gf < 0) ek.textContent = Math.abs(gf) + ' gün geçti';
        else if (gf === 0) ek.textContent = 'bugün';
        else ek.textContent = gf + ' gün sonra';
        tarih.appendChild(ek);
      }
      ust.appendChild(tarih);

      var tutar = document.createElement('div');
      tutar.className = 'cps-ith-plan-tutar';
      tutar.textContent = tamParaFmt(p.Tutar);
      var tutarAlt = document.createElement('div');
      tutarAlt.className = 'cps-ith-plan-tutar-alt';
      tutarAlt.textContent = p.ParaBirimi + ' · kalan ' + tamParaFmt(p.Kalan);
      tutar.appendChild(tutarAlt);
      ust.appendChild(tutar);

      var aks = document.createElement('div');
      aks.className = 'cps-ith-plan-aksiyon';
      if (p.Durum === 'BEKLIYOR' || p.Durum === 'KISMEN_ODENDI') {
        var odeBtn = document.createElement('button');
        odeBtn.type = 'button';
        odeBtn.className = 'cps-ith-btn cps-ith-btn-ghost cps-ith-btn-sm';
        odeBtn.textContent = '+ Ödeme';
        odeBtn.addEventListener('click', function () { odemeModul.hareketEkle(p); });
        aks.appendChild(odeBtn);
      }
      if (p.Durum !== 'IPTAL') {
        var iptalBtn = document.createElement('button');
        iptalBtn.type = 'button';
        iptalBtn.className = 'cps-ith-btn-ikon';
        iptalBtn.textContent = 'İptal';
        iptalBtn.addEventListener('click', function () { odemeModul.planIptal(p.Id); });
        aks.appendChild(iptalBtn);
      }
      ust.appendChild(aks);
      kart.appendChild(ust);

      var bar = document.createElement('div');
      bar.className = 'cps-ith-plan-durum-bar';
      var durumSpan = document.createElement('span');
      durumSpan.className = 'cps-ith-durum-etiket';
      durumSpan.textContent = PLAN_DURUM_ETIKET[p.Durum] || p.Durum;
      bar.appendChild(durumSpan);
      var notSpan = document.createElement('span');
      notSpan.textContent = p.NotMetni || '';
      bar.appendChild(notSpan);
      kart.appendChild(bar);

      var planHareketleri = tumHareketler.filter(function (h) { return h.OdemePlanId === p.Id; });
      if (planHareketleri.length) {
        var hKap = document.createElement('div');
        hKap.className = 'cps-ith-plan-hareketler';
        planHareketleri.forEach(function (h) {
          var hSatir = document.createElement('div');
          hSatir.className = 'cps-ith-hareket-satir';
          if (h.Iptal) hSatir.classList.add('iptal');
          var hTarih = document.createElement('span');
          hTarih.className = 'cps-ith-hareket-tarih';
          hTarih.textContent = tarihFmt(h.Tarih);
          hSatir.appendChild(hTarih);
          var hMeta = document.createElement('span');
          var metaT = [];
          if (h.OdemeYontemi) metaT.push(h.OdemeYontemi);
          if (h.BankaRef) metaT.push('Ref: ' + h.BankaRef);
          if (h.NotMetni) metaT.push(h.NotMetni);
          hMeta.textContent = metaT.join(' · ');
          hSatir.appendChild(hMeta);
          var hTutar = document.createElement('span');
          hTutar.className = 'cps-ith-hareket-tutar';
          hTutar.textContent = tamParaFmt(h.Tutar, h.ParaBirimi);
          hSatir.appendChild(hTutar);
          var hKul = document.createElement('span');
          hKul.style.fontSize = '11px';
          hKul.style.color = '#9ca3af';
          hKul.textContent = h.KaydedenKullanici || '';
          hSatir.appendChild(hKul);
          if (!h.Iptal) {
            var hIpt = document.createElement('button');
            hIpt.type = 'button';
            hIpt.className = 'cps-ith-btn-ikon';
            hIpt.textContent = '✕';
            hIpt.title = 'Hareketi iptal et';
            hIpt.addEventListener('click', function () { odemeModul.hareketIptal(h.Id); });
            hSatir.appendChild(hIpt);
          } else {
            hSatir.appendChild(document.createElement('span'));
          }
          hKap.appendChild(hSatir);
        });
        kart.appendChild(hKap);
      }
      return kart;
    },

    formuAc: function () {
      $('pl-tarih').value = new Date().toISOString().substring(0, 10);
      $('pl-tutar').value = '';
      $('pl-para').value = (DETAY_VERI && DETAY_VERI.para_birimi) || 'USD';
      $('pl-tip').value = '';
      $('pl-aciklama').value = '';
      $('pl-cari-kod').value = '';
      $('pl-cari-ad').value = '';
      gosterGizle($('cps-ith-plan-form'), true);
      $('pl-tutar').focus();
    },

    formuKapat: function () { gosterGizle($('cps-ith-plan-form'), false); },

    planKaydet: function () {
      var tutar = parseFloat($('pl-tutar').value);
      if (isNaN(tutar) || tutar <= 0) { alert('Tutar pozitif olmali.'); return; }
      var tarih = $('pl-tarih').value;
      if (!tarih) { alert('Planlanan tarih zorunlu.'); return; }
      var veri = {
        parti_id: PARTI_ID,
        planlanan_tarih: tarih,
        tutar: tutar,
        para_birimi: $('pl-para').value,
        odeme_tipi: $('pl-tip').value || null,
        aciklama: $('pl-aciklama').value.trim(),
        cari_kod: $('pl-cari-kod').value.trim(),
        cari_ad: $('pl-cari-ad').value.trim(),
      };
      api.post('/api/ithalat/odeme-plan/ekle', veri).then(function (r) {
        if (r.ok && r.data.ok) { odemeModul.formuKapat(); detayYukle(); }
        else alert('Eklenemedi: ' + (r.data.hata || 'hata'));
      }).catch(function () { alert('Baglanti hatasi'); });
    },

