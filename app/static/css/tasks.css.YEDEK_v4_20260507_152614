/* ==========================================================
   CPS TASKS - FAZ 2A v4 - UX REVIZE (8 NOKTA)
   ==========================================================
   v4 degisiklikleri:
   1. KPI bar guclendi (kontrast, sayi 32px, padding artti)
   2. Tablo nefes aldi (row 64px, alt yazi spacing)
   3. Badge'ler buyudu (min-height 28, padding 5x12)
   4. Filtre paneli ayristi (daha belirgin border + shadow)
   5. Tablo header guclendi (12px, weight 800, daha koyu renk)
   6. Aksiyon buton hover hissi
   7. Bottom padding optimize
   8. HIYERARSI: title dominant, secondary bilgi solgun
   ========================================================== */

.tasks-page {
  padding: 22px 24px 24px 24px;
  background: #f5f7fa;
  min-height: calc(100vh - 64px);
  color: #172033;
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
}


/* ============== HEADER =============== */
.tasks-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}
.tasks-title h1 {
  font-size: 28px;
  font-weight: 800;
  margin: 0;
  color: #0f172a;
  letter-spacing: -.4px;
}
.tasks-title p {
  margin: 5px 0 0 0;
  color: #64748b;
  font-size: 13px;
  font-weight: 500;
}

.tasks-actions {
  display: flex;
  gap: 10px;
  align-items: center;
}

.tasks-btn {
  height: 38px;
  padding: 0 16px;
  border-radius: 8px;
  border: 1px solid #d1d8e3;
  background: #fff;
  color: #1e293b;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  transition: all .15s ease;
  font-family: inherit;
}
.tasks-btn:hover {
  background: #f8fafc;
  border-color: #94a3b8;
}
.tasks-btn:active { transform: translateY(1px); }
.tasks-btn:disabled { opacity: .5; cursor: not-allowed; }

.tasks-btn-primary {
  background: #F97316;
  border-color: #F97316;
  color: #fff;
  box-shadow: 0 1px 2px rgba(249, 115, 22, .25);
}
.tasks-btn-primary:hover {
  background: #EA580C;
  border-color: #EA580C;
}

.tasks-btn-ghost {
  background: transparent;
  border-color: #d1d8e3;
  color: #64748b;
}


/* ============== SUMMARY (4 KART) - GUCLENDIRILDI =============== */
.tasks-summary {
  background: #fff;
  border: 1px solid #dde3ed;
  border-radius: 10px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin-bottom: 14px;
  box-shadow: 0 2px 4px rgba(15, 23, 42, .04);
  overflow: hidden;
}
.tasks-summary-item {
  padding: 22px 26px;
  display: flex;
  align-items: center;
  gap: 16px;
  border-right: 1px solid #eef2f7;
  min-height: 92px;
  background: #fafbfc;
}
.tasks-summary-item:last-child { border-right: 0; }

.tasks-summary-icon {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 20px;
  flex-shrink: 0;
  box-shadow: 0 1px 2px rgba(15, 23, 42, .06);
}
.tasks-summary-text { display: flex; flex-direction: column; }
.tasks-summary-label {
  font-size: 12px;
  font-weight: 800;
  color: #475569;
  letter-spacing: .4px;
  text-transform: uppercase;
}
.tasks-summary-number {
  font-size: 32px;
  line-height: 1;
  font-weight: 900;
  margin-top: 6px;
  font-variant-numeric: tabular-nums;
  letter-spacing: -.5px;
}

.tasks-summary-blue   .tasks-summary-icon { background: #dbeafe; color: #1d4ed8; }
.tasks-summary-blue   .tasks-summary-number { color: #1d4ed8; }
.tasks-summary-orange .tasks-summary-icon { background: #ffedd5; color: #c2410c; }
.tasks-summary-orange .tasks-summary-number { color: #c2410c; }
.tasks-summary-red    .tasks-summary-icon { background: #fee2e2; color: #b91c1c; }
.tasks-summary-red    .tasks-summary-number { color: #b91c1c; }
.tasks-summary-green  .tasks-summary-icon { background: #dcfce7; color: #15803d; }
.tasks-summary-green  .tasks-summary-number { color: #15803d; }


/* ============== FILTER PANEL - DAHA BELIRGIN AYRISMA =============== */
.tasks-filter-panel {
  background: #fff;
  border: 1px solid #dde3ed;
  border-radius: 10px;
  padding: 18px 20px;
  margin-bottom: 14px;
  box-shadow: 0 2px 6px rgba(15, 23, 42, .06);
}
.tasks-filter-grid {
  display: grid;
  grid-template-columns: 1.25fr 1fr 1fr 1fr 1fr;
  gap: 14px;
  align-items: end;
}
.tasks-filter-grid.second-row {
  margin-top: 14px;
  grid-template-columns: 1fr 1fr 1fr 1fr auto auto;
}

.tasks-field label {
  display: block;
  font-size: 12px;
  font-weight: 800;
  color: #334155;
  margin-bottom: 7px;
}
.tasks-field input,
.tasks-field select {
  width: 100%;
  height: 40px;
  border: 1px solid #d1d8e3;
  border-radius: 7px;
  padding: 0 12px;
  font-size: 13px;
  font-weight: 500;
  color: #1e293b;
  background: #fff;
  outline: none;
  font-family: inherit;
  box-sizing: border-box;
}
.tasks-field input::placeholder { color: #94a3b8; }
.tasks-field input:focus,
.tasks-field select:focus {
  border-color: #F97316;
  box-shadow: 0 0 0 3px rgba(249, 115, 22, .14);
}
.tasks-field-actions {
  display: flex;
  gap: 8px;
  align-items: end;
}
.tasks-field-actions .tasks-btn { white-space: nowrap; }


/* ============== TABLE CARD =============== */
.tasks-table-card {
  background: #fff;
  border: 1px solid #dde3ed;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 2px 4px rgba(15, 23, 42, .04);
}
.tasks-table-wrap {
  overflow-x: auto;
}
.tasks-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
  min-width: 1200px;
}

/* TABLO HEADER - GUCLENDIRILDI */
.tasks-table thead th {
  background: #f1f5f9;
  color: #334155;
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .3px;
  padding: 14px 14px;
  border-bottom: 1px solid #cbd5e1;
  text-align: left;
  white-space: nowrap;
  cursor: default;
  user-select: none;
}
.tasks-table thead th.sortable { cursor: pointer; }
.tasks-table thead th.sortable:hover { background: #e2e8f0; color: #0f172a; }
.tasks-table thead th .sort-ic { display: inline-block; margin-left: 5px; opacity: 0; }
.tasks-table thead th[data-dir] .sort-ic { opacity: 1; }
.tasks-table thead th[data-dir="asc"]  .sort-ic::before  { content: "▲"; font-size: 9px; color: #F97316; }
.tasks-table thead th[data-dir="desc"] .sort-ic::before  { content: "▼"; font-size: 9px; color: #F97316; }

/* TABLO BODY - NEFES ALDI */
.tasks-table tbody td {
  padding: 16px 14px;
  border-bottom: 1px solid #eef2f7;
  color: #1e293b;
  font-size: 13.5px;
  vertical-align: middle;
  overflow: hidden;
  text-overflow: ellipsis;
}
.tasks-table tbody tr { min-height: 64px; transition: background .1s; }
.tasks-table tbody tr:hover { background: #fff8f0; }
.tasks-table tbody tr:last-child td { border-bottom: 0; }
.tasks-table tbody tr.row-completed   { background: #fafefb; }
.tasks-table tbody tr.row-completed:hover { background: #f0fdf4; }
.tasks-table tbody tr.row-canceled    { opacity: .5; }

/* Kolon genislikleri (biraz daha ferah) */
.tasks-table .col-id       { width: 60px; }
.tasks-table .col-priority { width: 105px; }
.tasks-table .col-title    { width: 280px; }
.tasks-table .col-dept     { width: 105px; }
.tasks-table .col-user     { width: 150px; }
.tasks-table .col-status   { width: 140px; }
.tasks-table .col-date     { width: 125px; }
.tasks-table .col-order    { width: 110px; }
.tasks-table .col-creator  { width: 150px; }
.tasks-table .col-updated  { width: 125px; }
.tasks-table .col-action   { width: 110px; text-align: right; }

.task-id-cell {
  font-weight: 700;
  color: #94a3b8;
  font-variant-numeric: tabular-nums;
  font-size: 13px;
}

/* TITLE - DOMINANT (HIYERARSI 1.) */
.task-title-main {
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 5px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 14px;
  letter-spacing: -.1px;
  line-height: 1.3;
}
.task-title-sub {
  font-size: 12px;
  color: #94a3b8;
  font-weight: 500;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}


/* ============== BADGES - BUYUDU =============== */
.task-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 28px;
  padding: 5px 12px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  border: 1px solid transparent;
  white-space: nowrap;
  letter-spacing: .2px;
}

/* Oncelik */
.priority-kritik { color: #b91c1c; background: #fee2e2; border-color: #fca5a5; }
.priority-yuksek { color: #c2410c; background: #ffedd5; border-color: #fdba74; }
.priority-orta,
.priority-normal { color: #475569; background: #f1f5f9; border-color: #cbd5e1; }
.priority-dusuk  { color: #64748b; background: #f8fafc; border-color: #e2e8f0; }

/* Durum */
.status-bekliyor       { color: #475569; background: #f1f5f9; border-color: #cbd5e1; }
.status-devam_ediyor   { color: #1d4ed8; background: #dbeafe; border-color: #93c5fd; }
.status-onay_bekliyor  { color: #c2410c; background: #ffedd5; border-color: #fdba74; }
.status-revize_istendi { color: #92400e; background: #fef3c7; border-color: #fcd34d; }
.status-tamamlandi     { color: #15803d; background: #dcfce7; border-color: #86efac; }
.status-gecikti        { color: #b91c1c; background: #fee2e2; border-color: #fca5a5; }
.status-iptal          { color: #94a3b8; background: #f8fafc; border-color: #e2e8f0; text-decoration: line-through; }


/* ============== USER CELL - HIYERARSI 4. (orta agirlik) =============== */
.task-user {
  display: flex;
  align-items: center;
  gap: 9px;
  min-width: 0;
}
.task-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #fef3c7;
  color: #92400e;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 900;
  flex-shrink: 0;
  letter-spacing: .3px;
  border: 1px solid #fde68a;
}
.task-user-info { min-width: 0; }
.task-user-name {
  font-weight: 700;
  color: #1e293b;
  line-height: 1.2;
  font-size: 13px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.task-user-role {
  font-size: 10.5px;
  color: #94a3b8;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 1px;
}


/* ============== DATE CELL - HIYERARSI 3. (yuksek dikkat) =============== */
.task-date-main {
  font-weight: 800;
  color: #0f172a;
  font-variant-numeric: tabular-nums;
  font-size: 13px;
}
.task-date-sub {
  font-size: 11.5px;
  font-weight: 800;
  margin-top: 3px;
  letter-spacing: .1px;
}
.task-date-ok       { color: #16a34a; }
.task-date-warn     { color: #ea580c; }
.task-date-danger   { color: #dc2626; }
.task-date-mute     { color: #94a3b8; font-weight: 600; }


/* ============== ACTION ICONS - HOVER GUCLENDI =============== */
.task-row-actions {
  display: flex;
  justify-content: flex-end;
  gap: 6px;
}
.task-icon-btn {
  width: 34px;
  height: 34px;
  border-radius: 7px;
  border: 1px solid #d1d8e3;
  background: #fff;
  color: #334155;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  transition: all .15s ease;
  font-family: inherit;
}
.task-icon-btn:hover {
  background: #f1f5f9;
  border-color: #94a3b8;
  color: #0f172a;
  transform: translateY(-1px);
  box-shadow: 0 2px 4px rgba(15, 23, 42, .08);
}
.task-icon-btn:active { transform: translateY(0); }
.task-icon-btn-primary {
  color: #F97316;
  border-color: #fdba74;
  background: #fff7ed;
}
.task-icon-btn-primary:hover {
  background: #ffedd5;
  border-color: #F97316;
  color: #c2410c;
}
.task-icon-btn-warning {
  color: #ea580c;
  border-color: #fdba74;
  background: #fff7ed;
}


/* ============== TABLE FOOTER (pagination) =============== */
.tasks-table-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 20px;
  border-top: 1px solid #e2e8f0;
  background: #fafbfc;
  color: #475569;
  font-size: 13px;
  flex-wrap: wrap;
  gap: 12px;
}
.tasks-pagination-info { font-weight: 700; }
.tasks-pagination {
  display: flex;
  gap: 8px;
  align-items: center;
}
.tasks-page-size-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #475569;
  font-weight: 600;
}
.tasks-page-size {
  height: 36px;
  border: 1px solid #d1d8e3;
  border-radius: 7px;
  padding: 0 28px 0 12px;
  background: #fff;
  font-size: 13px;
  font-weight: 700;
  color: #1e293b;
  cursor: pointer;
  font-family: inherit;
  outline: none;
}
.tasks-page-size:focus {
  border-color: #F97316;
  box-shadow: 0 0 0 3px rgba(249, 115, 22, .14);
}
.tasks-page-btn {
  min-width: 36px;
  height: 36px;
  border: 1px solid #d1d8e3;
  background: #fff;
  border-radius: 7px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 800;
  color: #1e293b;
  padding: 0 10px;
  transition: all .12s ease;
  font-family: inherit;
}
.tasks-page-btn:hover:not(:disabled):not(.active) {
  background: #f1f5f9;
  border-color: #94a3b8;
}
.tasks-page-btn.active {
  background: #F97316;
  color: #fff;
  border-color: #F97316;
  box-shadow: 0 1px 2px rgba(249, 115, 22, .25);
}
.tasks-page-btn:disabled { opacity: .35; cursor: not-allowed; }


/* ============== EMPTY =============== */
.tasks-empty {
  padding: 56px 20px;
  text-align: center;
  color: #94a3b8;
  font-size: 14px;
  font-weight: 500;
}


/* ============== MODAL =============== */
.tasks-modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, .42);
  z-index: 9998;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
.tasks-modal-backdrop.show { display: flex; }
.tasks-modal {
  width: min(820px, 96vw);
  max-height: 88vh;
  overflow: hidden;
  background: #fff;
  border-radius: 12px;
  border: 1px solid #dde3ed;
  box-shadow: 0 20px 50px rgba(15, 23, 42, .25);
  display: flex;
  flex-direction: column;
}
.tasks-modal-create { width: min(720px, 94vw); }

.tasks-modal-header {
  padding: 18px 22px;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.tasks-modal-title {
  font-size: 18px;
  font-weight: 900;
  color: #0f172a;
  margin: 0;
}
.tasks-modal-close {
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: #64748b;
  padding: 0 6px;
  line-height: 1;
}
.tasks-modal-close:hover { color: #0f172a; }

.tasks-modal-body {
  padding: 22px;
  overflow: auto;
  flex: 1;
}
.tasks-modal-footer {
  padding: 14px 22px;
  border-top: 1px solid #e2e8f0;
  background: #f8fafc;
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
  flex-shrink: 0;
}


/* ============== DETAY MODAL ICERIK =============== */
.task-detay-baslik {
  font-size: 19px;
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 10px;
  line-height: 1.3;
  letter-spacing: -.2px;
}
.task-detay-baglam {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}
.task-detay-chip {
  display: inline-block;
  padding: 5px 12px;
  background: #f1f5f9;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  color: #334155;
  border: 1px solid #cbd5e1;
}
.task-detay-aciklama {
  font-size: 14px;
  color: #334155;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 18px;
  white-space: pre-wrap;
  line-height: 1.6;
}
.task-detay-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px 28px;
  margin-bottom: 20px;
}
.task-detay-grid .lbl {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #64748b;
  font-weight: 800;
  margin-bottom: 4px;
}
.task-detay-grid .val {
  font-size: 14px;
  color: #0f172a;
  word-break: break-word;
  font-weight: 700;
}
.task-detay-section-title {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #475569;
  font-weight: 800;
  margin: 18px 0 10px;
  border-bottom: 1px solid #e2e8f0;
  padding-bottom: 7px;
}
.task-detay-logs { font-size: 13px; }
.task-detay-logs .log-row {
  display: grid;
  grid-template-columns: 130px 130px 1fr 100px;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px dashed #eef2f7;
  color: #475569;
}
.task-detay-logs .log-row .when { color: #94a3b8; font-variant-numeric: tabular-nums; }
.task-detay-logs .log-row .who  { font-weight: 700; color: #1e293b; }
.task-detay-logs .log-row .what { font-weight: 800; color: #0f172a; }
.task-detay-files .file-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 0;
  font-size: 13px;
  color: #475569;
  border-bottom: 1px dashed #eef2f7;
}
.task-detay-files .file-row .nm { font-weight: 700; color: #0f172a; }
.task-detay-empty {
  font-size: 13px;
  color: #94a3b8;
  font-style: italic;
  padding: 8px 0;
}


/* ============== CREATE FORM =============== */
.tasks-form-row {
  margin-bottom: 14px;
}
.tasks-form-row label {
  display: block;
  font-size: 12px;
  font-weight: 800;
  color: #334155;
  margin-bottom: 5px;
}
.tasks-form-row input[type="text"],
.tasks-form-row input[type="date"],
.tasks-form-row textarea,
.tasks-form-row select {
  width: 100%;
  padding: 0 12px;
  border: 1px solid #d1d8e3;
  border-radius: 7px;
  background: #fff;
  font-size: 13px;
  font-family: inherit;
  color: #0f172a;
  outline: none;
  box-sizing: border-box;
  height: 40px;
}
.tasks-form-row textarea {
  resize: vertical;
  min-height: 90px;
  height: auto;
  padding: 10px 12px;
  line-height: 1.5;
}
.tasks-form-row input:focus,
.tasks-form-row select:focus,
.tasks-form-row textarea:focus {
  border-color: #F97316;
  box-shadow: 0 0 0 3px rgba(249, 115, 22, .14);
}
.tasks-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 16px;
}
.tasks-form-row .zorunlu { color: #dc2626; }
.tasks-cb-row {
  display: flex !important;
  align-items: center;
  gap: 10px;
  text-transform: none !important;
  letter-spacing: 0 !important;
  font-size: 14px !important;
  color: #1e293b !important;
  font-weight: 700 !important;
  cursor: pointer;
  margin-bottom: 0 !important;
}
.tasks-cb-row input[type="checkbox"] {
  width: 18px;
  height: 18px;
  cursor: pointer;
  accent-color: #F97316;
}
.tasks-form-err {
  background: #fee2e2;
  color: #b91c1c;
  border: 1px solid #fca5a5;
  border-radius: 7px;
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 600;
  margin-top: 10px;
}


/* ============== TOAST =============== */
.tasks-toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: #0f172a;
  color: #fff;
  padding: 12px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  box-shadow: 0 10px 25px rgba(15, 23, 42, .25);
  z-index: 9999;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .2s, transform .2s;
  pointer-events: none;
}
.tasks-toast.is-show { opacity: 1; transform: translateY(0); }
.tasks-toast.is-err  { background: #b91c1c; }
.tasks-toast.is-ok   { background: #15803d; }


/* ============== RESPONSIVE =============== */
@media (max-width: 1200px) {
  .tasks-summary { grid-template-columns: repeat(2, 1fr); }
  .tasks-summary-item:nth-child(even) { border-right: 0; }
  .tasks-summary-item:nth-child(1),
  .tasks-summary-item:nth-child(2) { border-bottom: 1px solid #eef2f7; }

  .tasks-filter-grid,
  .tasks-filter-grid.second-row { grid-template-columns: repeat(3, 1fr); }
  .tasks-filter-grid.second-row .tasks-field-actions { grid-column: 1 / -1; }
}

@media (max-width: 900px) {
  .tasks-page { padding: 16px; }
  .tasks-header { flex-direction: column; align-items: stretch; }
  .tasks-actions { width: 100%; }
  .tasks-actions .tasks-btn { flex: 1; justify-content: center; }

  .tasks-summary { grid-template-columns: 1fr; }
  .tasks-summary-item { border-right: 0; border-bottom: 1px solid #eef2f7; }
  .tasks-summary-item:last-child { border-bottom: 0; }

  .tasks-filter-grid,
  .tasks-filter-grid.second-row,
  .tasks-form-grid { grid-template-columns: 1fr; }

  .task-detay-grid { grid-template-columns: 1fr; }
  .task-detay-logs .log-row {
    grid-template-columns: 110px 1fr;
    row-gap: 3px;
  }
  .task-detay-logs .log-row .what,
  .task-detay-logs .log-row .who { grid-column: 2; }

  .tasks-table-footer { flex-direction: column; align-items: stretch; }
  .tasks-pagination-info { text-align: center; }
}
