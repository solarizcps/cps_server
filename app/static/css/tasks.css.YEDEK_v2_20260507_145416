/* ==========================================================
   CPS DEV - Tasks Modulu - Stiller (v2 - olcek revizyonu)
   ==========================================================
   Faz 2A: Liste sayfasi + 2 modal (detay/create)

   v2 NOTLARI:
     - Spacing/padding artirildi (kurumsal his)
     - Font'lar bir kademe buyutuldu
     - Tablo row height ~42px (tablet dostu dokunma alani)
     - KPI strip biraz daha belirgin
     - Filter inputlari yeterli yukseklikte (38px)

   Mevcut CPS pallet:
     --bg, --bg2, --bg3, --bg4, --border, --border2,
     --sol, --sol-dark, --sol-light, --sol-text,
     --green, --orange, --red, --yellow, --blue,
     --text, --text2, --text3,
     --shadow-sm, --shadow, --shadow-md,
     --radius, --radius-sm

   Class prefix: tasks-*
   ========================================================== */


/* ============== ANA SAYFA WRAPPER =============== */
.tasks-sayfa {
  padding-top: 4px;
}


/* ============== USTBASLIK GUCLENDIRME =============== */
.tasks-sayfa .page-header {
  margin-bottom: 18px;
}
.tasks-sayfa .page-title {
  font-size: 26px;
  font-weight: 800;
  letter-spacing: -.3px;
  color: var(--text);
}
.tasks-sayfa .page-sub {
  font-size: 13px;
  color: var(--text3);
  margin-top: 4px;
  font-weight: 500;
}


/* ============== KPI MINI STRIP =============== */
.tasks-kpi-strip {
  display: flex;
  align-items: center;
  gap: 22px;
  padding: 14px 22px;
  margin-bottom: 14px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 14px;
}
.tasks-kpi-item {
  display: flex;
  align-items: baseline;
  gap: 9px;
}
.tasks-kpi-etiket {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--text3);
  font-weight: 600;
}
.tasks-kpi-sayi {
  font-size: 20px;
  font-weight: 800;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.tasks-kpi-item[data-kpi="acik"] .tasks-kpi-sayi          { color: var(--text); }
.tasks-kpi-item[data-kpi="onay_bekliyor"] .tasks-kpi-sayi { color: var(--orange); }
.tasks-kpi-item[data-kpi="gecikti"] .tasks-kpi-sayi       { color: var(--red); }
.tasks-kpi-item[data-kpi="bugun_biten"] .tasks-kpi-sayi   { color: var(--green); }
.tasks-kpi-sep {
  color: var(--border2);
  font-weight: 700;
  font-size: 16px;
}


/* ============== FILTER BAR =============== */
.tasks-filter-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  margin-bottom: 12px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  flex-wrap: wrap;
}
.tasks-filter-input,
.tasks-filter-select {
  padding: 9px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
  font-size: 14px;
  color: var(--text);
  font-family: var(--sans);
  outline: none;
  height: 38px;
  box-sizing: border-box;
}
.tasks-filter-input { min-width: 240px; flex: 0 1 320px; }
.tasks-filter-select { min-width: 150px; cursor: pointer; }
.tasks-filter-input:focus,
.tasks-filter-select:focus {
  border-color: var(--sol-dark);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
.tasks-filter-info {
  margin-left: auto;
  font-size: 13px;
  color: var(--text3);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}


/* ============== USTBASLIK BUTONLARI =============== */
.tasks-sayfa .page-header .btn,
.tasks-sayfa .page-header button {
  min-height: 38px;
  padding: 8px 16px;
  font-size: 14px;
  font-weight: 600;
}


/* ============== ANA TABLO =============== */
.tasks-tbl-wrap {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: auto;
  max-height: calc(100vh - 320px);
}
.tasks-tbl {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.tasks-tbl thead th {
  position: sticky;
  top: 0;
  background: var(--bg3);
  border-bottom: 2px solid var(--border2);
  padding: 11px 12px;
  text-align: left;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--text3);
  font-weight: 700;
  white-space: nowrap;
  z-index: 2;
}
.tasks-tbl thead th.sortable {
  cursor: pointer;
  user-select: none;
}
.tasks-tbl thead th.sortable:hover {
  background: var(--bg4);
  color: var(--text2);
}
.tasks-tbl thead th .sort-ic::after {
  content: " ";
  display: inline-block;
  width: 0; height: 0;
  margin-left: 5px;
  vertical-align: middle;
}
.tasks-tbl thead th[data-dir="asc"]  .sort-ic::after {
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-bottom: 5px solid var(--sol-dark);
}
.tasks-tbl thead th[data-dir="desc"] .sort-ic::after {
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 5px solid var(--sol-dark);
}

/* row height ~ 42px (tablet dostu) */
.tasks-tbl tbody td {
  padding: 11px 12px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
  color: var(--text2);
}
.tasks-tbl tbody tr {
  transition: background-color .08s;
}
.tasks-tbl tbody tr:hover {
  background: var(--bg3);
}
.tasks-tbl tbody tr.row-kritik       { background: #fef2f2; }
.tasks-tbl tbody tr.row-kritik:hover { background: #fee2e2; }
.tasks-tbl tbody tr.row-yuksek       { background: #fff7ed; }
.tasks-tbl tbody tr.row-yuksek:hover { background: #ffedd5; }
.tasks-tbl tbody tr.row-tamamlandi       { background: #f0fdf4; }
.tasks-tbl tbody tr.row-tamamlandi:hover { background: #dcfce7; }
.tasks-tbl tbody tr.row-iptal        { opacity: .55; }
.tasks-tbl tbody tr.row-gecikti td.col-due { color: var(--red); font-weight: 700; }

.tasks-tbl .col-id      { font-weight: 700; color: var(--text3); font-variant-numeric: tabular-nums; }
.tasks-tbl .col-title   { font-weight: 600; color: var(--text); }
.tasks-tbl .col-onclock { font-size: 12px; color: var(--red); }


/* ============== STATUS PILL =============== */
.tasks-pill {
  display: inline-block;
  padding: 4px 11px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  white-space: nowrap;
  letter-spacing: .3px;
}
.tasks-pill-bekliyor       { background: var(--bg4);   color: var(--text2); }
.tasks-pill-devam_ediyor   { background: #dbeafe;      color: #1d4ed8; }
.tasks-pill-onay_bekliyor  { background: #fef3c7;      color: var(--sol-text); }
.tasks-pill-revize_istendi { background: #fee2e2;      color: var(--red); }
.tasks-pill-tamamlandi     { background: #dcfce7;      color: var(--green); }
.tasks-pill-gecikti        { background: #fecaca;      color: #991b1b; }
.tasks-pill-iptal          { background: var(--bg4);   color: var(--text3); text-decoration: line-through; }


/* ============== ONCELIK INDIKATOR =============== */
.tasks-onclik {
  display: inline-block;
  width: 26px;
  text-align: center;
  padding: 3px 0;
  border-radius: 5px;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.tasks-onclik-kritik { background: #fee2e2; color: #991b1b; }
.tasks-onclik-yuksek { background: #ffedd5; color: var(--orange); }
.tasks-onclik-orta   { background: var(--bg4); color: var(--text2); }
.tasks-onclik-dusuk  { background: var(--bg4); color: var(--text3); }


/* ============== ISLEM BUTONU =============== */
.tasks-btn-detay {
  padding: 7px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
  color: var(--text2);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  font-family: var(--sans);
  min-height: 32px;
}
.tasks-btn-detay:hover {
  background: var(--bg3);
  border-color: var(--border2);
  color: var(--text);
}
.tasks-btn-detay:active {
  transform: translateY(1px);
}


/* ============== EMPTY STATE =============== */
.tasks-empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--text3);
  font-size: 14px;
}


/* ============== MODAL =============== */
.tasks-modal {
  position: fixed;
  inset: 0;
  display: none;
  z-index: 1000;
  align-items: center;
  justify-content: center;
}
.tasks-modal.is-open { display: flex; }
.tasks-modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, .55);
}
.tasks-modal-box {
  position: relative;
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow-md);
  max-height: 92vh;
  display: flex;
  flex-direction: column;
  width: min(760px, 94vw);
}
.tasks-modal-detay  { width: min(860px, 95vw); }
.tasks-modal-create { width: min(720px, 94vw); }

.tasks-modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 22px;
  border-bottom: 1px solid var(--border);
}
.tasks-modal-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--text);
}
.tasks-modal-close {
  background: none;
  border: none;
  font-size: 26px;
  line-height: 1;
  cursor: pointer;
  color: var(--text3);
  padding: 0 6px;
}
.tasks-modal-close:hover { color: var(--text); }

.tasks-modal-body {
  padding: 20px 22px;
  overflow: auto;
  flex: 1;
}
.tasks-modal-foot {
  padding: 14px 22px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 10px;
  justify-content: flex-end;
  flex-wrap: wrap;
  background: var(--bg3);
}
.tasks-modal-foot .btn {
  min-height: 38px;
  padding: 8px 18px;
  font-size: 14px;
  font-weight: 600;
}


/* ============== DETAY MODAL ICERIK =============== */
.tasks-detay-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px 24px;
  margin-bottom: 18px;
}
.tasks-detay-grid .lbl {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--text3);
  font-weight: 700;
  margin-bottom: 3px;
}
.tasks-detay-grid .val {
  font-size: 14px;
  color: var(--text);
  word-break: break-word;
}
.tasks-detay-baslik {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10px;
  line-height: 1.3;
}
.tasks-detay-aciklama {
  font-size: 14px;
  color: var(--text2);
  background: var(--bg3);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  margin-bottom: 16px;
  white-space: pre-wrap;
  line-height: 1.5;
}
.tasks-detay-baglam {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}
.tasks-detay-baglam .chip {
  display: inline-block;
  padding: 5px 12px;
  background: var(--bg4);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text2);
}
.tasks-detay-section-title {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--text3);
  font-weight: 700;
  margin: 16px 0 8px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 6px;
}
.tasks-detay-logs {
  font-size: 13px;
}
.tasks-detay-logs .log-row {
  display: grid;
  grid-template-columns: 130px 130px 1fr 100px;
  gap: 10px;
  padding: 7px 0;
  border-bottom: 1px dashed var(--border);
  color: var(--text2);
}
.tasks-detay-logs .log-row .when { color: var(--text3); font-variant-numeric: tabular-nums; }
.tasks-detay-logs .log-row .who  { font-weight: 600; }
.tasks-detay-logs .log-row .what { font-weight: 700; color: var(--text2); }
.tasks-detay-files .file-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 0;
  font-size: 13px;
  color: var(--text2);
  border-bottom: 1px dashed var(--border);
}
.tasks-detay-files .file-row .nm { font-weight: 600; }
.tasks-detay-empty {
  font-size: 13px;
  color: var(--text3);
  font-style: italic;
  padding: 8px 0;
}


/* ============== CREATE FORM =============== */
.tasks-form-row {
  margin-bottom: 14px;
}
.tasks-form-row label {
  display: block;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .8px;
  color: var(--text3);
  font-weight: 700;
  margin-bottom: 5px;
}
.tasks-form-row input[type="text"],
.tasks-form-row input[type="date"],
.tasks-form-row textarea,
.tasks-form-row select {
  width: 100%;
  padding: 9px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: #fff;
  font-size: 14px;
  font-family: var(--sans);
  color: var(--text);
  outline: none;
  box-sizing: border-box;
  height: 40px;
}
.tasks-form-row textarea {
  resize: vertical;
  min-height: 80px;
  height: auto;
  line-height: 1.5;
}
.tasks-form-row input:focus,
.tasks-form-row select:focus,
.tasks-form-row textarea:focus {
  border-color: var(--sol-dark);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
.tasks-form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0 16px;
}
.tasks-form-row .zorunlu { color: var(--red); }
.tasks-cb-row {
  display: flex !important;
  align-items: center;
  gap: 10px;
  text-transform: none !important;
  letter-spacing: 0 !important;
  font-size: 14px !important;
  color: var(--text2) !important;
  font-weight: 600 !important;
  cursor: pointer;
}
.tasks-cb-row input[type="checkbox"] {
  width: 18px;
  height: 18px;
  cursor: pointer;
}
.tasks-form-err {
  background: #fee2e2;
  color: var(--red);
  border: 1px solid #fecaca;
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  font-size: 13px;
  margin-top: 10px;
}


/* ============== TOAST =============== */
.tasks-toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: var(--text);
  color: #fff;
  padding: 12px 20px;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-weight: 600;
  box-shadow: var(--shadow-md);
  z-index: 1100;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .2s, transform .2s;
  pointer-events: none;
}
.tasks-toast.is-show {
  opacity: 1;
  transform: translateY(0);
}
.tasks-toast.is-err   { background: var(--red); }
.tasks-toast.is-ok    { background: var(--green); }


/* ============== TABLET (1100px alti) =============== */
@media (max-width: 1100px) {
  .tasks-sayfa .page-title { font-size: 22px; }

  .tasks-kpi-strip { gap: 14px; padding: 12px 16px; }
  .tasks-kpi-sayi  { font-size: 18px; }

  .tasks-filter-bar { gap: 8px; padding: 10px 12px; }
  .tasks-filter-input { flex: 1 1 100%; min-width: 0; }
  .tasks-filter-select { min-width: 130px; }

  .tasks-form-grid { grid-template-columns: 1fr; }
  .tasks-tbl       { font-size: 13px; }
  .tasks-tbl thead th,
  .tasks-tbl tbody td  { padding: 9px 10px; }

  .tasks-detay-grid     { grid-template-columns: 1fr; }
  .tasks-detay-logs .log-row {
    grid-template-columns: 110px 1fr;
    row-gap: 3px;
  }
  .tasks-detay-logs .log-row .what,
  .tasks-detay-logs .log-row .who  { grid-column: 2; }
}


/* ============== TELEFON (740px alti) =============== */
@media (max-width: 740px) {
  .tasks-kpi-strip { flex-wrap: wrap; row-gap: 10px; }
  .tasks-kpi-sep   { display: none; }
  .tasks-kpi-item  { min-width: 45%; }
}


/* ============== KUCUK YARDIMCI =============== */
.tasks-mute   { color: var(--text3); font-size: 13px; }
.tasks-strong { color: var(--text); font-weight: 700; }
