/* enjeksiyon.css - FAZ 6.7
   Tablet ergonomi revize:
   - Istasyonlar 2 sutun grid (1-2 / 3-4 / 5-6 / 7-8) - dikey okuma kolay
   - A/B kutulari arasinda 14px bosluk + buyuk tiklama (18px padding, 16px font)
   - Bloklar arasinda daha fazla hava (padding/margin artirildi)
   - Input/select tablet icin buyuk (min-height 38px, font 13px)
   - CPS sari/beyaz korundu, yeni renk eklemedik. */

.enj-wrap { font-family: 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif; font-size: 13px; color: #1f2937; line-height: 1.4; padding: 18px; max-width: 1400px; margin: 0 auto; }

.enj-page-head { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.enj-page-head h2 { margin: 0; font-size: 22px; font-weight: 700; color: #1f2937; }
.enj-page-head .sub { font-size: 13px; font-weight: 500; color: #888780; }
.enj-vrd-badge { margin-left: auto; font-size: 12px; color: #6b7280; }
.enj-vrd-badge b { color: #92400e; background: #fef3c7; padding: 4px 12px; border-radius: 12px; font-weight: 600; letter-spacing: 0.3px; }

/* UST: 4 MAKINE SADE KART (genis + havadar) */
.enj-mak-secim { display: grid; grid-template-columns: 90px 1fr 1fr 1fr 1fr; gap: 14px; margin-bottom: 18px; align-items: stretch; }
.enj-lbl { font-size: 11px; font-weight: 700; color: #1f2937; padding-top: 16px; }
.enj-lbl small { display: block; font-size: 10px; font-weight: 400; color: #6b7280; margin-top: 3px; }
.enj-mak-kart { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; padding: 16px 18px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; transition: border-color 0.12s, background 0.12s; }
.enj-mak-kart:hover { background: #fafaf7; border-color: #d4a52f; }
.enj-mak-kart.aktif { border-color: #d4a52f; box-shadow: 0 0 0 1px #d4a52f; background: #fff; }
.enj-mak-kart .ad { font-size: 14px; font-weight: 700; }
.enj-mak-kart .ad .no { font-size: 20px; font-weight: 700; margin-right: 6px; vertical-align: -2px; }
.enj-tick { width: 30px; height: 30px; background: #22c55e; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 17px; font-weight: 700; flex-shrink: 0; }
.enj-toggle { width: 36px; height: 20px; background: #fbbf24; border-radius: 10px; position: relative; flex-shrink: 0; }
.enj-toggle::after { content: ''; position: absolute; left: 2px; top: 2px; width: 16px; height: 16px; background: #fff; border-radius: 50%; }

/* ORTA: SECILI MAKINE PANELI - havadar */
.enj-mak-panel { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; padding: 20px 22px; margin-bottom: 18px; display: none; }
.enj-mak-panel.aktif { display: block; }
.enj-mak-panel .basl { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid #f0f0ec; }
.enj-mak-panel .basl .lbl { font-size: 15px; font-weight: 700; color: #1f2937; }
.enj-mak-panel .basl .lbl .no { font-size: 22px; font-weight: 700; margin-right: 7px; vertical-align: -2px; }
.enj-mak-panel .basl .lbl .sub { font-size: 12px; font-weight: 500; color: #6b7280; margin-left: 12px; }
.enj-mak-panel .basl .tools { display: flex; gap: 8px; align-items: center; }
.enj-mini-btn { padding: 8px 14px; border-radius: 4px; border: 1px solid #fde68a; background: #fffbeb; color: #92400e; font-size: 11px; font-weight: 700; cursor: pointer; font-family: inherit; letter-spacing: 0.4px; }
.enj-mini-btn:hover { background: #fef3c7; }
.enj-mini-btn:active { transform: translateY(1px); }
.enj-mini-btn.kapat { border-color: #d1d5db; background: #fff; color: #6b7280; }
.enj-mini-btn.kapat:hover { background: #f9fafb; }

/* ISTASYON LIST: 2 SUTUN GRID (dikey okuma) */
.enj-ist-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px 24px; max-width: 720px; }
.enj-ist-cell { display: flex; flex-direction: column; gap: 10px; align-items: stretch; }
.enj-ist-cell .no { font-size: 12px; font-weight: 700; color: #6b7280; letter-spacing: 0.6px; text-align: left; }
.enj-ist-cell .ab { display: flex; gap: 14px; width: 100%; }
.enj-ist-cell .ab .s { flex: 1; padding: 16px 0; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; font-size: 16px; font-weight: 700; color: #6b7280; text-align: center; cursor: pointer; font-family: inherit; line-height: 1; min-width: 0; min-height: 48px; transition: background 0.1s, border-color 0.1s; }
.enj-ist-cell .ab .s:hover:not(.on) { background: #f9fafb; border-color: #9ca3af; }
.enj-ist-cell .ab .s.on { background: #22c55e; border-color: #16a34a; color: #fff; }
.enj-ist-cell .ab .s.on:hover { background: #16a34a; }
.enj-ist-cell .ab .s:active { transform: scale(0.97); }

/* FORM */
.enj-fwrap { display: grid; grid-template-columns: 1fr 220px; gap: 14px; margin-bottom: 18px; }
.enj-form { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; padding: 18px; }
.enj-fr { display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 14px; }
.enj-fr:last-child { margin-bottom: 0; }
.enj-fld { display: flex; flex-direction: column; }
.enj-fld label { font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.5px; margin-bottom: 6px; text-transform: uppercase; }
.enj-fld label.g { color: #16a34a; }
.enj-fld label.b { color: #1e40af; }
.enj-fld input, .enj-fld select, .enj-fld textarea { background: #fff; border: 1px solid #d1d5db; border-radius: 4px; padding: 9px 12px; font-size: 13px; color: #1f2937; line-height: 1.4; font-family: inherit; box-sizing: border-box; min-height: 40px; width: 100%; }
.enj-fld select { padding: 9px 30px 9px 12px; cursor: pointer; }
.enj-fld input:focus, .enj-fld select:focus, .enj-fld textarea:focus { outline: none; border-color: #d4a52f; box-shadow: 0 0 0 2px rgba(212,165,47,0.2); }
.enj-fld input[readonly] { background: #fafaf7; color: #6b7280; cursor: default; }
.enj-fld input.calc { background: #fef6e0; border-color: #d4a52f; color: #5a3a08; font-weight: 700; font-size: 16px; }
.enj-fld input.gh { background: #f0fdf4; border-color: #bbf7d0; }
.enj-fld input.bh { background: #eff6ff; border-color: #bfdbfe; }

.enj-urun { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; padding: 14px; display: flex; flex-direction: column; }
.enj-urun .et { font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.5px; margin-bottom: 8px; text-transform: uppercase; }
.enj-urun .ph { flex: 1; min-height: 130px; background: #f3f4f6; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #9ca3af; font-size: 12px; margin-bottom: 10px; border: 1px dashed #d1d5db; }
.enj-urun .ad { font-size: 14px; font-weight: 700; color: #1f2937; line-height: 1.3; }
.enj-urun .alt { font-size: 12px; color: #6b7280; margin-top: 4px; }
.enj-urun .bos { color: #9ca3af; font-weight: 400; font-style: italic; }

/* SAATLIK TABLO + OZET */
.enj-main { display: grid; grid-template-columns: 1fr 280px; gap: 14px; margin-bottom: 18px; }
.enj-tbl-card { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; overflow: hidden; }
.enj-tbl-basl { padding: 12px 18px; font-size: 12px; font-weight: 700; color: #1f2937; letter-spacing: 0.3px; background: #fafaf7; border-bottom: 1px solid #e3e3e0; }
.enj-tbl-basl b { color: #92400e; }
.enj-tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
.enj-tbl th { text-align: center; padding: 11px 10px; font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.4px; background: #fafaf7; border-bottom: 1px solid #e3e3e0; }
.enj-tbl th:first-child { text-align: left; padding-left: 18px; }
.enj-tbl td { padding: 10px 10px; border-bottom: 1px solid #f0f0ec; text-align: center; }
.enj-tbl td:first-child { text-align: left; padding-left: 18px; color: #1f2937; font-weight: 500; white-space: nowrap; }
.enj-tbl tr:last-child td { border-bottom: none; }
.enj-tbl .tur-inp { width: 80px; padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 4px; font-size: 13px; text-align: center; font-weight: 600; font-family: inherit; min-height: 38px; box-sizing: border-box; }
.enj-tbl .tur-inp:focus { outline: none; border-color: #d4a52f; box-shadow: 0 0 0 2px rgba(212,165,47,0.2); }
.enj-tbl .durum-sel, .enj-tbl .aks-sel { padding: 8px 30px 8px 12px; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; font-size: 12px; font-weight: 600; font-family: inherit; min-width: 130px; min-height: 38px; cursor: pointer; box-sizing: border-box; }
.enj-tbl .aks-sel { min-width: 170px; }
.enj-tbl .enj-mesai-info { padding: 36px; color: #888780; font-style: italic; }

.enj-ozet { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; padding: 14px 16px; align-self: start; }
.enj-ozet h4 { font-size: 12px; font-weight: 700; color: #1f2937; margin: 0 0 12px; padding-bottom: 9px; border-bottom: 1px solid #f0f0ec; letter-spacing: 0.4px; }
.enj-ozet .or { display: flex; justify-content: space-between; align-items: baseline; padding: 7px 0; }
.enj-ozet .or .l { font-size: 11px; font-weight: 600; color: #6b7280; letter-spacing: 0.3px; }
.enj-ozet .or .v { font-size: 15px; font-weight: 700; color: #1e40af; }
.enj-ozet .or .v.muted { color: #6b7280; font-weight: 500; }
.enj-ozet .or .v.red { color: #dc2626; }

/* GUN SONU - 6 KOLON YATAY (genis tablet) */
.enj-gs { background: #fff; border: 1px solid #e3e3e0; border-radius: 5px; padding: 16px 18px; margin-bottom: 18px; }
.enj-gs h4 { font-size: 12px; font-weight: 700; color: #1f2937; margin: 0 0 14px; padding-bottom: 9px; border-bottom: 1px solid #f0f0ec; letter-spacing: 0.4px; }
.enj-gs-yatay { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr 2fr; gap: 14px; align-items: stretch; }
.enj-gs-foto { display: flex; flex-direction: column; }
.enj-gs-foto label { font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.5px; margin-bottom: 6px; text-transform: uppercase; }
.enj-gs-foto .zone { flex: 1; min-height: 40px; padding: 10px; border: 1px dashed #d1d5db; border-radius: 4px; background: #fafaf7; text-align: center; font-size: 12px; color: #6b7280; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px; }
.enj-gs-foto .zone:hover { border-color: #d4a52f; background: #fff; }
.enj-gs-not { display: flex; flex-direction: column; }
.enj-gs-not label { font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.5px; margin-bottom: 6px; text-transform: uppercase; }
.enj-note { background: #fff; border: 1px solid #d1d5db; border-radius: 4px; padding: 9px 12px; font-size: 13px; color: #1f2937; min-height: 40px; resize: vertical; font-family: inherit; box-sizing: border-box; width: 100%; }
.enj-note:focus { outline: none; border-color: #d4a52f; box-shadow: 0 0 0 2px rgba(212,165,47,0.2); }

/* BUTONLAR */
.enj-act { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.enj-btn { padding: 16px 20px; border-radius: 4px; font-size: 13px; font-weight: 700; border: 1px solid #fde68a; background: #fffbeb; color: #92400e; cursor: pointer; font-family: inherit; display: inline-flex; align-items: center; justify-content: center; gap: 10px; letter-spacing: 0.5px; min-height: 52px; }
.enj-btn:hover { background: #fef3c7; }
.enj-btn:active { transform: translateY(1px); }
.enj-btn.kaydet { background: #16a34a; color: #fff; border-color: #15803d; font-size: 14px; }
.enj-btn.kaydet:hover { background: #15803d; }

/* RESPONSIVE */
@media (max-width: 1200px) { .enj-gs-yatay { grid-template-columns: 1fr 1fr 1fr; } }
@media (max-width: 1000px) { .enj-fwrap, .enj-main { grid-template-columns: 1fr; } }
@media (max-width: 800px) {
  .enj-mak-secim { grid-template-columns: 1fr 1fr; }
  .enj-lbl { grid-column: 1 / -1; padding-top: 0; }
  .enj-fr { grid-template-columns: repeat(3, 1fr); }
  .enj-gs-yatay { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .enj-ist-list { grid-template-columns: 1fr; }
  .enj-fr { grid-template-columns: repeat(2, 1fr); }
  .enj-gs-yatay { grid-template-columns: 1fr; }
  .enj-act { grid-template-columns: 1fr; }
}
