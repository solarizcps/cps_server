/* =============================================================
   SOLARIZ CPS - PLANLAMA OPERASYON RAPORU CSS
   F9.5.2 - UI Layer
   Prefix: .or-* (Operasyon Raporu)
   ============================================================= */

/* ========== SAYFA ========== */
.or-sayfa {
  padding: 16px 20px 32px;
  max-width: 1280px;
  margin: 0 auto;
  font-size: 13px;
  color: #2c2c2a;
}

/* ========== UST BASLIK ========== */
.or-ust {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14px;
  padding-bottom: 12px;
  border-bottom: 1px solid #e8e6df;
}

.or-baslik h2 {
  margin: 0;
  font-size: 22px;
  font-weight: 600;
  color: #2c2c2a;
  letter-spacing: -0.3px;
}

.or-breadcrumb {
  font-size: 11px;
  color: #888780;
  margin-bottom: 4px;
}

.or-canli-bilgi {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  color: #888780;
}

.or-canli-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 9px;
  background: #eaf3de;
  color: #173404;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.3px;
}

.or-canli-dot {
  width: 6px;
  height: 6px;
  background: #639922;
  border-radius: 50%;
  display: inline-block;
  animation: or-pulse 1.5s ease-in-out infinite;
}

@keyframes or-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.or-btn-yenile {
  width: 28px;
  height: 28px;
  border: 1px solid #d3d1c7;
  background: #fff;
  border-radius: 4px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5f5e5a;
  transition: all 0.15s;
}
.or-btn-yenile:hover { background: #f5f4ee; border-color: #b4b2a9; }
.or-btn-yenile.donuyor svg { animation: or-donuyor 0.6s linear infinite; }
@keyframes or-donuyor { from { transform: rotate(0); } to { transform: rotate(360deg); } }

/* ========== FILTRE BAR ========== */
.or-filtre {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 14px;
  background: #f5f4ee;
  border: 1px solid #e8e6df;
  border-radius: 6px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}

.or-filtre-grup {
  display: flex;
  align-items: center;
  gap: 8px;
}
.or-filtre-grup label {
  font-size: 11px;
  color: #5f5e5a;
  font-weight: 500;
  letter-spacing: 0.2px;
}

.or-input {
  height: 30px;
  padding: 0 10px;
  border: 1px solid #d3d1c7;
  border-radius: 4px;
  font-size: 12px;
  background: #fff;
  color: #2c2c2a;
  font-family: inherit;
  outline: none;
}
.or-input:focus { border-color: #d4a52f; }

.or-btn-uygula {
  height: 30px;
  padding: 0 16px;
  background: #d4a52f;
  color: #2c2c2a;
  border: 1px solid #c0941a;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}
.or-btn-uygula:hover { background: #c0941a; }

.or-filtre-spacer { flex: 1; min-width: 20px; }

.or-vardiya-bilgi {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
}
.or-vardiya-etiket { color: #5f5e5a; }
.or-vardiya-deger { color: #2c2c2a; font-weight: 600; }
.or-vardiya-yuzde {
  padding: 2px 8px;
  background: #d4a52f;
  color: #2c2c2a;
  border-radius: 3px;
  font-weight: 700;
  font-size: 11px;
}

/* ========== KPI SERIDI ========== */
.or-kpi-serit {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
  margin-bottom: 16px;
}

.or-kpi {
  background: #fff;
  border: 1px solid #e8e6df;
  border-radius: 6px;
  padding: 10px 12px;
  text-align: left;
}
.or-kpi-label {
  font-size: 10px;
  color: #888780;
  font-weight: 600;
  letter-spacing: 0.4px;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.or-kpi-deger {
  font-size: 22px;
  font-weight: 600;
  color: #2c2c2a;
  line-height: 1;
  letter-spacing: -0.5px;
}
.or-kpi-deger.bos { color: #b4b2a9; }
.or-kpi-alt {
  font-size: 10px;
  color: #888780;
  margin-top: 3px;
}

/* ========== MAKINE GRID ========== */
.or-makine-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 14px;
}

.or-yukleniyor {
  grid-column: 1 / -1;
  padding: 40px;
  text-align: center;
  color: #888780;
  font-size: 13px;
}

/* ========== MAKINE KART ========== */
.or-mak-kart {
  background: #fff;
  border: 1px solid #e8e6df;
  border-radius: 6px;
  padding: 12px 14px;
  cursor: pointer;
  transition: all 0.15s;
}
.or-mak-kart:hover { border-color: #d4a52f; }
.or-mak-kart.secili { border-color: #d4a52f; border-width: 2px; padding: 11px 13px; }

.or-mak-kart.durum-tumuyle-aktif { border-left: 3px solid #639922; }
.or-mak-kart.durum-hibrit         { border-left: 3px solid #EF9F27; }
.or-mak-kart.durum-ariza-riski    { border-left: 3px solid #E24B4A; }
.or-mak-kart.durum-tumuyle-kapali { border-left: 3px solid #888780; }
.or-mak-kart.durum-rapor-yok      { border-left: 3px solid #d3d1c7; opacity: 0.85; }

.or-mak-ust {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8px;
}
.or-mak-ad {
  font-size: 14px;
  font-weight: 600;
  color: #2c2c2a;
}
.or-mak-ist-sayi {
  font-size: 10px;
  color: #888780;
}

.or-mak-durum-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 9px;
  border-radius: 3px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2px;
  margin-bottom: 8px;
}
.or-mak-durum-badge.tumuyle-aktif { background: #eaf3de; color: #173404; }
.or-mak-durum-badge.hibrit         { background: #faeeda; color: #412402; }
.or-mak-durum-badge.ariza-riski    { background: #fcebeb; color: #501313; }
.or-mak-durum-badge.tumuyle-kapali { background: #f1efe8; color: #2c2c2a; }
.or-mak-durum-badge.tumuyle-ariza  { background: #fcebeb; color: #501313; }
.or-mak-durum-badge.tumuyle-setup  { background: #faeeda; color: #412402; }
.or-mak-durum-badge.duruyor        { background: #f1efe8; color: #5f5e5a; }
.or-mak-durum-badge.rapor-yok      { background: #faeeda; color: #412402; }
.or-mak-durum-badge.ariza-ve-setup { background: #fcebeb; color: #501313; }

/* Slot dagilim cubuk */
.or-slot-bar {
  display: flex;
  height: 5px;
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 10px;
  background: #f1efe8;
}
.or-slot-bar-aktif  { background: #639922; }
.or-slot-bar-setup  { background: #EF9F27; }
.or-slot-bar-ariza  { background: #E24B4A; }
.or-slot-bar-kapali { background: #888780; }

/* Metrik grid */
.or-mak-metrikler {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px 12px;
  margin-bottom: 8px;
}
.or-metrik-blok { }
.or-metrik-label {
  font-size: 10px;
  color: #888780;
  font-weight: 500;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  margin-bottom: 2px;
}
.or-metrik-deger {
  font-size: 14px;
  font-weight: 600;
  color: #2c2c2a;
  line-height: 1.1;
}
.or-metrik-deger.bos { color: #b4b2a9; }
.or-metrik-alt {
  font-size: 10px;
  color: #888780;
  margin-top: 1px;
}

.or-mak-alt {
  margin-top: 10px;
  padding-top: 8px;
  border-top: 1px solid #f1efe8;
  display: flex;
  justify-content: space-between;
  font-size: 11px;
}
.or-mak-aktif-orani { color: #5f5e5a; }
.or-mak-aktif-orani strong { color: #2c2c2a; font-weight: 600; }
.or-mak-detay-btn {
  color: #d4a52f;
  font-weight: 600;
  cursor: pointer;
  background: none;
  border: none;
  font-size: 11px;
  padding: 0;
}
.or-mak-detay-btn:hover { text-decoration: underline; }

/* ========== DETAY PANELI ========== */
.or-detay {
  background: #fff;
  border: 1px solid #e8e6df;
  border-radius: 6px;
  margin-bottom: 14px;
  overflow: hidden;
}

.or-detay-baslik {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: #f5f4ee;
  border-bottom: 1px solid #e8e6df;
  font-size: 13px;
  font-weight: 600;
}
.or-detay-baslik #or-detay-makine-ad { color: #2c2c2a; }
.or-detay-durum-badge {
  padding: 2px 9px;
  background: #faeeda;
  color: #412402;
  border-radius: 3px;
  font-size: 11px;
  font-weight: 600;
}
.or-detay-vardiya {
  color: #888780;
  font-weight: 400;
  font-size: 11px;
  margin-left: auto;
}
.or-btn-detay-kapat {
  background: none;
  border: 1px solid #d3d1c7;
  border-radius: 3px;
  padding: 3px 10px;
  cursor: pointer;
  font-size: 11px;
  color: #5f5e5a;
}
.or-btn-detay-kapat:hover { background: #fff; }

.or-detay-icerik {
  padding: 14px;
}

.or-detay-grid {
  display: grid;
  grid-template-columns: 2fr 1.3fr 1fr 1.5fr;
  gap: 10px;
}

/* Detay panelleri */
.or-detay-panel {
  background: #fafaf6;
  border: 1px solid #e8e6df;
  border-radius: 4px;
  padding: 10px 12px;
}
.or-detay-panel-baslik {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.4px;
  text-transform: uppercase;
  color: #888780;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
}
.or-detay-panel-not {
  font-size: 10px;
  color: #888780;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
}

/* SLOT GRID - GRID_FIX_V2 (15.05.2026 - kompakt + net renkler) */
.or-slot-grid {
  display: grid;
  gap: 2px;
  font-size: 10px;
  align-items: stretch;
}
.or-slot-grid-baslik {
  display: contents;
}
.or-slot-grid-baslik > div {
  text-align: center;
  color: #5f5e5a;
  font-weight: 600;
  font-size: 9px;
  padding: 2px 0;
  letter-spacing: 0.3px;
}
.or-slot-hucre {
  height: 26px;
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 9px;
  letter-spacing: 0.4px;
}
.or-slot-hucre.s-aktif  { background: #639922; color: #fff; }
.or-slot-hucre.s-setup  { background: #EF9F27; color: #fff; }
.or-slot-hucre.s-ariza  { background: #E24B4A; color: #fff; }
.or-slot-hucre.s-kapali { background: #d3d1c7; color: #888780; font-weight: 600; }
.or-slot-satir-baslik {
  font-weight: 700;
  color: #2c2c2a;
  font-size: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f4ee;
  border-radius: 3px;
  height: 26px;
}

/* SAATLIK TUR TABLO */
.or-saatlik-tablo {
  width: 100%;
  font-size: 11px;
  border-collapse: collapse;
}
.or-saatlik-tablo th {
  text-align: left;
  font-weight: 600;
  color: #888780;
  padding: 4px 4px;
  border-bottom: 1px solid #e8e6df;
  font-size: 10px;
}
.or-saatlik-tablo th:nth-child(2) { text-align: right; }
.or-saatlik-tablo td {
  padding: 4px 4px;
  border-bottom: 1px solid #f1efe8;
}
.or-saatlik-tablo td:nth-child(2) {
  text-align: right;
  font-weight: 600;
}
.or-saatlik-tablo tr.bos td { color: #b4b2a9; }
.or-saatlik-tablo tr.bos td:nth-child(2) { font-weight: 400; }
.or-saatlik-tablo tr.toplam td {
  border-top: 1px solid #d3d1c7;
  font-weight: 700;
  padding-top: 5px;
}

/* SLOT-DAKIKA BAR LISTESI */
.or-sd-liste { display: flex; flex-direction: column; gap: 8px; }
.or-sd-blok { }
.or-sd-ust { display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 2px; }
.or-sd-etiket { font-weight: 600; }
.or-sd-deger { color: #5f5e5a; }
.or-sd-bar { height: 5px; background: #f1efe8; border-radius: 3px; overflow: hidden; }
.or-sd-bar-fill { height: 100%; }

.or-sd-blok.aktif .or-sd-etiket { color: #173404; }
.or-sd-blok.aktif .or-sd-bar-fill { background: #639922; }
.or-sd-blok.setup .or-sd-etiket { color: #412402; }
.or-sd-blok.setup .or-sd-bar-fill { background: #EF9F27; }
.or-sd-blok.ariza .or-sd-etiket { color: #501313; }
.or-sd-blok.ariza .or-sd-bar-fill { background: #E24B4A; }
.or-sd-blok.kapali .or-sd-etiket { color: #5f5e5a; }
.or-sd-blok.kapali .or-sd-bar-fill { background: #888780; }

.or-sd-toplam {
  margin-top: 8px;
  padding-top: 6px;
  border-top: 1px solid #e8e6df;
  display: flex;
  justify-content: space-between;
  font-size: 10px;
}
.or-sd-toplam-deger { font-weight: 600; }

/* OLAY LISTESI */
.or-olay-liste { display: flex; flex-direction: column; gap: 4px; }
.or-olay {
  display: grid;
  grid-template-columns: 44px 64px 1fr;
  gap: 6px;
  padding: 5px 7px;
  background: #fff;
  border: 1px solid #e8e6df;
  border-radius: 3px;
  font-size: 10px;
}
.or-olay-saat { font-family: 'Consolas', monospace; color: #888780; }
.or-olay-tip {
  display: inline-flex;
  align-items: center;
  padding: 1px 6px;
  border-radius: 2px;
  font-size: 9px;
  font-weight: 600;
}
.or-olay-tip.setup { background: #faeeda; color: #412402; }
.or-olay-tip.ariza { background: #fcebeb; color: #501313; }
.or-olay-tip.diger { background: #f1efe8; color: #5f5e5a; }
.or-olay-metin { color: #2c2c2a; font-size: 10px; }
.or-olay-metin .or-olay-detay-sure { color: #888780; }
.or-olay-bos {
  text-align: center;
  padding: 12px;
  color: #b4b2a9;
  font-size: 11px;
}

/* ========== ALT BILGI ========== */
.or-alt-bilgi {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  background: #fafaf6;
  border: 1px solid #e8e6df;
  border-radius: 6px;
  font-size: 11px;
  flex-wrap: wrap;
  gap: 10px;
}

.or-uyari-ozet {
  color: #5f5e5a;
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}
.or-uyari-item {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.or-uyari-item.warning { color: #854F0B; }
.or-uyari-item.info { color: #888780; }

.or-renk-legend {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.or-renk-item {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  color: #5f5e5a;
}
.or-renk-kutu {
  width: 10px;
  height: 10px;
  border-radius: 2px;
}
.or-renk-kutu.r-aktif  { background: #639922; }
.or-renk-kutu.r-setup  { background: #EF9F27; }
.or-renk-kutu.r-ariza  { background: #E24B4A; }
.or-renk-kutu.r-kapali { background: #888780; }
.or-renk-kutu.r-hibrit { background: #faeeda; border: 1px solid #EF9F27; }

/* ========== RESPONSIVE ========== */
@media (max-width: 1023px) {
  .or-kpi-serit { grid-template-columns: repeat(4, 1fr); }
  .or-kpi-serit > .or-kpi:nth-child(n+5):nth-child(-n+7) { grid-column: span 1; }
  .or-detay-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 767px) {
  .or-kpi-serit { grid-template-columns: repeat(3, 1fr); }
  .or-makine-grid { grid-template-columns: 1fr; }
  .or-detay-grid { grid-template-columns: 1fr; }
  .or-filtre { flex-direction: column; align-items: flex-start; }
  .or-filtre-spacer { display: none; }
  .or-vardiya-bilgi { align-self: stretch; justify-content: space-between; }
}
