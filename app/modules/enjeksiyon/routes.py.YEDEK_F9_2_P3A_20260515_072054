                    "eski_durum": eski_durum, "kalip_id": ist["kalip_id"]
                }
            )
        except Exception:
            pass
        
        con.commit()
        con.close()
        
        return jsonify({
            "ok": True, "durum": "ARIZA",
            "ariza_sebep": sebep,
            "kalip_id": ist["kalip_id"],
            "bagli_kalip_adet": yeni_bagli
