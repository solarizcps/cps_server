"""CPS DEV - Enjeksiyon Takip Routes (FAZ 2 iskelet)

Bu modul faz 1 migration tablolarini (enj_*) kullanarak enjeksiyon
takip ekranini render eder. F2'de sadece iskelet; F6'da gercek HTML.

URL yapisi:
  /enjeksiyon/          -> Yonetim (admin/Yonetim/Planlama/Uretim)
  /enjeksiyon/saha      -> Saha (login yeterli, sidebar'siz)
  /enjeksiyon/api/...   -> API endpointleri

Yetki desenleri hedef modulu (modules.hedef.routes) ile uyumludur.
"""
from flask import (Blueprint, render_template, redirect, url_for,
                   request, session, abort, jsonify)
from functools import wraps


enjeksiyon_bp = Blueprint('enjeksiyon', __name__, url_prefix='/enjeksiyon')


# ============== YETKI HELPER'LARI ==============

def _yonetim_yetkisi():
    """admin / Yonetim / Planlama / Uretim erisebilir.

    Hedef modulundeki _admin_mi() ile ayni desen.
    """
    u = session.get('kullanici')
    if not u:
        return False
    if u.get('KullaniciAdi') == 'admin':
        return True
    if u.get('RolAd') in ('Yönetim', 'Planlama', 'Uretim'):
        return True
    return False


def yonetim_yetkili(f):
    """Sidebar'li yonetim sayfalari icin decorator."""
    @wraps(f)
    def wrapper(*args, **kwargs):
        if not session.get('kullanici'):
            return redirect(url_for('auth.login', next=request.path))
        if not _yonetim_yetkisi():
            abort(403)
        return f(*args, **kwargs)
    return wrapper


def saha_yetkili(f):
    """Saha ekrani icin decorator - login olmus herkes."""
    @wraps(f)
    def wrapper(*args, **kwargs):
        if not session.get('kullanici'):
            return redirect(url_for('auth.login', next=request.path))
        return f(*args, **kwargs)
    return wrapper


