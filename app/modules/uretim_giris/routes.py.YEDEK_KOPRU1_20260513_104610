# -*- coding: utf-8 -*-

from flask import Blueprint, render_template, redirect, url_for, request, session, abort, Response
from functools import wraps
import requests
from config import Config

# 🔥 Blueprint
uretim_giris_bp = Blueprint('uretim_giris', __name__, url_prefix='/uretim')


# ================== YETKI ==================
def _uretim_yetkili_mi():
    """FAZ 5.5: Tip oncelikli + admin + rol fallback."""
    u = session.get('kullanici')
    if not u:
        return False

    # FAZ 5.5: Tip kontrolu (personel ve usta her zaman /uretim/ acabilir)
    tip = session.get('kullanici_tip')
    if tip in ('personel', 'usta'):
        return True

    # Admin kisayolu
    if u.get('KullaniciAdi') == 'admin':
        return True

    # Rol kontrolu - guvenli okuma (RolAd, Rol, rol_ad, rol)
    rol = (u.get('RolAd') or u.get('Rol') or u.get('rol_ad') or u.get('rol') or '').strip()
    return rol in ('Personel', 'Usta', 'Yönetim', 'Üretim')


def uretim_yetkili(f):
    @wraps(f)
    def wrapper(*args, **kwargs):
        if not session.get('kullanici'):
            return redirect(url_for('auth.login', next=request.path))

        if not _uretim_yetkili_mi():
            abort(403)

        return f(*args, **kwargs)
    return wrapper


# ================== PANEL ==================
@uretim_giris_bp.route('/')
@uretim_yetkili
def panel():
    return render_template('uretim_giris/index.html')


# ================== PROXY ==================
@uretim_giris_bp.route('/proxy/<path:path>', methods=['GET', 'POST'])
def uretim_proxy(path):

    url = f"{Config.MES_API_URL}/{path}"

    try:
        if request.method == 'GET':
            r = requests.get(url)
        else:
            r = requests.post(url, json=request.get_json())

        return Response(
            r.content,
            status=r.status_code,
            content_type=r.headers.get('Content-Type')
        )

    except Exception as e:
        return {"ok": False, "hata": str(e)}, 500


