# =====================================================
# YETKI KONTROLU
# =====================================================
def _yetki_var_mi():
    """Sadece Yonetim rolu + admin kullanici gorebilir."""
    u = session.get('kullanici')
    if not u or not isinstance(u, dict):
        return False
    rol = u.get('RolAd') or ''
    kad = u.get('KullaniciAdi') or ''
    return rol == 'Yönetim' or kad == 'admin'


