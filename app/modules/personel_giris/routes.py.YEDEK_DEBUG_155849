@personel_giris_bp.route('/gecmis/<int:pid>', methods=['GET'])
def gecmis(pid):
    limit = request.args.get('limit', 30, type=int)
    try:
        conn = _cps_conn()
        rows = conn.execute("""
            SELECT id, emir_no, model_kod, model_adi, miktar,
                   proses_adi, tarih, saat, onay_durum, olusturma
              FROM uretim_kayit
             WHERE personel_id = ?
             ORDER BY olusturma DESC
             LIMIT ?
        """, (pid, limit)).fetchall()
        conn.close()
        return jsonify([dict(r) for r in rows])
    except Exception as e:
        return jsonify({'hata': str(e)}), 500


