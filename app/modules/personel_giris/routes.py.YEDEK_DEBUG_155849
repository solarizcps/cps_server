"""
personel_giris/routes.py
========================
Personel telefon UI backend endpoint'leri.

5055 ile birebir uyumlu API:
  GET  /personel-giris/                  -> HTML (telefon UI)
  GET  /personel-giris/health            -> JSON saglik
  POST /personel-giris/login             -> Sifre kontrol
  GET  /personel-giris/personeller       -> Aktif personel listesi
  GET  /personel-giris/dogrula/<pid>     -> Session refresh
  GET  /personel-giris/emir/<emir_no>    -> Emir detay (placeholder, Korgun sonra)
  GET  /personel-giris/emir-toplam/<no>  -> Toplam + benim toplam
  GET  /personel-giris/prosesler/<no>    -> Emir prosesleri (5055 emir_proses tablosu)
  POST /personel-giris/kaydet            -> Uretim kaydet (CPS_CANLI)
  GET  /personel-giris/gecmis/<pid>      -> Personel gecmis
  GET  /personel-giris/prim/<pid>        -> Personel prim (placeholder)
"""
import sqlite3
import os
import datetime
import traceback
from flask import Blueprint, render_template, jsonify, request

personel_giris_bp = Blueprint(
    'personel_giris',
    __name__,
    url_prefix='/personel-giris',
    template_folder='../../templates/personel_giris',
)

DB_5055 = r"D:\Ortak\Solariz-ARGE\solariz.db"


def _db_path():
    """CPS DB yolu."""
    here = os.path.dirname(os.path.abspath(__file__))
    return os.path.normpath(os.path.join(here, '..', '..', 'mock_data.db'))


def _cps_conn():
    """CPS DB baglantisi."""
    conn = sqlite3.connect(_db_path(), timeout=10)
    conn.row_factory = sqlite3.Row
    return conn


def _5055_conn():
    """5055 READ-ONLY baglantisi (emir_proses icin)."""
    uri = "file:" + DB_5055.replace("\\", "/") + "?mode=ro&nolock=1"
    conn = sqlite3.connect(uri, uri=True, timeout=5)
    conn.row_factory = sqlite3.Row
    return conn


# CPS auth bypass icin: bu blueprint'in tum endpoint'lerinde session kontrolu olmasın
@personel_giris_bp.before_request
def _bypass_cps_auth():
    """Personel telefon UI kendi login sistemine sahip - CPS auth bypass."""
    # Burada None dondurursek before_request normal akisa devam eder.
    # Eger CPS'in global auth filter'i varsa, o yine de calisir.
    # Bu sebepten endpoint icinde de kendi kontrolumuzu yapacagiz.
    return None


