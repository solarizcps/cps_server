# 9. KAYDET - ANA KAYIT ENDPOINT
# ============================================================
@personel_giris_bp.route('/kaydet', methods=['POST'])
def kaydet():
    """
    Personel uretim kaydi.
    POST body:
      emir_no, model_kod, model_adi, emir_miktar, miktar,
      proses_adi (opsiyonel), personel_id, personel_ad,
      tarih, saat
    """
    data = request.get_json(silent=True) or {}

    # Zorunlu alanlar
    emir_no = data.get('emir_no')
    miktar = data.get('miktar')
    personel_id = data.get('personel_id')
    personel_ad = data.get('personel_ad', '').strip()

    if not emir_no or not miktar or not personel_id:
        return jsonify({'ok': False, 'mesaj': 'emir_no, miktar, personel_id zorunlu'}), 400

    try:
        miktar = int(miktar)
        emir_no = int(emir_no)
        personel_id = int(personel_id)
    except (ValueError, TypeError):
        return jsonify({'ok': False, 'mesaj': 'Sayisal alanlar gecersiz'}), 400

    if miktar <= 0:
        return jsonify({'ok': False, 'mesaj': 'Miktar 0 dan buyuk olmali'}), 400

    # Opsiyonel alanlar
    model_kod = (data.get('model_kod') or '').strip()
    model_adi = (data.get('model_adi') or '').strip()
    proses_adi = (data.get('proses_adi') or '').strip()
    tarih = data.get('tarih') or datetime.datetime.now().strftime('%Y-%m-%d')
    saat = data.get('saat') or datetime.datetime.now().strftime('%H:%M')

    try:
        conn = _cps_conn()
        cur = conn.cursor()
        cur.execute("""
            INSERT INTO uretim_kayit (
                emir_no, model_kod, model_adi, miktar,
                proses_kodu, proses_adi,
                personel_id, personel_ad,
                tarih, saat,
                not_metin, onay_durum,
                usta_id, usta_ad, usta_not,
                onay_tarihi, olusturma,
                kaynak, legacy_id, legacy_db, import_tarihi, import_hash
            ) VALUES (
                ?, ?, ?, ?,
                NULL, ?,
                ?, ?,
                ?, ?,
                NULL, 'bekliyor',
                NULL, NULL, NULL,
                NULL, datetime('now', 'localtime'),
                'CPS_CANLI', NULL, NULL, NULL, NULL
            )
        """, (
            emir_no, model_kod, model_adi, miktar,
            proses_adi,
            personel_id, personel_ad,
            tarih, saat
        ))
        kayit_id = cur.lastrowid
        conn.commit()
        conn.close()

        return jsonify({
            'ok': True,
            'mesaj': f'{miktar} cift kaydedildi',
            'id': kayit_id
        })
    except Exception as e:
        return jsonify({'ok': False, 'mesaj': str(e)}), 500


