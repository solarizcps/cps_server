@personel_giris_bp.route('/health', methods=['GET'])
def health():
    try:
        conn = _cps_conn()
        toplam = conn.execute("SELECT COUNT(*) FROM personel_kullanici").fetchone()[0]
        aktif = conn.execute("SELECT COUNT(*) FROM personel_kullanici WHERE aktif=1").fetchone()[0]
        conn.close()
        return jsonify({
            'ok': True,
            'modul': 'personel_giris',
            'personel_kullanici_toplam': toplam,
            'aktif_personel': aktif,
        })
    except Exception as e:
        return jsonify({'ok': False, 'mesaj': str(e)}), 500


