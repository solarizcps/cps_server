# 3. LOGIN - sifre kontrol
# ============================================================
@personel_giris_bp.route('/login', methods=['POST'])
def login():
    data = request.get_json(silent=True) or {}
    kullanici = (data.get('kullanici') or '').strip().lower()
    sifre = (data.get('sifre') or '').strip()

    if not kullanici or not sifre:
        return jsonify({'ok': False, 'mesaj': 'Kullanici ve sifre gerekli'}), 400

    try:
        conn = _cps_conn()
        # Case-insensitive lookup (5055'te 'halil kıraç' format)
        row = conn.execute("""
            SELECT id, ad, kullanici_adi, sifre, aktif
              FROM personel_kullanici
             WHERE LOWER(kullanici_adi) = ? AND aktif = 1
             LIMIT 1
        """, (kullanici,)).fetchone()
        conn.close()

        if not row:
            return jsonify({'ok': False, 'mesaj': 'Kullanici bulunamadi'}), 200
        if row['sifre'] != sifre:
            return jsonify({'ok': False, 'mesaj': 'Sifre yanlis'}), 200

        return jsonify({
            'ok': True,
            'personel': {
                'id': row['id'],
                'ad': row['ad'],
                'kullanici_adi': row['kullanici_adi']
            }
        })
    except Exception as e:
        return jsonify({'ok': False, 'mesaj': str(e)}), 500


