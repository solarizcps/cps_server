# 6. EMIR detay - placeholder (FAZ 5/6'da Korgun zenginlestirme)
# ============================================================
@personel_giris_bp.route('/emir/<int:emir_no>', methods=['GET'])
def emir_detay(emir_no):
    """
    Emir detayi - gercek veri enrichment.
    Kaynak siralamasi:
      EmirMiktar:
        1) CPS emir_alt_proses MAX(hedef_adet)
        2) 5055 emir_proses MAX(limit_miktar) (proses_adi NOT LIKE '%.%')
      toplam_girilen / bugun_girilen / kalan:
        CPS uretim_kayit (onaylandi + bekliyor)
      ModelKod / ModelAdi / CariAdi / TerTarih:
        Korgun proxy (sonraki sprint - simdilik bos)
    """
    personel_id = request.args.get('personel_id', type=int)

    emir_miktar = 0
    # A) CPS emir_alt_proses
    try:
        ccps = _cps_conn()
        row = ccps.execute("""
            SELECT MAX(hedef_adet) m FROM emir_alt_proses
             WHERE emir_no = ? AND aktif = 1
        """, (emir_no,)).fetchone()
        ccps.close()
        if row and row['m']:
            emir_miktar = row['m']
    except Exception:
        pass

    # B) 5055 emir_proses fallback
    if not emir_miktar:
        try:
            c5055 = _5055_conn()
            row = c5055.execute("""
                SELECT MAX(limit_miktar) m FROM emir_proses
                 WHERE emir_no = ?
                   AND proses_adi NOT LIKE '%.%'
                   AND limit_miktar > 0
            """, (emir_no,)).fetchone()
            c5055.close()
            if row and row['m']:
                emir_miktar = row['m']
        except Exception as e:
            traceback.print_exc()
            print(f"[EMIR HATA] {type(e).__name__}: {e}", flush=True)

    # CPS toplam / bugun girilen
    toplam_girilen = 0
    bugun_girilen = 0
    try:
        ccps = _cps_conn()
        toplam_girilen = ccps.execute("""
            SELECT COALESCE(SUM(miktar), 0) FROM uretim_kayit
             WHERE emir_no = ? AND onay_durum IN ('onaylandi', 'bekliyor')
        """, (emir_no,)).fetchone()[0]
        if personel_id:
            bugun_girilen = ccps.execute("""
                SELECT COALESCE(SUM(miktar), 0) FROM uretim_kayit
                 WHERE emir_no = ? AND personel_id = ?
                   AND date(tarih) = date('now', 'localtime')
                   AND onay_durum IN ('onaylandi', 'bekliyor')
            """, (emir_no, personel_id)).fetchone()[0]
        ccps.close()
    except Exception:
        pass

    kalan = max(0, (emir_miktar or 0) - (toplam_girilen or 0))

    return jsonify({
        'EmirNo': emir_no,
        'ModelKod': '',
        'ModelAdi': '',
        'RenkAdi': '',
        'CariAdi': '',
        'TerTarih': '',
        'Location': '',
        'EmirMiktar': emir_miktar or 0,
        'prosesler': [],
        'toplam_girilen': toplam_girilen or 0,
        'bugun_girilen': bugun_girilen or 0,
        'kalan': kalan
    })


