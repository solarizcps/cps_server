# 7. EMIR-TOPLAM - bu emirden ne kadar girilmis
# ============================================================
@personel_giris_bp.route('/emir-toplam/<int:emir_no>', methods=['GET'])
def emir_toplam(emir_no):
    personel_id = request.args.get('personel_id', type=int)
    proses = request.args.get('proses', '')

    try:
        conn = _cps_conn()

        # Toplam (onaylananlar - tum sistemden)
        toplam = conn.execute("""
            SELECT COALESCE(SUM(miktar), 0)
              FROM uretim_kayit
             WHERE emir_no = ? AND onay_durum = 'onaylandi'
        """, (emir_no,)).fetchone()[0]

        # Benim toplam (bu personelin bugunku - bekleyenler dahil)
        benim = 0
        if personel_id:
            if proses:
                benim = conn.execute("""
                    SELECT COALESCE(SUM(miktar), 0)
                      FROM uretim_kayit
                     WHERE emir_no = ? AND personel_id = ?
                       AND proses_adi = ?
                       AND date(tarih) = date('now', 'localtime')
                """, (emir_no, personel_id, proses)).fetchone()[0]
            else:
                benim = conn.execute("""
                    SELECT COALESCE(SUM(miktar), 0)
                      FROM uretim_kayit
                     WHERE emir_no = ? AND personel_id = ?
                       AND date(tarih) = date('now', 'localtime')
                """, (emir_no, personel_id)).fetchone()[0]

        conn.close()
        return jsonify({'toplam': toplam, 'benim': benim})
    except Exception as e:
        return jsonify({'toplam': 0, 'benim': 0, 'hata': str(e)})


# ============================================================
# 8. PROSESLER - bir emir'in alt prosesleri (5055 emir_proses tablosu)
# ============================================================
@personel_giris_bp.route('/prosesler/<int:emir_no>', methods=['GET'])
def prosesler(emir_no):
    """5055'in emir_proses tablosundan oku - 5055 hala usta panel ile guncelliyor olabilir."""
    try:
        # Once 5055 emir_proses'ten oku (READ-ONLY)
        c5055 = _5055_conn()
        # Hatali coklu-proses satirlarini at (proses_adi'da nokta=birden cok proses yapismis)
        rows = c5055.execute("""
            SELECT id, emir_no, proses_adi, limit_miktar, olusturma
              FROM emir_proses
             WHERE emir_no = ?
               AND proses_adi NOT LIKE '%.%'
             ORDER BY id
        """, (emir_no,)).fetchall()
        c5055.close()

        # Her proses icin toplam_girilen hesabi (CPS uretim_kayit)
        ccps = _cps_conn()
        result = []
        for r in rows:
            d = dict(r)
            total = ccps.execute("""
                SELECT COALESCE(SUM(miktar), 0)
                  FROM uretim_kayit
                 WHERE emir_no = ? AND proses_adi = ?
                   AND onay_durum IN ('onaylandi', 'bekliyor')
            """, (emir_no, d['proses_adi'])).fetchone()[0]
            d['toplam_girilen'] = total
            result.append(d)
        ccps.close()

        return jsonify(result)
    except Exception as e:
        traceback.print_exc()
        print(f"[PROSESLER HATA] {type(e).__name__}: {e}", flush=True)
        return jsonify({"hata_debug": str(e), "tip": type(e).__name__})


