@finans_bp.route('/anlasma/yeni', methods=['GET', 'POST'])
def anlasma_yeni():
    if request.method == 'POST':
        try:
            data = request.get_json(force=True, silent=False)
            veri = data['anlasma']
            modeller = data.get('modeller') or []
            avanslar = data.get('avanslar') or []
            plan = data.get('plan') or []
            if not veri.get('ProjeKod') or not veri.get('ProjeAdi') or not veri.get('CKod'):
