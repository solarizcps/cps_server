@finans_bp.route('/simulator/<int:sim_id>')
def simulator_detay(sim_id):
    if not session.get('kullanici'):
        return redirect(url_for('auth.login', next=request.path))
    s = sim_qr.simulasyon_tek(sim_id)
    if not s:
        abort(404)
    ay = request.args.get('ay', default=6, type=int)
    if ay not in (3, 6, 12):
        ay = 6

    secenekler = sim_qr.secenek_liste(sim_id)
    # Her seçenek için kıyas hesapla
    kiyaslar = {}
    for sc in secenekler:
        kiyaslar[sc['Id']] = sim_qr.gecmis_kiyas_hesapla(dict(sc), dict(s), ay=ay)

    # Öneri skoru
    satis_var = (s['HedefCiftSatis'] or 0) > 0
    skorlar = sim_qr.oneri_skorla(secenekler, satis_var)
    en_iyiler = sim_qr.en_iyiler(secenekler)
    onerilen = sim_qr.en_onerilen(secenekler, skorlar)

    # Tedarikçi ve teklif dropdown için
    from db import q as _q
    tedarikciler = _q("SELECT Id, Ad FROM grafik_tedarikci WHERE Aktif=1 ORDER BY Ad")
    teklifler = _q("""SELECT Id, TeklifNo, UrunAd, BirimFiyat, ParaBirimi, KurSnapshot
                      FROM grafik_fiyat_teklif WHERE Durum IN ('ALINDI','DEGERLENDIRILIYOR')
                      ORDER BY TeklifTarihi DESC LIMIT 50""")

    return render_template('finans/simulator_detay.html',
                           sim=s,
                           secenekler=secenekler,
                           kiyaslar=kiyaslar,
                           skorlar=skorlar,
                           en_iyiler=en_iyiler,
                           onerilen=onerilen,
                           ay=ay,
                           satis_var=satis_var,
                           tedarikciler=tedarikciler,
                           teklifler=teklifler,
                           karar_yetkili=_karar_yetkili())


