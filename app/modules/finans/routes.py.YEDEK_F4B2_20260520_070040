# [FINANS_YETKI_HELPER_V1] - Finans Native yetki kontrolu
# Karar: sadece admin + altan finans modulune girer.
# Halil/Hasan/Muhasebe URL yazsa 403 alir.
# Sahsi entity kurali service icinde ayrica filtreli (admin only).
def _finans_native_allowed_user(g_user):
    """Finans Native modulu yetki kontrolu - sadece admin + altan."""
    if not g_user:
        return False
    kullanici_adi = (g_user.get('KullaniciAdi') or '').strip().lower()
    return kullanici_adi in ('admin', 'altan')


# ============================================================
# FAZ KOPRU-2 (13.05.2026): FINANS MODUL ERISIM GUARD
# Sadece su kullanicilar finans modulunu acabilir:
#   - admin (kullanici adi)
#   - Adem Terzi / Altan Terzi (isim/kullanici adi ile)
#   - RolAd 'Muhasebe' veya 'Finans'
# Diger herkes (Yonetim rolu dahil) 403 alir.
# Yetki Sistemi V2 sonrasi sistem_yetki tablosundan okunacak.
# ============================================================
@finans_bp.before_request
def _finans_modul_guard():
    if not session.get('kullanici'):
        return redirect(url_for('auth.login', next=request.path))
    u = session['kullanici']
    kadi = (u.get('KullaniciAdi') or '').strip().lower()
    adsoyad = (u.get('AdSoyad') or '').strip().lower()
    rol = (u.get('RolAd') or u.get('Rol') or '').strip()
    # 1) admin
    if kadi == 'admin':
        return None
    # 2) Adem Terzi (kullanici adi VEYA isim)
    if kadi == 'adem' or 'adem terzi' in adsoyad:
        return None
    # 3) Altan Terzi (kullanici adi VEYA isim)
    if kadi == 'altan' or 'altan terzi' in adsoyad:
        return None
    # 4) Muhasebe veya Finans rolu
    if rol in ('Muhasebe', 'Finans'):
        return None
    # 5) Diger herkes (Yonetim rolu dahil) 403
    abort(403)



def _u():
    """Mevcut kullanıcı adı — audit log için."""
    k = session.get('kullanici')
    return k['KullaniciAdi'] if k else 'sistem'


