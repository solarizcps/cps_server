@finans_bp.route('/cin-ofis/upload', methods=['POST'])
def cin_ofis_upload():
    if not _cof_yetkili():
        abort(403)
    f = request.files.get('excel')
    if not f or not f.filename.endswith('.xlsx'):
        flash('Geçerli bir .xlsx dosyası yükleyin.', 'hata')
        return redirect(url_for('finans.cin_ofis_liste'))

    try:
        # Temp kaydet
        temp_dir = os.path.join('uploads', 'cin_ofis', '_temp')
        os.makedirs(temp_dir, exist_ok=True)
        temp_path = os.path.join(temp_dir, secure_filename(f.filename))
        f.save(temp_path)

        # Parse
        data = cof_xl.parse_excel(temp_path)
        hatalar, uyarilar = cof_xl.validate(data)

        # Kritik parse hataları varsa önizleme bile oluşturma
        if hatalar and any('okunamadı' in h or 'bulunamadı' in h or 'versiyonu uyumsuz' in h for h in hatalar):
            audit.log_olay(_u(), 'CIN_OFIS_PARSE_HATASI', None, None,
                           aciklama=f'Dosya: {f.filename} | Hatalar: {"; ".join(hatalar[:3])}',
                           modul='finans', alt_modul='cin_ofis')
            flash('Dosya okunamadı: ' + '; '.join(hatalar), 'hata')
            return redirect(url_for('finans.cin_ofis_liste'))

        # Kur çözümle
        try:
            kur_info = cof_xl.kur_coz(data)
        except ValueError as e:
            audit.log_olay(_u(), 'CIN_OFIS_KUR_HATASI', None, None,
                           aciklama=str(e),
                           modul='finans', alt_modul='cin_ofis')
            flash(str(e), 'hata')
            return redirect(url_for('finans.cin_ofis_liste'))

        # Büyük fark audit
        if kur_info.get('buyuk_fark'):
            audit.log_olay(_u(), 'CIN_OFIS_KUR_FARKI_YUKSEK', None, None,
                           aciklama=(f'{kur_info["pb"]} sistem={kur_info["sistem_kur"]:.4f} '
                                    f'excel={kur_info["excel_rate"]:.4f} fark=%{kur_info["fark_yuzde"]}'),
                           modul='finans', alt_modul='cin_ofis')

        # Önizleme log kaydı
        log_id, onceki = cof_qr.log_onizleme_kaydet(data, f.filename, kur_info, _u())
        return redirect(url_for('finans.cin_ofis_onizleme', log_id=log_id))

    except Exception as e:
        import logging, traceback
        logging.error(f'Çin Ofis upload hatası: {e}\n{traceback.format_exc()}')
        flash(f'Sistem hatası: Excel işlenemedi. Detay: {str(e)[:150]}', 'hata')
        return redirect(url_for('finans.cin_ofis_liste'))


@finans_bp.route('/cin-ofis/onizleme/<int:log_id>')
def cin_ofis_onizleme(log_id):
    if not _cof_yetkili():
        abort(403)
    log = cof_qr.import_log_tek(log_id)
    if not log:
        abort(404)
    import json as _json
    parse_data = _json.loads(log['ParseOzet'])
    hatalar, uyarilar = cof_xl.validate(parse_data)

    # Kur info
    kur_info = {
        'pb': log['KurPB'],
        'sistem_kur': log['SistemKurDeger'],
        'excel_rate': log['ExcelKurDeger'],
        'fark_yuzde': log['KurFarkiYuzde'],
        'buyuk_fark': (log['KurFarkiYuzde'] or 0) > 10,
        'override_mumkun': bool(log['ExcelKurDeger']),
        'kaynak_default': log['KurKaynagi'],
        'kur_tarih': log['KurTarihi'],
    }

    # Önceki import (revizyon)
    onceki = None
    if log['OncekiImportId']:
        onceki = qone(
            """SELECT l.*, s.SiparisNo, s.Durum as SiparisDurum
               FROM cin_ofis_import_log l
               LEFT JOIN grafik_cin_siparis s ON s.Id = l.SiparisId
               WHERE l.Id = ?""", (log['OncekiImportId'],))

    # Required dosyalar — yüklendi mi
    dosyalar = cof_qr.dosya_referans_liste(log_id)
    upload_dir = os.path.join('uploads', 'cin_ofis', log['OrderCode'])
    dosya_durumu = []
    for d in dosyalar:
        yuklu = os.path.exists(os.path.join(upload_dir, d['DosyaAdi']))
        dosya_durumu.append({**dict(d), 'Yuklu': yuklu})

    # Tedarikçi eşleşmesi — önizleme bilgisi
    tedarikci_info = {'durum': 'YOK', 'ad': None, 'kod': None, 'mevcut_kod': None}
    ted_ad = (parse_data.get('INFO', {}).get('Supplier Name') or '').strip()
    if ted_ad:
        tedarikci_info['ad'] = ted_ad
        # Exact
        exact = qone("SELECT Id, Kod FROM grafik_tedarikci WHERE LOWER(Ad)=LOWER(?) AND Aktif=1",
                     (ted_ad,))
        if exact:
            tedarikci_info['durum'] = 'EXACT'
            tedarikci_info['mevcut_kod'] = exact['Kod']
        else:
            search = ted_ad[:10].strip()
            fuzzy = qone("SELECT Id, Kod, Ad FROM grafik_tedarikci WHERE Ad LIKE ? AND Aktif=1 LIMIT 1",
                         (f'%{search}%',))
            if fuzzy:
                tedarikci_info['durum'] = 'FUZZY'
                tedarikci_info['mevcut_kod'] = fuzzy['Kod']
                tedarikci_info['ad'] = f'{ted_ad} → {fuzzy["Ad"]}'
            else:
                tedarikci_info['durum'] = 'YENI'
                # Oluşacak kod tahmini
                import re as _re
                kelimeler = _re.findall(r'[A-Za-z0-9]+', ted_ad.upper())
                base = kelimeler[0][:4] if kelimeler else 'SUP'
                tedarikci_info['kod'] = f'CN-{base}'

    return render_template('finans/cin_ofis_onizleme.html',
                           log=log, data=parse_data,
                           hatalar=hatalar, uyarilar=uyarilar,
                           kur_info=kur_info, onceki=onceki,
                           odeme_taslak=cof_qr.odeme_taslak_liste(log_id),
                           dosyalar=dosya_durumu,
                           tedarikci_info=tedarikci_info,
                           kur_override_yetkili=_cof_kur_override_yetkili())


@finans_bp.route('/cin-ofis/onayla/<int:log_id>', methods=['POST'])
def cin_ofis_onayla(log_id):
    if not _cof_yetkili():
        abort(403)

    log = cof_qr.import_log_tek(log_id)
    if not log:
        abort(404)

    # Duplicate varsa aksiyon
    duplicate_aksiyon = request.form.get('duplicate_aksiyon')  # 'revize' veya 'iptal'
    if log['OncekiImportId'] and duplicate_aksiyon == 'iptal':
        cof_qr.import_iptal(log_id, _u(), sebep='Duplicate — kullanıcı iptal etti')
        flash('İçe aktarma iptal edildi.', 'ok')
        return redirect(url_for('finans.cin_ofis_liste'))

    revizyon_flag = (log['OncekiImportId'] and duplicate_aksiyon == 'revize')

    # Kur kararı
    kur_override = request.form.get('kur_override') == '1'
    if kur_override:
        if not _cof_kur_override_yetkili():
            abort(403)
        gerekce = (request.form.get('kur_gerekce') or '').strip()
        if not gerekce:
            flash('Excel kuru kullanmak için gerekçe zorunlu.', 'hata')
            return redirect(url_for('finans.cin_ofis_onizleme', log_id=log_id))
        kur_karari = {
            'kaynak': 'EXCEL_OVERRIDE',
            'kur': log['ExcelKurDeger'],
            'gerekce': gerekce,
        }
    else:
        kur_karari = {
            'kaynak': 'SISTEM_OTOMATIK',
            'kur': log['SistemKurDeger'] or log['KurDeger'],
            'gerekce': None,
        }

    try:
        siparis_id, sno = cof_qr.siparis_olustur(log_id, _u(), kur_karari, revizyon=revizyon_flag)
        flash(f'✓ Sipariş oluşturuldu: {sno} (Durum: CIN_IMPORT_KONTROL)', 'ok')
        # Zengin sonuç için ek bilgi topla
        siparis = qone("""SELECT s.*, t.Ad AS TedarikciAd
                          FROM grafik_cin_siparis s
                          LEFT JOIN grafik_tedarikci t ON t.Id = s.TedarikciId
                          WHERE s.Id = ?""", (siparis_id,))
        from db import qscalar
        kalem_sayi = qscalar("SELECT COUNT(*) FROM grafik_cin_siparis_kalem WHERE SiparisId=?", (siparis_id,)) or 0
        toplam = qscalar("SELECT COALESCE(SUM(Tutar),0) FROM grafik_cin_siparis_kalem WHERE SiparisId=?", (siparis_id,)) or 0
        ot_sayi = qscalar("SELECT COUNT(*) FROM cin_ofis_odeme_taslak WHERE ImportLogId=?", (log_id,)) or 0
        ds = qscalar("SELECT COUNT(*) FROM cin_ofis_dosya_referans WHERE ImportLogId=?", (log_id,)) or 0
        req = qscalar("SELECT COUNT(*) FROM cin_ofis_dosya_referans WHERE ImportLogId=? AND Gerekli=1", (log_id,)) or 0
        return render_template('finans/cin_ofis_sonuc.html',
                               log=cof_qr.import_log_tek(log_id),
                               siparis_id=siparis_id, siparis_no=sno,
                               tedarikci_ad=siparis['TedarikciAd'] if siparis else None,
                               kalem_sayi=kalem_sayi,
                               toplam_tutar=toplam,
                               odeme_taslak_sayi=ot_sayi,
                               dosya_sayi=ds,
                               required_dosya_sayi=req)
    except ValueError as e:
        flash(str(e), 'hata')
        return redirect(url_for('finans.cin_ofis_onizleme', log_id=log_id))
    except Exception as e:
        import logging, traceback
        logging.error(f'Çin Ofis onayla hatası log_id={log_id}: {e}\n{traceback.format_exc()}')
        flash(f'Sistem hatası: sipariş oluşturulamadı. Detay: {str(e)[:150]}', 'hata')
        return redirect(url_for('finans.cin_ofis_onizleme', log_id=log_id))


