import sqlite3
import os
from datetime import datetime, timedelta


def _db_path():
    """app/mock_data.db full path (services 3 seviye yukari)"""
    here = os.path.dirname(os.path.abspath(__file__))
    return os.path.join(os.path.dirname(os.path.dirname(os.path.dirname(here))), "mock_data.db")


def _entity_yetki_filtre(g_user):
    """Madde 10-12: Sahsi sadece admin gorur"""
    kullanici_adi = (g_user.get("KullaniciAdi") or "").lower() if g_user else ""
    if kullanici_adi == "admin":
        return ["solariz", "nexgen", "pera", "sahsi"]
    return ["solariz", "nexgen", "pera"]


def _durum_class(kullanim_yuzde, gun_kaldi):
    """Madde 19: normal/yuksek_risk/kritik/gecikmis"""
    if gun_kaldi is not None and gun_kaldi < 0:
        return ("gecikmis", "Gecikti")
    if kullanim_yuzde >= 90:
        return ("kritik", "Kritik")
    if kullanim_yuzde >= 70:
        return ("yuksek_risk", "Yuksek Risk")
    return ("normal", "Normal")


