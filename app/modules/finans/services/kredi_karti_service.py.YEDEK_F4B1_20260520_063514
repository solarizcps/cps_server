def kredi_kartlari_listele(g_user=None):
    """
    Ana liste fonksiyonu.
    1. DB'de gercek kart varsa onu doner (entity yetkisi ile filtreli)
    2. Yoksa demo veri doner (entity yetkisi ile filtreli)
    """
    izinli = _entity_yetki_filtre(g_user)

    c = sqlite3.connect(_db_path())
    c.row_factory = sqlite3.Row

    # Once DB'de gercek kart var mi
    placeholders = ",".join(["?"] * len(izinli))
    db_rows = c.execute(
        f"SELECT * FROM finans_kredi_karti WHERE entity IN ({placeholders}) AND Aktif=1",
        izinli
    ).fetchall()

    if db_rows:
        # Gercek veri var
        kartlar_raw = [dict(r) for r in db_rows]
        veri_kaynak = "DB"
        # Kullanim placeholder (FAZ 3C+ ekstre tablosundan hesaplanir)
        for k in kartlar_raw:
            k["kullanim"] = 0
            k["son_odeme_tarihi"] = None
            k["ekstre_tarihi"] = None
            k["gun_kaldi"] = None
            k["son_4"] = "****"
    else:
        # Demo veri (madde 9, 23)
        kartlar_raw = [k for k in _demo_kartlar() if k["entity"] in izinli]
        veri_kaynak = "DEMO"

    c.close()

    # Durum + yuzde hesaplama
    kartlar = []
    toplam_limit = 0.0
    toplam_kullanim = 0.0
    yaklasan_odeme = 0
    geciken_kart = 0

    for k in kartlar_raw:
        limit_ = k.get("Limit_") or 0
        kullanim = k.get("kullanim") or 0
        gk = k.get("gun_kaldi")

        kullanim_yuzde = (kullanim / limit_ * 100) if limit_ > 0 else 0
        k["kullanim_yuzde"] = min(kullanim_yuzde, 100)

        d_class, d_text = _durum_class(kullanim_yuzde, gk)
        k["durum_class"] = d_class
        k["durum_text"] = d_text

        toplam_limit += limit_
        toplam_kullanim += kullanim

        if gk is not None and 0 <= gk <= 7:
            yaklasan_odeme += 1
        if gk is not None and gk < 0:
            geciken_kart += 1

        kartlar.append(k)

    # KPI
    kpi = {
        "toplam_limit": toplam_limit,
        "toplam_kullanim": toplam_kullanim,
        "kullanim_orani": (toplam_kullanim / toplam_limit * 100) if toplam_limit > 0 else 0,
        "yaklasan_odeme": yaklasan_odeme,
        "geciken_kart": geciken_kart,
    }

    return {
        "kartlar": kartlar,
        "kpi": kpi,
        "izinli_entity": izinli,
        "can_view_sahsi": "sahsi" in izinli,
        "veri_kaynak": veri_kaynak,
    }


def kart_detay(kart_id, g_user=None):
    """Tek kart detayi (modal icin)"""
    izinli = _entity_yetki_filtre(g_user)
    c = sqlite3.connect(_db_path())
    c.row_factory = sqlite3.Row
    r = c.execute(
        "SELECT * FROM finans_kredi_karti WHERE Id = ?", (kart_id,)
    ).fetchone()
    c.close()
    if r:
        d = dict(r)
        if d.get("entity") not in izinli:
            return None
        return d
    # Demo veri detay
    for k in _demo_kartlar():
        if k["Id"] == kart_id and k["entity"] in izinli:
            return k
    return None