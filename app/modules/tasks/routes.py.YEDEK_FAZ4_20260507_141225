# ============================================================
# 3) Liste endpoint - simdilik bos / minimal
# ============================================================
@tasks_bp.route("/api/tasks")
def api_list():
    """
    Tum gorevleri listeler. ISKELET HALI - henuz yetki filtresi YOK,
    parametre YOK, sadece DB'den ham okur.
    Sonraki adimda service.py ile genisletilecek.
    """
    try:
        rows = q("""
            SELECT id, title, task_type, priority, status,
                   created_by, assigned_to, department,
                   due_date, created_at
            FROM tasks
            WHERE status != 'IPTAL'
            ORDER BY created_at DESC
            LIMIT 50
        """)
        return jsonify({"ok": True, "count": len(rows), "tasks": rows})
    except Exception as e:
        return jsonify({"ok": False, "error": str(e)}), 500
