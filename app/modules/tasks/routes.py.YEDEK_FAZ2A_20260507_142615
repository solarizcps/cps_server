@tasks_bp.route("/api/tasks", methods=["GET"])
def api_list():
    user = get_current_task_user()
    if not user:
        return err_json("Oturum acik degil", 401)

    try:
        filters = parse_list_filters(request)

        # limit
        try:
            limit = int(request.args.get("limit", 200))
            limit = max(1, min(limit, 1000))
        except ValueError:
            limit = 200

        # include_iptal flag
        include_iptal = request.args.get("include_iptal", "0") in ("1", "true", "True")

        rows = tsk.list_tasks(limit=limit, include_iptal=include_iptal, **filters)

        # Post-filter: q (basit search title/description)
        qstr = request.args.get("q", "").strip().lower()
        if qstr:
            rows = [r for r in rows if
                    qstr in (r.get("title") or "").lower()
                    or qstr in (r.get("description") or "").lower()]

        # related_order_no / related_emir_no filtreleri
        if request.args.get("related_order_no"):
            v = request.args.get("related_order_no")
            rows = [r for r in rows if r.get("related_order_no") == v]
        if request.args.get("related_emir_no"):
            v = request.args.get("related_emir_no")
            rows = [r for r in rows if r.get("related_emir_no") == v]
        if request.args.get("priority"):
            v = request.args.get("priority")
            rows = [r for r in rows if r.get("priority") == v]

        # Yetki: admin tum listeyi gorur, digerleri sadece can_view_task=True olanlari
        if not perm.is_admin(user):
            rows = [r for r in rows if perm.can_view_task(r, user)]

        return ok_json({
            "count": len(rows),
            "tasks": rows,
            "filters": filters,
            "limit": limit,
        })
    except Exception as e:
        return handle_service_error(e)


