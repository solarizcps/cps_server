@tasks_bp.route("/api/tasks/my", methods=["GET"])
def api_my():
    user = get_current_task_user()
    if not user:
        return err_json("Oturum acik degil", 401)

    try:
        kadi = user.get("KullaniciAdi")
        dep = user.get("departman")

        # 1) Bana atanmis acik gorevler
        assigned = tsk.list_tasks(assigned_to=kadi)
        assigned_open = [r for r in assigned if r["status"] not in ("tamamlandi", "iptal")]

        # 2) Olusturdugum acik gorevler
        created = tsk.list_tasks(created_by=kadi)
        created_open = [r for r in created if r["status"] not in ("tamamlandi", "iptal")]

        # 3) Onaylamam gerekenler
        approve_pending = []
        try:
            approve_pending = q("""
                SELECT * FROM tasks
                WHERE approval_user_id=? AND status='onay_bekliyor'
                ORDER BY created_at DESC LIMIT 200
            """, (kadi,))
        except Exception:
            approve_pending = []

        # 4) Sayim
        open_count = tsk.my_open_count(kadi, dep)

        return ok_json({
            "user": kadi,
            "open_count": open_count,
            "assigned_open": assigned_open,
            "created_open": created_open,
            "approve_pending": approve_pending,
        })
    except Exception as e:
        return handle_service_error(e)


