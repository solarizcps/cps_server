@tasks_bp.route("/api/tasks/<int:task_id>/complete", methods=["POST"])
def api_complete(task_id):
    user = get_current_task_user()
    if not user:
        return err_json("Oturum acik degil", 401)

    try:
        body = request.get_json(silent=True) or {}
        note = body.get("note")

        # Hangi status'a gidecek?
        current = tsk.get_task_or_404(task_id)
        if current.get("requires_approval"):
            new_status = "onay_bekliyor"
        else:
            new_status = "tamamlandi"

        task = tsk.change_task_status(task_id, new_status, user, note=note)
        return ok_json({"task": task, "transition": new_status})
    except Exception as e:
        return handle_service_error(e)


