@tasks_bp.route("/api/tasks/<int:task_id>", methods=["PUT"])
def api_update(task_id):
    user = get_current_task_user()
    if not user:
        return err_json("Oturum acik degil", 401)

    try:
        body = request.get_json(silent=True) or {}

        # Sadece izin verilen alanlari geciriyoruz (whitelist)
        ALLOWED = {"title", "description", "priority", "due_date",
                   "related_order_no", "related_emir_no",
                   "related_model", "related_customer",
                   "approval_user_id", "requires_approval",
                   "requires_response", "assigned_to"}
        fields = {k: v for k, v in body.items() if k in ALLOWED}

        if not fields:
            return err_json("Guncellenecek alan yok", 400)

        task = tsk.update_task(task_id, user, **fields)
        return ok_json({"task": task})
    except Exception as e:
        return handle_service_error(e)


