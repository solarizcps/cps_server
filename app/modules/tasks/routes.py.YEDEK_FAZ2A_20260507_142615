def get_current_task_user():
    """
    Session'dan kullaniciyi al, tasks_users ile zenginlestir.

    Returns:
        dict: {
            "KullaniciAdi", "RolAd", "Birim",                # session'dan
            "departman", "tasks_user_id", "tasks_rol",       # tasks_users'tan
        }
        veya None (oturum acik degilse)
    """
    u = session.get("kullanici")
    if not u:
        return None

    # Kopyala (session'i mutate etme)
    enriched = dict(u)

    # tasks_users'tan zenginlestir (departman + id)
    kadi = u.get("KullaniciAdi")
    if kadi:
        tu = qone(
            "SELECT id, rol, departman FROM tasks_users WHERE kullanici_adi=? AND aktif=1",
            (kadi,)
        )
        if tu:
            enriched["tasks_user_id"] = tu["id"]
            enriched["tasks_rol"] = tu["rol"]
            # Birim/departman: session'da yoksa tasks_users'tan
            if not enriched.get("departman"):
                enriched["departman"] = tu["departman"]

    return enriched


def ok_json(data=None, status=200):
    """Basarili response."""
    return jsonify({"ok": True, "data": data}), status


def err_json(error_msg, status=400):
    """Hata response."""
    return jsonify({"ok": False, "error": str(error_msg)}), status


def handle_service_error(exception):
    """
    service/permissions exception'larini HTTP response'a cevir.
    """
    if isinstance(exception, tsk.TaskNotFound):
        return err_json(str(exception), 404)
    if isinstance(exception, tsk.InvalidTransition):
        return err_json(str(exception), 400)
    if isinstance(exception, tsk.ValidationError):
        return err_json(str(exception), 400)
    if isinstance(exception, perm.PermissionDenied):
        return err_json(str(exception), 403)
    if isinstance(exception, tsk.TaskError):
        return err_json(str(exception), 400)
    # Bilinmeyen hata
    return err_json(f"Sistem hatasi: {type(exception).__name__}: {exception}", 500)


def parse_list_filters(req):
    """request.args -> service.list_tasks() filtre dict'i."""
    filters = {}
    for key in ("status", "department", "assigned_to", "created_by",
                "task_type", "baglam_tipi", "baglam_id"):
        v = req.args.get(key)
        if v:
            filters[key] = v.strip()

    # priority filter (service.list_tasks bunu desteklemiyor, bu yuzden post-filter)
    # related_order_no, related_emir_no, q -> ozel handling

    return filters


def require_user():
    """Session yoksa exception (route handler'lar try'da yakalar)."""
    u = get_current_task_user()
    if not u:
        raise tsk.PermissionError("Oturum acik degil")  # noqa
    return u


