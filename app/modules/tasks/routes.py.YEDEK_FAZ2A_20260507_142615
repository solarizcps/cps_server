@tasks_bp.route("/api/tasks", methods=["POST"])
def api_create():
    user = get_current_task_user()
    if not user:
        return err_json("Oturum acik degil", 401)

    try:
        body = request.get_json(silent=True) or {}

        # Zorunlu alanlar
        title = (body.get("title") or "").strip()
        if not title:
            return err_json("title zorunlu", 400)

        # created_by HER ZAMAN session'dan alinir (client'tan kabul etme)
        created_by = user.get("KullaniciAdi")
        if not created_by:
            return err_json("Oturum bilgisi eksik", 401)

        # department: body'de yoksa session.departman
        department = body.get("department") or user.get("departman") or user.get("Birim")
        if not department:
            return err_json("department zorunlu", 400)

        new_id = tsk.create_task(
            title=title,
            created_by=created_by,
            department=department,
            description=body.get("description"),
            task_type=body.get("task_type", "operasyon_talimati"),
            priority=body.get("priority", "orta"),
            assigned_to=body.get("assigned_to"),
            due_date=body.get("due_date"),
            related_order_no=body.get("related_order_no"),
            related_emir_no=body.get("related_emir_no"),
            related_model=body.get("related_model"),
            related_customer=body.get("related_customer"),
            baglam_tipi=body.get("baglam_tipi"),
            baglam_id=body.get("baglam_id"),
            baglam_ozet=body.get("baglam_ozet"),
            requires_approval=body.get("requires_approval", 0),
            approval_user_id=body.get("approval_user_id"),
            requires_response=body.get("requires_response", 0),
            parent_task_id=body.get("parent_task_id"),
        )

        task = tsk.get_task(new_id)
        return ok_json({"task_id": new_id, "task": task}, status=201)
    except Exception as e:
        return handle_service_error(e)


