@tasks_bp.route("/api/tasks/<int:task_id>", methods=["GET"])
def api_detail(task_id):
    user = get_current_task_user()
    if not user:
        return err_json("Oturum acik degil", 401)

    try:
        task = tsk.get_task_or_404(task_id)

        # Yetki: gorebilir mi?
        if not perm.can_view_task(task, user):
            return err_json("Bu gorevi goruntuleme yetkiniz yok", 403)

        logs = tsk.get_task_logs(task_id)
        files = tsk.get_task_files(task_id)

        return ok_json({
            "task": task,
            "logs": logs,
            "files": files,
            "permissions": {
                "can_edit":     perm.can_edit_task(task, user),
                "can_approve":  perm.can_approve_task(task, user),
                "is_creator":   task.get("created_by") == user.get("KullaniciAdi"),
                "is_assigned":  task.get("assigned_to") == user.get("KullaniciAdi"),
            },
        })
    except Exception as e:
        return handle_service_error(e)


