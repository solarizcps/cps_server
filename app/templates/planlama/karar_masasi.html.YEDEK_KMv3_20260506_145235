{% extends "base.html" %}
{% block title %}Planlama / Karar Masası · Solariz CPS{% endblock %}

{% block head %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/planlama.css') }}?v={{ range(100000, 999999) | random }}">
{% endblock %}

{% block content %}

<div class="pl-toolbar">
  <div class="pl-toolbar-left">
    <h1>📋 Planlama / Karar Masası</h1>
    <p>Operasyon karar masası — öncelik, darboğaz, üretilebilirlik bir arada.</p>
  </div>
  <div class="pl-toolbar-right">
    <span class="pl-veri-kaynak" id="pl-veri-kaynak">MOCK VERİ</span>
  </div>
</div>

<!-- FİLTRE BANDI -->
<div class="pl-filtreler">
  
  <div class="pl-filtre-grup">
    <div class="pl-filtre-baslik">⏰ ZAMAN</div>
    <div class="pl-filtre-secenekler" data-filtre="zaman">
      <button class="pl-flt aktif" data-deger="HEPSI">Hepsi</button>
      <button class="pl-flt" data-deger="BU_HAFTA">Bu hafta</button>
      <button class="pl-flt" data-deger="SONRAKI_HAFTA">Sonraki</button>
      <button class="pl-flt" data-deger="BU_AY">Bu ay</button>
      <button class="pl-flt" data-deger="3_AY">3 ay</button>
      <button class="pl-flt" data-deger="6_AY">6 ay</button>
      <button class="pl-flt" data-deger="1_YIL">1 yıl</button>
    </div>
  </div>

  <div class="pl-filtre-grup">
    <div class="pl-filtre-baslik">👥 MÜŞTERİ</div>
    <div class="pl-filtre-secenekler" data-filtre="musteri">
      <button class="pl-flt aktif" data-deger="HEPSI">Hepsi</button>
      <button class="pl-flt" data-deger="Lc Waikiki">LCW</button>
      <button class="pl-flt" data-deger="Boyner">Boyner</button>
      <button class="pl-flt" data-deger="Koton">Koton</button>
    </div>
  </div>

  <div class="pl-filtre-grup">
    <div class="pl-filtre-baslik">⚡ ÖNCELİK</div>
    <div class="pl-filtre-secenekler" data-filtre="oncelik">
      <button class="pl-flt aktif" data-deger="HEPSI">Hepsi</button>
      <button class="pl-flt" data-deger="ACIL">Acil</button>
      <button class="pl-flt" data-deger="NAKIT">Nakit</button>
      <button class="pl-flt" data-deger="NORMAL">Normal</button>
    </div>
  </div>

  <div class="pl-filtre-grup">
    <div class="pl-filtre-baslik">🏭 ÜRETİLEBİLİRLİK</div>
    <div class="pl-filtre-secenekler" data-filtre="production_ready">
      <button class="pl-flt aktif" data-deger="HEPSI">Hepsi</button>
      <button class="pl-flt" data-deger="HAZIR">🟢 Hazır</button>
      <button class="pl-flt" data-deger="KISMI">🟡 Kısmi</button>
      <button class="pl-flt" data-deger="BLOKE">🔴 Bloke</button>
      <button class="pl-flt" data-deger="BILINMIYOR">⚪ Belirsiz</button>
    </div>
  </div>

</div>

<!-- ÖZET BANDI -->
<div class="pl-ozet-bandi" id="pl-ozet">
  <div class="pl-ozet-item"><span class="pl-ozet-deger" id="pl-ozet-toplam">-</span><span class="pl-ozet-etiket">Toplam</span></div>
  <div class="pl-ozet-item"><span class="pl-ozet-deger pl-yesil" id="pl-ozet-hazir">-</span><span class="pl-ozet-etiket">🟢 Hazır</span></div>
  <div class="pl-ozet-item"><span class="pl-ozet-deger pl-sari" id="pl-ozet-kismi">-</span><span class="pl-ozet-etiket">🟡 Kısmi</span></div>
  <div class="pl-ozet-item"><span class="pl-ozet-deger pl-kirmizi" id="pl-ozet-bloke">-</span><span class="pl-ozet-etiket">🔴 Bloke</span></div>
  <div class="pl-ozet-item"><span class="pl-ozet-deger pl-kirmizi" id="pl-ozet-darbogaz">-</span><span class="pl-ozet-etiket">⚠️ Darboğaz</span></div>
</div>

<!-- KART LİSTESİ -->
<div id="pl-kart-listesi" class="pl-kart-liste">
  <div class="pl-loading">Yükleniyor...</div>
</div>

{% endblock %}

{% block scripts %}
<script src="{{ url_for('static', filename='js/planlama_karar_masasi.js') }}?v={{ range(100000, 999999) | random }}"></script>
{% endblock %}