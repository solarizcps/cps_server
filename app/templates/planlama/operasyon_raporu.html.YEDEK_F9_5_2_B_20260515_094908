{% extends "base.html" %}

{% block title %}Operasyon Raporu - Solariz CPS{% endblock %}

{% block content %}
<div style="padding: 24px; max-width: 1280px; margin: 0 auto;">
  <div style="font-size: 12px; color: #888; margin-bottom: 6px;">
    Planlama / Operasyon Raporu
  </div>
  <h2 style="margin: 0 0 16px; font-size: 22px; font-weight: 500;">
    Operasyon Raporu
  </h2>
  
  <div style="background: #fff8e6; border: 1px solid #f4d690; border-radius: 8px; padding: 20px; margin-top: 20px;">
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
      <span style="font-size: 20px;">[!]</span>
      <strong style="font-size: 16px;">Yapim asamasinda - F9.5.2</strong>
    </div>
    <p style="margin: 8px 0 0; color: #5a4317; font-size: 13px;">
      Backend hesap motoru (F9.5.1) tamamlandi. UI bilesenleri (F9.5.2) yarin hazirlanacak.
    </p>
    <p style="margin: 12px 0 0; color: #5a4317; font-size: 12px;">
      <strong>API endpoint'leri aktif:</strong><br/>
      <code style="font-size: 11px;">GET /planlama/api/operasyon/genel</code><br/>
      <code style="font-size: 11px;">GET /planlama/api/operasyon/makine/&lt;id&gt;</code><br/>
      <code style="font-size: 11px;">GET /planlama/api/operasyon/event-timeline/&lt;rapor_id&gt;</code>
    </p>
  </div>
  
  <div style="margin-top: 24px; padding: 16px; background: #f5f5f3; border-radius: 8px; font-size: 12px; color: #666;">
    <strong>Test:</strong>
    <a href="/planlama/api/operasyon/genel" target="_blank" style="color: #185fa5; margin-left: 8px;">/api/operasyon/genel</a>
    <a href="/planlama/api/operasyon/makine/2" target="_blank" style="color: #185fa5; margin-left: 8px;">/api/operasyon/makine/2</a>
  </div>
</div>
{% endblock %}