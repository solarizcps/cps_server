{% extends "base.html" %}

{% block title %}Operasyon Raporu - Solariz CPS{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/planlama_operasyon.css') }}?v={{ range(100000, 999999) | random }}">

<div class="or-sayfa">

  <!-- ============ UST BASLIK + CANLI BADGE ============ -->
  <div class="or-ust">
    <div class="or-baslik">
      <div class="or-breadcrumb">Planlama / Enjeksiyon</div>
      <h2>Operasyon raporu</h2>
    </div>
    <div class="or-canli-bilgi">
      <span class="or-canli-badge" id="or-canli-badge">
        <span class="or-canli-dot"></span>CANLI
      </span>
      <span class="or-son-guncelleme">Son güncelleme: <span id="or-son-gun">—</span></span>
      <button class="or-btn-yenile" id="or-btn-yenile" title="Yenile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
      </button>
    </div>
  </div>

  <!-- ============ FILTRE BAR ============ -->
  <div class="or-filtre">
    <div class="or-filtre-grup">
      <label>Tarih</label>
      <input type="date" id="or-tarih" class="or-input">
    </div>
    <div class="or-filtre-grup">
      <label>Vardiya</label>
      <select id="or-vardiya" class="or-input">
        <option value="gunduz">Gündüz (07:00–17:00)</option>
        <option value="gece">Gece (17:00–07:00)</option>
      </select>
    </div>
    <button class="or-btn-uygula" id="or-btn-uygula">Yenile</button>
    <div class="or-filtre-spacer"></div>
    <div class="or-vardiya-bilgi" id="or-vardiya-bilgi">
      <span class="or-vardiya-etiket">Vardiya ilerleme</span>
      <span class="or-vardiya-deger"><span id="or-vardiya-dk">—</span> / <span id="or-vardiya-sure">—</span></span>
      <span class="or-vardiya-yuzde" id="or-vardiya-yuzde">—</span>
    </div>
  </div>

  <!-- ============ KPI SERIDI ============ -->
  <div class="or-kpi-serit" id="or-kpi-serit">
    <div class="or-kpi"><div class="or-kpi-label">Toplam tur</div><div class="or-kpi-deger" id="kpi-tur">—</div><div class="or-kpi-alt" id="kpi-tur-alt">—</div></div>
    <div class="or-kpi"><div class="or-kpi-label">Teorik çift</div><div class="or-kpi-deger" id="kpi-teorik">—</div><div class="or-kpi-alt" id="kpi-teorik-alt">—</div></div>
    <div class="or-kpi"><div class="or-kpi-label">Net çift</div><div class="or-kpi-deger" id="kpi-net">—</div><div class="or-kpi-alt" id="kpi-net-alt">—</div></div>
    <div class="or-kpi"><div class="or-kpi-label">Toplam setup</div><div class="or-kpi-deger" id="kpi-setup">—</div><div class="or-kpi-alt" id="kpi-setup-alt">—</div></div>
    <div class="or-kpi"><div class="or-kpi-label">Toplam arıza</div><div class="or-kpi-deger" id="kpi-ariza">—</div><div class="or-kpi-alt" id="kpi-ariza-alt">—</div></div>
    <div class="or-kpi"><div class="or-kpi-label">Verim %</div><div class="or-kpi-deger" id="kpi-verim">—</div><div class="or-kpi-alt" id="kpi-verim-alt">—</div></div>
    <div class="or-kpi"><div class="or-kpi-label">Aktif slot</div><div class="or-kpi-deger" id="kpi-aktif">—</div><div class="or-kpi-alt" id="kpi-aktif-alt">—</div></div>
  </div>

  <!-- ============ MAKINE KARTLARI ============ -->
  <div class="or-makine-grid" id="or-makine-grid">
    <div class="or-yukleniyor">Veriler yükleniyor…</div>
  </div>

  <!-- ============ DETAY PANELI (Accordion) ============ -->
  <div class="or-detay" id="or-detay" style="display:none;">
    <div class="or-detay-baslik">
      <span id="or-detay-makine-ad">—</span>
      <span class="or-detay-durum-badge" id="or-detay-durum">—</span>
      <span class="or-detay-vardiya">Vardiya <span id="or-detay-vardiya-dk">—</span></span>
      <button class="or-btn-detay-kapat" id="or-btn-detay-kapat">Kapat ▼</button>
    </div>
    <div class="or-detay-icerik" id="or-detay-icerik">
      <div class="or-yukleniyor">Detay yükleniyor…</div>
    </div>
  </div>

  <!-- ============ ALT BILGI ============ -->
  <div class="or-alt-bilgi" id="or-alt-bilgi">
    <div class="or-uyari-ozet" id="or-uyari-ozet"></div>
    <div class="or-renk-legend">
      <span class="or-renk-item"><span class="or-renk-kutu r-aktif"></span>Aktif</span>
      <span class="or-renk-item"><span class="or-renk-kutu r-setup"></span>Setup</span>
      <span class="or-renk-item"><span class="or-renk-kutu r-ariza"></span>Arıza</span>
      <span class="or-renk-item"><span class="or-renk-kutu r-kapali"></span>Kapalı</span>
      <span class="or-renk-item"><span class="or-renk-kutu r-hibrit"></span>Hibrit / Uyarı</span>
    </div>
  </div>

</div>

<script src="{{ url_for('static', filename='js/planlama_operasyon.js') }}?v={{ range(100000, 999999) | random }}"></script>
{% endblock %}
