{% extends "base.html" %}
{% block title %}{{ rol.Ad }} - Yetki Matrisi V2{% endblock %}

{% block head %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/rol_detay.css') }}">
<style>
.r-bas { background:#fff; border:0.5px solid var(--border); border-radius:10px; padding:18px 20px; margin-bottom:14px; box-shadow:var(--shadow-sm); }
.r-bas input { width:100%; padding:8px 12px; border:1px solid var(--border); border-radius:6px; font-family:var(--sans); font-size:14px; }
.r-bas label { display:block; font-size:10px; font-weight:700; color:var(--text3); text-transform:uppercase; letter-spacing:1.3px; margin-bottom:4px; }
.r-bas-grid { display:grid; grid-template-columns:280px 1fr; gap:14px; }
.grup { background:#fff; border:0.5px solid var(--border); border-radius:10px; margin-bottom:10px; overflow:hidden; }
.grup-bas {
  background:linear-gradient(90deg, var(--sol-light), transparent);
  padding:10px 16px; display:flex; justify-content:space-between; align-items:center;
  border-bottom:0.5px solid var(--border); font-weight:700; font-size:13px;
}
.grup-bas .mod { color:var(--sol-dark); text-transform:uppercase; letter-spacing:1.5px; font-size:11px; }
.grup-bas .alt { color:var(--text2); margin-left:8px; font-size:12px; font-weight:500; }
.aksiyon-bar {
  position:sticky; bottom:0; background:#fff; padding:14px 20px; border-radius:10px;
  box-shadow:0 -4px 16px rgba(0,0,0,0.08); border:0.5px solid var(--border);
  display:flex; justify-content:space-between; align-items:center; margin-top:16px;
}
.v2-action.v2-tehlike:checked {
  outline: 2px solid #fee2e2;
  outline-offset: 1px;
}
</style>
{% endblock %}

{% block content %}

<div class="page-header">
  <div>
    <div class="page-title">
      {{ rol.Ad }}
      {% if rol.SuperAdmin %}
      <span class="v2-superadmin-badge">SuperAdmin</span>
      {% endif %}
    </div>
    <div class="page-sub">Yetki matrisi V2 - {{ gruplar | length }} modul grubu - 7 boyut</div>
  </div>
  <div style="display:flex; gap:8px;">
    <a class="btn btn-outline" href="/yonetim/rol">&larr; Roller</a>
    {% if not rol.SuperAdmin %}
    <form method="post" action="/yonetim/rol/{{ rol.Id }}/sil" style="display:inline;" onsubmit="return confirm('Bu rolu silmek istediginize emin misiniz?')">
      <button class="btn btn-outline" type="submit" style="color:var(--red);">Rolu Sil</button>
    </form>
    {% endif %}
  </div>
</div>

{% if rol.SuperAdmin %}
<div class="v2-readonly-info">
  <strong>SuperAdmin rolu:</strong> Bu rol tum yetkilere otomatik sahiptir (*). Matris referans icin gosterilir.
</div>
{% endif %}

<form method="post" action="/yonetim/rol/{{ rol.Id }}/kaydet" id="rolForm">

<div class="r-bas">
  <div class="r-bas-grid">
    <div>
      <label>Rol Adi</label>
      <input type="text" name="Ad" value="{{ rol.Ad }}" required>
    </div>
    <div>
      <label>Aciklama</label>
      <input type="text" name="Aciklama" value="{{ rol.Aciklama or '' }}" placeholder="(opsiyonel) rol tarifi">
    </div>
  </div>
</div>

{% for grup_key, grup in gruplar.items() %}
<div class="grup">
  <div class="grup-bas">
    <div>
      <span class="mod">{{ grup.modul }}</span>
      {% if grup.alt_modul %}<span class="alt">{{ grup.alt_modul }}</span>{% endif %}
    </div>
    <div class="v2-grup-eylem-grup">
      <span class="v2-grup-eylem" onclick="v2GrupSet(this, 'view')">Sadece Gor</span>
      <span class="v2-grup-eylem-ayrac">|</span>
      <span class="v2-grup-eylem" onclick="v2GrupSet(this, 'view_report')">Gor+Rap</span>
      <span class="v2-grup-eylem-ayrac">|</span>
      <span class="v2-grup-eylem" onclick="v2GrupSet(this, 'work')">Gor+Olu+Gun+Rap</span>
      <span class="v2-grup-eylem-ayrac">|</span>
      <span class="v2-grup-eylem" onclick="v2GrupSet(this, 'none')">Hicbiri</span>
    </div>
  </div>

  <div class="v2-y-hdr">
    <span>Yetki</span>
    <span class="v2-col-view v2-tooltip" data-tip="Goruntuleme (en gevsek)">Gor</span>
    <span class="v2-col-create v2-tooltip" data-tip="Yeni kayit olusturma">Olu</span>
    <span class="v2-col-update v2-tooltip" data-tip="Mevcut kaydi degistirme">Gun</span>
    <span class="v2-col-delete v2-tooltip" data-tip="DIKKAT: Silme yetkisi">Sil</span>
    <span class="v2-col-approve v2-tooltip" data-tip="Onaylama/karar verme">Ony</span>
    <span class="v2-col-report v2-tooltip" data-tip="Rapor goruntuleme">Rap</span>
    <span class="v2-col-manage v2-tooltip" data-tip="TEHLIKE: Yonetim/sistem ayari">Yon</span>
    <span class="v2-col-eski v2-tooltip" data-tip="Eski 2-boyut yetki (migration takip)">ESKI</span>
  </div>

  {% for y in grup.yetkiler %}
  {% set m = mevcut.get(y.Id, {}) %}
  <div class="v2-y-row" data-yid="{{ y.Id }}">
    <div class="v2-y-info">
      <strong>{{ y.Ad }}</strong>
      <span class="v2-kod">{{ y.Kod }}</span>
    </div>
    <div class="v2-cb v2-cb-view">
      <input type="checkbox" name="v2_can_view_{{ y.Id }}" value="1"
             class="v2-action v2-action-view"
             data-yid="{{ y.Id }}" data-action="can_view"
             {% if m.can_view %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb v2-cb-create">
      <input type="checkbox" name="v2_can_create_{{ y.Id }}" value="1"
             class="v2-action v2-action-create"
             data-yid="{{ y.Id }}" data-action="can_create"
             {% if m.can_create %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb v2-cb-update">
      <input type="checkbox" name="v2_can_update_{{ y.Id }}" value="1"
             class="v2-action v2-action-update"
             data-yid="{{ y.Id }}" data-action="can_update"
             {% if m.can_update %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb v2-cb-delete">
      <input type="checkbox" name="v2_can_delete_{{ y.Id }}" value="1"
             class="v2-action v2-action-delete v2-tehlike"
             data-yid="{{ y.Id }}" data-action="can_delete"
             {% if m.can_delete %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb v2-cb-approve">
      <input type="checkbox" name="v2_can_approve_{{ y.Id }}" value="1"
             class="v2-action v2-action-approve"
             data-yid="{{ y.Id }}" data-action="can_approve"
             {% if m.can_approve %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb v2-cb-report">
      <input type="checkbox" name="v2_can_report_{{ y.Id }}" value="1"
             class="v2-action v2-action-report"
             data-yid="{{ y.Id }}" data-action="can_report"
             {% if m.can_report %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb v2-cb-manage">
      <input type="checkbox" name="v2_can_manage_{{ y.Id }}" value="1"
             class="v2-action v2-action-manage v2-tehlike"
             data-yid="{{ y.Id }}" data-action="can_manage"
             {% if m.can_manage %}checked{% endif %}
             onchange="v2ChangeAction(this)">
    </div>
    <div class="v2-cb">
      {% set eski_g = m.Gorebilir %}
      {% set eski_d = m.Duzenleyebilir %}
      {% if eski_g and eski_d %}
        <span class="v2-eski-badge v2-eski-GD">GD</span>
      {% elif eski_g %}
        <span class="v2-eski-badge v2-eski-G">G</span>
      {% elif eski_d %}
        <span class="v2-eski-badge v2-eski-D">D</span>
      {% else %}
        <span class="v2-eski-badge v2-eski-bos">-</span>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>
{% endfor %}

<div class="aksiyon-bar">
  <div class="v2-istat">
    <div class="v2-istat-item" id="v2-stat-view"><span class="v2-istat-deger" id="cnt_view">0</span> Gor</div>
    <div class="v2-istat-item" id="v2-stat-create"><span class="v2-istat-deger" id="cnt_create">0</span> Olu</div>
    <div class="v2-istat-item" id="v2-stat-update"><span class="v2-istat-deger" id="cnt_update">0</span> Gun</div>
    <div class="v2-istat-item tehlike" id="v2-stat-delete"><span class="v2-istat-deger" id="cnt_delete">0</span> Sil</div>
    <div class="v2-istat-item" id="v2-stat-approve"><span class="v2-istat-deger" id="cnt_approve">0</span> Ony</div>
    <div class="v2-istat-item" id="v2-stat-report"><span class="v2-istat-deger" id="cnt_report">0</span> Rap</div>
    <div class="v2-istat-item tehlike" id="v2-stat-manage"><span class="v2-istat-deger" id="cnt_manage">0</span> Yon</div>
  </div>
  <div style="display:flex; gap:8px;">
    <button type="button" class="btn btn-outline" onclick="location.reload()">Iptal</button>
    <button type="submit" class="btn btn-primary" id="v2SaveBtn">Kaydet</button>
  </div>
</div>

</form>

<script>
var v2InChange = false;

function v2ChangeAction(cb) {
  if (v2InChange) return;
  v2InChange = true;

  try {
    var action = cb.dataset.action;
    var yid = cb.dataset.yid;

    if (cb.checked && (action === 'can_delete' || action === 'can_manage')) {
      var actionAd = action === 'can_delete' ? 'SILME' : 'YONETIM';
      if (!confirm('DIKKAT: ' + actionAd + ' yetkisi acmak istediginize emin misiniz?')) {
        cb.checked = false;
      }
    }

    if (cb.checked && (action === 'can_create' || action === 'can_update' || action === 'can_report')) {
      var row = cb.closest('.v2-y-row');
      var viewCb = row.querySelector('.v2-action-view');
      if (viewCb && !viewCb.checked) viewCb.checked = true;
    }

    if (!cb.checked && action === 'can_view') {
      var row = cb.closest('.v2-y-row');
      row.querySelectorAll('.v2-action').forEach(function(c) {
        if (c !== cb) c.checked = false;
      });
    }
  } finally {
    v2InChange = false;
    v2GuncelleIstat();
  }
}

function v2GrupSet(elem, preset) {
  var grup = elem.closest('.grup');
  var actions = ['view', 'create', 'update', 'delete', 'approve', 'report', 'manage'];
  var aktifSet = [];
  if (preset === 'view') aktifSet = ['view'];
  else if (preset === 'view_report') aktifSet = ['view', 'report'];
  else if (preset === 'work') aktifSet = ['view', 'create', 'update', 'report'];

  actions.forEach(function(a) {
    grup.querySelectorAll('.v2-action-' + a).forEach(function(cb) {
      cb.checked = aktifSet.indexOf(a) !== -1;
    });
  });
  v2GuncelleIstat();
}

function v2GuncelleIstat() {
  ['view', 'create', 'update', 'delete', 'approve', 'report', 'manage'].forEach(function(a) {
    var cnt = document.querySelectorAll('.v2-action-' + a + ':checked').length;
    var elem = document.getElementById('cnt_' + a);
    if (elem) elem.innerText = cnt;
    var stat = document.getElementById('v2-stat-' + a);
    if (stat) {
      if (cnt > 0 && a !== 'delete' && a !== 'manage') stat.classList.add('aktif');
      else if (a !== 'delete' && a !== 'manage') stat.classList.remove('aktif');
    }
  });
}

document.getElementById('rolForm').addEventListener('submit', function() {
  var btn = document.getElementById('v2SaveBtn');
  btn.disabled = true;
  btn.innerText = 'Kaydediliyor...';
});

document.addEventListener('DOMContentLoaded', v2GuncelleIstat);
</script>

{% endblock %}
