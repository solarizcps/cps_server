{% extends "base.html" %}

{% block title %}Finans Takvim - Konsol{% endblock %}

{% set active = 'finans' %}

{% block content %}
<div class="fk-wrap">

  <div class="page-header fk-header">
    <div class="page-header-baslik">
      <h1 class="page-title">
        <span class="fk-icon">TK</span>
        Finans Takvim
      </h1>
      <div class="page-subtitle">
        Cari odemeler + Kredi karti ekstreler + Manuel odemeler birlesik takvim - FAZ 3D
      </div>
    </div>
    <div class="fk-konsol-back">
      <a href="/finans/konsol" class="fk-back-btn">&larr; Konsola Don</a>
    </div>
  </div>

  <!-- KPI 4 KART -->
  <div class="fk-kpi-bar">
    <div class="fk-kpi-card fk-kpi-bugun">
      <div class="fk-kpi-label">Bugun</div>
      <div class="fk-kpi-deger">{{ kpi.bugun_sayi or 0 }}</div>
      <div class="fk-kpi-sub">{{ '{:,.0f}'.format(kpi.bugun_tutar or 0) }} TL</div>
    </div>
    <div class="fk-kpi-card fk-kpi-hafta">
      <div class="fk-kpi-label">Bu Hafta</div>
      <div class="fk-kpi-deger">{{ kpi.hafta_sayi or 0 }}</div>
      <div class="fk-kpi-sub">{{ '{:,.0f}'.format(kpi.hafta_tutar or 0) }} TL</div>
    </div>
    <div class="fk-kpi-card fk-kpi-gecikti">
      <div class="fk-kpi-label">Gecikti</div>
      <div class="fk-kpi-deger">{{ kpi.gecikti_sayi or 0 }}</div>
      <div class="fk-kpi-sub">{{ '{:,.0f}'.format(kpi.gecikti_tutar or 0) }} TL</div>
    </div>
    <div class="fk-kpi-card fk-kpi-bekleyen">
      <div class="fk-kpi-label">Toplam Bekleyen</div>
      <div class="fk-kpi-deger">{{ kpi.bekleyen_sayi or 0 }}</div>
      <div class="fk-kpi-sub">{{ '{:,.0f}'.format(kpi.bekleyen_tutar or 0) }} TL</div>
    </div>
  </div>

  <!-- FILTRELER -->
  <div class="fk-filter-bar">
    <div class="fk-filter-grup">
      <label class="fk-filter-label">Firma:</label>
      <select id="fk-flt-entity" class="fk-filter-input">
        <option value="">Hepsi</option>
        <option value="solariz">Solariz</option>
        <option value="nexgen">NexGen</option>
        <option value="pera">Pera</option>
        {% if can_view_sahsi %}
        <option value="sahsi">Sahsi</option>
        {% endif %}
      </select>
    </div>

    <div class="fk-filter-grup">
      <label class="fk-filter-label">Kaynak:</label>
      <select id="fk-flt-kaynak" class="fk-filter-input">
        <option value="">Hepsi</option>
        <option value="CARI">Cari</option>
        <option value="KART">Kredi Karti</option>
        <option value="MANUEL">Manuel</option>
        <option value="KREDI">Kredi</option>
      </select>
    </div>

    <div class="fk-filter-grup">
      <label class="fk-filter-label">Durum:</label>
      <select id="fk-flt-durum" class="fk-filter-input">
        <option value="">Hepsi</option>
        <option value="BEKLIYOR">Bekliyor</option>
        <option value="GECIKTI">Gecikti</option>
        <option value="ODENDI">Odendi</option>
        <option value="PLANLANDI">Planlandi</option>
      </select>
    </div>

    <div class="fk-filter-grup">
      <label class="fk-filter-label">Gorunum:</label>
      <select id="fk-flt-view" class="fk-filter-input" onchange="fkViewSwitch(this.value)">
        <option value="aylik">Aylik Liste</option>
        <option value="haftalik">Haftalik Ozet</option>
        <option value="bugun">Bugun/Yaklasan</option>
      </select>
    </div>

    <div class="fk-filter-grup">
      <button id="fk-btn-temizle" class="fk-btn-secondary" onclick="fkTemizle()">Temizle</button>
    </div>
  </div>

  <!-- AYLIK LISTE (default) -->
  <div id="fk-view-aylik" class="fk-view-panel">

    {% if not gunler %}
    <div class="fk-empty">
      <div class="fk-empty-icon">--</div>
      <h3 class="fk-empty-h3">Takvimde kayit yok</h3>
      <p>Su an gosterilen veri DEMO mock - manuel odeme/kart ekstre veya cari odeme durum eklendiginde canli olacak.</p>
    </div>
    {% else %}

    {% for gun in gunler %}
    <div class="fk-day-block fk-day-{{ gun.day_class }}" data-tarih="{{ gun.tarih }}">
      <div class="fk-day-header">
        <div class="fk-day-tarih">
          <span class="fk-day-num">{{ gun.gun_num }}</span>
          <div>
            <div class="fk-day-name">{{ gun.gun_adi }}</div>
            <div class="fk-day-tarih-full">{{ gun.tarih }}</div>
          </div>
        </div>
        <div class="fk-day-summary">
          {% if gun.tag %}<span class="fk-tag fk-tag-{{ gun.tag_class }}">{{ gun.tag }}</span>{% endif %}
          <span class="fk-day-toplam">{{ '{:,.0f}'.format(gun.toplam_tutar) }} TL</span>
          <span class="fk-day-sayi">{{ gun.kayit_sayi }} odeme</span>
        </div>
      </div>
      <div class="fk-day-items">
        {% for it in gun.kayitlar %}
        <div class="fk-item fk-item-{{ it.durum_class }}" data-kaynak="{{ it.kaynak }}" data-durum="{{ it.durum }}" data-entity="{{ it.entity }}">
          <div class="fk-item-left">
            <span class="fk-item-kaynak fk-kaynak-{{ it.kaynak|lower }}">{{ it.kaynak }}</span>
            <span class="fk-item-entity">{{ it.entity }}</span>
          </div>
          <div class="fk-item-baslik">
            <strong>{{ it.baslik }}</strong>
            {% if it.alt_baslik %}<span class="fk-item-alt">{{ it.alt_baslik }}</span>{% endif %}
          </div>
          <div class="fk-item-right">
            <span class="fk-item-tutar">{{ '{:,.2f}'.format(it.tutar) }} {{ it.para_birimi }}</span>
            <span class="fk-durum fk-durum-{{ it.durum_class }}">{{ it.durum }}</span>
            {% if it.risk %}<span class="fk-risk fk-risk-{{ it.risk_class }}">{{ it.risk }}</span>{% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}

    {% endif %}
  </div>

  <!-- HAFTALIK OZET (gizli, switch ile gosterilir) -->
  <div id="fk-view-haftalik" class="fk-view-panel" style="display:none;">
    <div class="fk-week-grid">
      {% for hafta in haftalar %}
      <div class="fk-week-cell fk-week-{{ hafta.week_class }}">
        <div class="fk-week-label">{{ hafta.label }}</div>
        <div class="fk-week-sayi">{{ hafta.kayit_sayi }} odeme</div>
        <div class="fk-week-tutar">{{ '{:,.0f}'.format(hafta.toplam_tutar) }} TL</div>
        <div class="fk-week-detay">
          {% if hafta.gecikti_sayi %}<span class="fk-mini-bad">{{ hafta.gecikti_sayi }} gecikti</span>{% endif %}
          {% if hafta.bugun_sayi %}<span class="fk-mini-warn">{{ hafta.bugun_sayi }} bugun</span>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- BUGUN/YAKLASAN (gizli) -->
  <div id="fk-view-bugun" class="fk-view-panel" style="display:none;">
    <div class="fk-bugun-list">
      {% if bugun_yaklasan %}
      {% for it in bugun_yaklasan %}
      <div class="fk-bugun-item fk-bugun-{{ it.durum_class }}">
        <div class="fk-bugun-left">
          <div class="fk-bugun-tarih">{{ it.tarih }}</div>
          <div class="fk-bugun-gun-kala">{% if it.gun_kala == 0 %}BUGUN{% elif it.gun_kala < 0 %}{{ it.gun_kala|abs }} gun gecti{% else %}{{ it.gun_kala }} gun kaldi{% endif %}</div>
        </div>
        <div class="fk-bugun-content">
          <strong>{{ it.baslik }}</strong>
          <div class="fk-bugun-meta">
            <span class="fk-item-kaynak fk-kaynak-{{ it.kaynak|lower }}">{{ it.kaynak }}</span>
            <span>{{ it.entity }}</span>
          </div>
        </div>
        <div class="fk-bugun-right">
          <div class="fk-bugun-tutar">{{ '{:,.2f}'.format(it.tutar) }} {{ it.para_birimi }}</div>
          <span class="fk-durum fk-durum-{{ it.durum_class }}">{{ it.durum }}</span>
        </div>
      </div>
      {% endfor %}
      {% else %}
      <div class="fk-empty">
        <p>Bugun veya yaklasan 14 gun icinde odeme yok.</p>
      </div>
      {% endif %}
    </div>
  </div>

  <!-- INFO BAR -->
  <div class="fk-info-bar">
    <span class="fk-info-icon">i</span>
    {% if veri_kaynak == 'DEMO' %}
      <span><strong>DEMO veri</strong> gosteriliyor - gercek odemeler eklendiginde otomatik canli olacak.</span>
    {% else %}
      <span>Canli veri - {{ kayit_sayi }} kayit.</span>
    {% endif %}
  </div>

</div>

<style>
/* === FAZ 3D - Finans Takvim - scoped fk- prefix === */
.fk-wrap { padding:0; }
.fk-header { display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:12px; }
.fk-icon { display:inline-block; background:#d4a52f; color:#1a1d2e; font-weight:700; font-size:13px; padding:4px 8px; border-radius:4px; margin-right:8px; }
.fk-back-btn {
  display:inline-block; padding:6px 12px; background:transparent;
  color:#6b7280; border:1px solid #e8eaf0; border-radius:4px;
  font-size:12px; font-weight:600; text-decoration:none;
}
.fk-back-btn:hover { background:#fef9c3; color:#1a1d2e; border-color:#d4a52f; }

.fk-kpi-bar { display:grid; grid-template-columns:repeat(4, 1fr); gap:12px; margin-top:16px; }
@media (max-width:760px) { .fk-kpi-bar { grid-template-columns:repeat(2, 1fr); } }
.fk-kpi-card {
  background:#fff; border:1px solid #e8eaf0; border-radius:6px;
  padding:12px 14px; border-left:4px solid #d4a52f;
}
.fk-kpi-bugun     { border-left-color:#d4a52f; }
.fk-kpi-hafta     { border-left-color:#2563eb; }
.fk-kpi-gecikti   { border-left-color:#dc2626; }
.fk-kpi-bekleyen  { border-left-color:#6b7280; }
.fk-kpi-label { font-size:11px; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
.fk-kpi-deger { font-size:24px; font-weight:700; color:#1a1d2e; margin-top:4px; }
.fk-kpi-sub { font-size:11px; color:#9ca3af; margin-top:2px; }

.fk-filter-bar {
  display:grid; grid-template-columns:repeat(auto-fit, minmax(150px, 1fr));
  gap:10px; padding:14px; background:#f8f9fc;
  border:1px solid #e8eaf0; border-radius:6px; margin-top:14px;
}
.fk-filter-grup { display:flex; flex-direction:column; gap:4px; justify-content:flex-end; }
.fk-filter-label { font-size:11px; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
.fk-filter-input {
  padding:7px 10px; border:1px solid #e8eaf0; border-radius:4px;
  background:#fff; font-size:13px; color:#1a1d2e;
}
.fk-filter-input:focus { border-color:#d4a52f; outline:none; box-shadow:0 0 0 2px rgba(212,165,47,0.2); }
.fk-btn-secondary {
  padding:7px 16px; background:transparent; color:#6b7280;
  border:1px solid #e8eaf0; border-radius:4px;
  font-weight:600; font-size:12px; cursor:pointer;
}
.fk-btn-secondary:hover { background:#f8f9fc; }

.fk-view-panel { margin-top:16px; }

/* GUN BLOCK */
.fk-day-block {
  background:#fff; border:1px solid #e8eaf0; border-radius:6px;
  margin-bottom:12px; overflow:hidden;
}
.fk-day-bugun { border-left:4px solid #d4a52f; }
.fk-day-gecikti { border-left:4px solid #dc2626; }
.fk-day-yaklasan { border-left:4px solid #2563eb; }
.fk-day-normal { border-left:4px solid #e8eaf0; }
.fk-day-odendi { border-left:4px solid #16a34a; }

.fk-day-header {
  display:flex; justify-content:space-between; align-items:center;
  padding:10px 14px; background:#f8f9fc; border-bottom:1px solid #e8eaf0;
}
.fk-day-tarih { display:flex; align-items:center; gap:10px; }
.fk-day-num {
  display:inline-flex; align-items:center; justify-content:center;
  width:38px; height:38px; background:#1a1d2e; color:#d4a52f;
  font-weight:700; font-size:18px; border-radius:6px;
}
.fk-day-name { font-size:13px; font-weight:700; color:#1a1d2e; }
.fk-day-tarih-full { font-size:11px; color:#6b7280; }
.fk-day-summary { display:flex; align-items:center; gap:10px; }
.fk-day-toplam { font-weight:700; color:#1a1d2e; font-size:13px; font-variant-numeric:tabular-nums; }
.fk-day-sayi { font-size:11px; color:#6b7280; }
.fk-tag {
  font-size:10px; font-weight:700; padding:2px 8px; border-radius:3px;
  text-transform:uppercase; letter-spacing:0.5px;
}
.fk-tag-bugun    { background:#fef3c7; color:#92400e; }
.fk-tag-yaklasan { background:#dbeafe; color:#1e40af; }
.fk-tag-gecikti  { background:#fee2e2; color:#991b1b; }

.fk-day-items { padding:6px 14px; }
.fk-item {
  display:grid; grid-template-columns:140px 1fr 200px;
  gap:12px; padding:8px 0; border-bottom:1px dashed #f1f3f6;
  align-items:center; transition:background 0.15s;
}
.fk-item:last-child { border-bottom:none; }
.fk-item:hover { background:#fef9c3; }
.fk-item-left { display:flex; align-items:center; gap:6px; }
.fk-item-kaynak {
  display:inline-block; padding:2px 8px; border-radius:3px;
  font-size:10px; font-weight:700; letter-spacing:0.5px;
}
.fk-kaynak-cari   { background:#e0e7ff; color:#4338ca; }
.fk-kaynak-kart   { background:#fce7f3; color:#9d174d; }
.fk-kaynak-manuel { background:#dcfce7; color:#166534; }
.fk-kaynak-kredi  { background:#fef3c7; color:#854d0e; }
.fk-item-entity { font-size:11px; color:#6b7280; text-transform:uppercase; }
.fk-item-baslik strong { font-size:13px; color:#1a1d2e; font-weight:600; }
.fk-item-alt { font-size:11px; color:#9ca3af; margin-left:6px; }
.fk-item-right { display:flex; align-items:center; gap:6px; justify-content:flex-end; flex-wrap:wrap; }
.fk-item-tutar { font-weight:700; color:#1a1d2e; font-size:13px; font-variant-numeric:tabular-nums; }

.fk-durum {
  display:inline-block; padding:2px 8px; border-radius:3px;
  font-size:10px; font-weight:700; letter-spacing:0.5px;
}
.fk-durum-gecikti  { background:#fee2e2; color:#dc2626; }
.fk-durum-bugun    { background:#fef3c7; color:#92400e; }
.fk-durum-yaklasan { background:#dbeafe; color:#2563eb; }
.fk-durum-odendi   { background:#dcfce7; color:#16a34a; }
.fk-durum-bekliyor { background:#f3f4f6; color:#6b7280; }
.fk-durum-planlandi { background:#e0e7ff; color:#4338ca; }
.fk-durum-normal   { background:#f3f4f6; color:#6b7280; }

.fk-risk {
  display:inline-block; padding:2px 6px; border-radius:3px;
  font-size:9px; font-weight:700; letter-spacing:0.5px;
}
.fk-risk-yuksek { background:#fee2e2; color:#dc2626; }
.fk-risk-orta   { background:#fef3c7; color:#92400e; }
.fk-risk-dusuk  { background:#dcfce7; color:#166534; }

/* HAFTALIK GRID */
.fk-week-grid {
  display:grid; grid-template-columns:repeat(4, 1fr);
  gap:12px;
}
@media (max-width:760px) { .fk-week-grid { grid-template-columns:repeat(2, 1fr); } }
.fk-week-cell {
  background:#fff; border:1px solid #e8eaf0; border-left:4px solid #d4a52f;
  border-radius:6px; padding:14px;
}
.fk-week-gecikti  { border-left-color:#dc2626; }
.fk-week-bugun    { border-left-color:#d4a52f; }
.fk-week-yaklasan { border-left-color:#2563eb; }
.fk-week-normal   { border-left-color:#e8eaf0; }
.fk-week-label { font-size:11px; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
.fk-week-sayi { font-size:18px; font-weight:700; color:#1a1d2e; margin-top:4px; }
.fk-week-tutar { font-size:14px; color:#1a1d2e; font-variant-numeric:tabular-nums; margin-top:2px; }
.fk-week-detay { margin-top:6px; display:flex; gap:6px; }
.fk-mini-bad  { background:#fee2e2; color:#dc2626; font-size:10px; padding:1px 6px; border-radius:3px; font-weight:700; }
.fk-mini-warn { background:#fef3c7; color:#92400e; font-size:10px; padding:1px 6px; border-radius:3px; font-weight:700; }

/* BUGUN/YAKLASAN LISTE */
.fk-bugun-list { display:flex; flex-direction:column; gap:8px; }
.fk-bugun-item {
  display:grid; grid-template-columns:140px 1fr 180px;
  gap:14px; align-items:center;
  background:#fff; border:1px solid #e8eaf0; border-left:4px solid #d4a52f;
  border-radius:6px; padding:12px 14px;
}
.fk-bugun-gecikti  { border-left-color:#dc2626; }
.fk-bugun-bugun    { border-left-color:#d4a52f; }
.fk-bugun-yaklasan { border-left-color:#2563eb; }
.fk-bugun-tarih { font-weight:700; color:#1a1d2e; font-size:14px; }
.fk-bugun-gun-kala { font-size:11px; color:#6b7280; font-weight:600; text-transform:uppercase; margin-top:2px; }
.fk-bugun-content strong { font-size:13px; color:#1a1d2e; }
.fk-bugun-meta { display:flex; gap:6px; margin-top:4px; font-size:11px; color:#6b7280; align-items:center; }
.fk-bugun-right { text-align:right; }
.fk-bugun-tutar { font-weight:700; color:#1a1d2e; font-size:14px; font-variant-numeric:tabular-nums; }

/* INFO + EMPTY */
.fk-info-bar {
  margin-top:14px; padding:8px 12px; background:#eff6ff; border:1px solid #bfdbfe;
  border-radius:4px; font-size:12px; color:#1e40af; display:flex; align-items:center; gap:8px;
}
.fk-info-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:18px; height:18px; background:#1e40af; color:#fff;
  border-radius:50%; font-size:11px; font-weight:700;
}
.fk-empty { text-align:center; padding:48px 16px; }
.fk-empty-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:48px; height:48px; background:#fef9c3; border:2px solid #d4a52f;
  border-radius:50%; font-weight:700; font-size:18px; color:#d4a52f; margin-bottom:12px;
}
.fk-empty-h3 { font-size:16px; font-weight:700; color:#1a1d2e; margin-bottom:6px; }
.fk-empty p { color:#6b7280; font-size:13px; }
</style>

<script>
(function(){
  window.fkViewSwitch = function(val) {
    document.getElementById('fk-view-aylik').style.display = (val === 'aylik' ? '' : 'none');
    document.getElementById('fk-view-haftalik').style.display = (val === 'haftalik' ? '' : 'none');
    document.getElementById('fk-view-bugun').style.display = (val === 'bugun' ? '' : 'none');
  };

  function fkFiltreUygula() {
    var entity = document.getElementById('fk-flt-entity').value;
    var kaynak = document.getElementById('fk-flt-kaynak').value;
    var durum  = document.getElementById('fk-flt-durum').value;

    document.querySelectorAll('.fk-item').forEach(function(it){
      var iEntity = it.getAttribute('data-entity');
      var iKaynak = it.getAttribute('data-kaynak');
      var iDurum  = it.getAttribute('data-durum');

      var ok = true;
      if (entity && iEntity !== entity) ok = false;
      if (kaynak && iKaynak !== kaynak) ok = false;
      if (durum  && iDurum  !== durum ) ok = false;

      it.style.display = ok ? '' : 'none';
    });

    // Gun bloklarini gizle: tum item gizli ise
    document.querySelectorAll('.fk-day-block').forEach(function(blk){
      var visible = blk.querySelectorAll('.fk-item:not([style*="display: none"])').length;
      blk.style.display = visible > 0 ? '' : 'none';
    });
  }

  window.fkTemizle = function() {
    document.getElementById('fk-flt-entity').value = '';
    document.getElementById('fk-flt-kaynak').value = '';
    document.getElementById('fk-flt-durum').value = '';
    fkFiltreUygula();
  };

  document.querySelectorAll('.fk-filter-input').forEach(function(s){
    if (s.id === 'fk-flt-view') return;
    s.addEventListener('change', fkFiltreUygula);
  });
})();
</script>
{% endblock %}