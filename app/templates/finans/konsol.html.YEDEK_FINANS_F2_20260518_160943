{% extends "base.html" %}

{% block title %}Finans Konsolu - Solariz CPS{% endblock %}

{% set active = 'finans' %}

{% block content %}
<div class="fk-konsol-wrap">

  <div class="page-header">
    <div class="page-header-baslik">
      <h1 class="page-title">
        <span class="fk-konsol-icon">FK</span>
        Finans Konsolu
      </h1>
      <div class="page-subtitle">Native CPS Finans Yonetim Modulu</div>
    </div>
  </div>

  <div class="fk-konsol-grid">

    <div class="card fk-konsol-info-card">
      <div class="card-body">
        <div class="fk-konsol-badge">FAZ 1 - PLACEHOLDER</div>
        <h2 class="fk-konsol-h2">Yapim Asamasinda</h2>
        <p class="fk-konsol-aciklama">
          Kredi Karti, Cari Odemeler, Takvim ve Korgun entegrasyonu
          sonraki fazlarda eklenecek.
        </p>

        <div class="fk-konsol-roadmap">
          <div class="fk-konsol-faz fk-konsol-faz-active">
            <span class="fk-konsol-faz-no">FAZ 1</span>
            <span class="fk-konsol-faz-ad">Yetki + Sidebar + Placeholder</span>
            <span class="fk-konsol-faz-durum">AKTIF</span>
          </div>
          <div class="fk-konsol-faz">
            <span class="fk-konsol-faz-no">FAZ 2</span>
            <span class="fk-konsol-faz-ad">DB Sema + CRUD altyapi</span>
            <span class="fk-konsol-faz-durum">Bekliyor</span>
          </div>
          <div class="fk-konsol-faz">
            <span class="fk-konsol-faz-no">FAZ 3</span>
            <span class="fk-konsol-faz-ad">Kredi Karti Modulu</span>
            <span class="fk-konsol-faz-durum">Bekliyor</span>
          </div>
          <div class="fk-konsol-faz">
            <span class="fk-konsol-faz-no">FAZ 4</span>
            <span class="fk-konsol-faz-ad">Cari Odemeler</span>
            <span class="fk-konsol-faz-durum">Bekliyor</span>
          </div>
          <div class="fk-konsol-faz">
            <span class="fk-konsol-faz-no">FAZ 5</span>
            <span class="fk-konsol-faz-ad">Takvim + Nakit Akisi</span>
            <span class="fk-konsol-faz-durum">Bekliyor</span>
          </div>
          <div class="fk-konsol-faz">
            <span class="fk-konsol-faz-no">FAZ 6</span>
            <span class="fk-konsol-faz-ad">Korgun Entegrasyonu</span>
            <span class="fk-konsol-faz-durum">Bekliyor</span>
          </div>
          <div class="fk-konsol-faz">
            <span class="fk-konsol-faz-no">FAZ 7</span>
            <span class="fk-konsol-faz-ad">5058 Kapatma + Arsivleme</span>
            <span class="fk-konsol-faz-durum">Bekliyor</span>
          </div>
        </div>
      </div>
    </div>

    <div class="card fk-konsol-info-card">
      <div class="card-body">
        <h3 class="fk-konsol-h3">Mevcut Finans Modulleri</h3>
        <ul class="fk-konsol-modul-list">
          <li><a href="/finans/">Finans Paneli</a></li>
          <li><a href="/finans/anlasma">Anlasmalar</a></li>
          <li><a href="/finans/simulator">Maliyet Simulatoru</a></li>
          <li><a href="/finans/cin-ofis">Cin Ofis Ice Aktarma</a></li>
          <li><a href="/finans/cari?tip=1">Cari (Tedarikci)</a></li>
          <li><a href="/finans/cari?tip=2">Cari (Musteri)</a></li>
        </ul>
        <p class="fk-konsol-not">
          <em>Eski 5058 finans sistemi sadece referans amacli paraleldedir.
          Bu modul tamamlandiginda kapatilacaktir.</em>
        </p>
      </div>
    </div>

  </div>
</div>

<style>
.fk-konsol-wrap { padding: 0; }
.fk-konsol-icon { font-size: 22px; margin-right: 6px; font-weight:700; color:#d4a52f; }
.fk-konsol-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 16px;
  margin-top: 16px;
}
@media (max-width: 980px) {
  .fk-konsol-grid { grid-template-columns: 1fr; }
}
.fk-konsol-info-card { border-left: 4px solid #d4a52f; }
.fk-konsol-badge {
  display: inline-block;
  background: #d4a52f;
  color: #1a1d2e;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 1px;
  padding: 4px 10px;
  border-radius: 4px;
  margin-bottom: 12px;
}
.fk-konsol-h2 { font-size: 22px; font-weight: 700; color: #1a1d2e; margin-bottom: 8px; }
.fk-konsol-h3 { font-size: 16px; font-weight: 700; color: #1a1d2e; margin-bottom: 12px; }
.fk-konsol-aciklama { color: #6b7280; margin-bottom: 20px; line-height: 1.6; }
.fk-konsol-roadmap { display: flex; flex-direction: column; gap: 6px; margin-top: 16px; }
.fk-konsol-faz {
  display: grid;
  grid-template-columns: 70px 1fr 110px;
  gap: 10px;
  padding: 10px 14px;
  background: #f8f9fc;
  border: 1px solid #e8eaf0;
  border-radius: 6px;
  font-size: 13px;
  align-items: center;
}
.fk-konsol-faz-active {
  background: #fef9c3;
  border-color: #d4a52f;
  border-left: 4px solid #d4a52f;
}
.fk-konsol-faz-no { font-weight: 700; color: #6b7280; font-size: 12px; }
.fk-konsol-faz-active .fk-konsol-faz-no { color: #1a1d2e; }
.fk-konsol-faz-ad { color: #1a1d2e; }
.fk-konsol-faz-durum {
  text-align: right;
  font-size: 11px;
  font-weight: 600;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.fk-konsol-faz-active .fk-konsol-faz-durum { color: #d4a52f; }
.fk-konsol-modul-list { list-style: none; padding: 0; margin: 0 0 16px 0; }
.fk-konsol-modul-list li { padding: 8px 0; border-bottom: 1px solid #e8eaf0; }
.fk-konsol-modul-list li:last-child { border-bottom: none; }
.fk-konsol-modul-list a { color: #1a1d2e; text-decoration: none; font-size: 13px; }
.fk-konsol-modul-list a:hover { color: #d4a52f; }
.fk-konsol-not {
  font-size: 11px;
  color: #9ca3af;
  margin-top: 12px;
  padding: 10px;
  background: #f8f9fc;
  border-radius: 4px;
  border-left: 3px solid #9ca3af;
}
</style>
{% endblock %}