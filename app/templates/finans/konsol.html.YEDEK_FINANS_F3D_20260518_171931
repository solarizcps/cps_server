{% extends "base.html" %}

{% block title %}Finans Konsolu - Solariz CPS{% endblock %}

{% set active = 'finans' %}

{% block content %}
<div class="fk-wrap">

  <div class="page-header fk-header">
    <div class="page-header-baslik">
      <h1 class="page-title">
        <span class="fk-icon">FK</span>
        Finans Konsolu
      </h1>
      <div class="page-subtitle">Native CPS Finans Yonetim Modulu - FAZ 2 (Iskelet)</div>
    </div>
    <div class="fk-entity-bar">
      <label class="fk-entity-label">Firma:</label>
      <select id="fk-entity-select" class="fk-entity-select">
        <option value="solariz" selected>Solariz</option>
        <option value="nexgen">NexGen</option>
        <option value="pera">Pera</option>
        <option value="sahsi">Sahsi</option>
      </select>
      <span class="fk-entity-info">Secim sadece UI state - DB yazma yok</span>
    </div>
  </div>

  <div class="fk-tabs">
    <button class="fk-tab fk-tab-active" data-tab="ozet">Ozet</button>
    <button class="fk-tab" data-tab="odemeler">Odemeler</button>
    <a href="/finans/cari-odemeler" class="fk-tab fk-tab-link" data-tab="cari-odemeler" style="text-decoration:none;display:inline-flex;align-items:center;">Cari Odemeler</a>
    <a href="/finans/kredi-kartlari" class="fk-tab fk-tab-link" data-tab="kredi-karti" style="text-decoration:none;display:inline-flex;align-items:center;">Kredi Karti</a>
    <button class="fk-tab" data-tab="krediler">Krediler</button>
    <button class="fk-tab" data-tab="cekler">Cekler</button>
    <button class="fk-tab" data-tab="kasa">Kasa</button>
    <button class="fk-tab" data-tab="takvim">Takvim</button>
    <button class="fk-tab" data-tab="nakit-akisi">Nakit Akisi</button>
    <button class="fk-tab" data-tab="planlama">12 Ay Planlama</button>
  </div>

  <div class="fk-content">

    <div class="fk-panel fk-panel-active" data-panel="ozet">
      <div class="fk-grid-2">
        <div class="card fk-info-card">
          <div class="card-body">
            <div class="fk-badge">FAZ 2 - ISKELET</div>
            <h2 class="fk-h2">Yapim Asamasinda</h2>
            <p class="fk-aciklama">
              UI iskeleti tamamlandi. Veri katmani sonraki fazda eklenecek.
              Su an sadece bos sekmeler ve placeholder'lar gorunuyor.
            </p>
          </div>
        </div>
        <div class="card fk-info-card">
          <div class="card-body">
            <h3 class="fk-h3">Roadmap (FAZ 2+)</h3>
            <div class="fk-roadmap">
              <div class="fk-rm-item fk-rm-pending">
                <span class="fk-rm-no">3</span>
                <div>
                  <div class="fk-rm-ad">Cari Odemeler</div>
                  <div class="fk-rm-not">Korgun MSSQL'den senkron, ayri faz</div>
                </div>
              </div>
              <div class="fk-rm-item fk-rm-pending">
                <span class="fk-rm-no">4</span>
                <div>
                  <div class="fk-rm-ad">Kredi Karti</div>
                  <div class="fk-rm-not">Manuel + ekstre import bazli</div>
                </div>
              </div>
              <div class="fk-rm-item fk-rm-pending">
                <span class="fk-rm-no">5</span>
                <div>
                  <div class="fk-rm-ad">Krediler + Taksit</div>
                  <div class="fk-rm-not">Yeni DB sema (finans_kredi, finans_kredi_taksit)</div>
                </div>
              </div>
              <div class="fk-rm-item fk-rm-pending">
                <span class="fk-rm-no">6</span>
                <div>
                  <div class="fk-rm-ad">Takvim + Nakit Akisi</div>
                  <div class="fk-rm-not">Eski tasarim YOK, sifirdan yazilacak</div>
                </div>
              </div>
              <div class="fk-rm-item fk-rm-pending">
                <span class="fk-rm-no">7</span>
                <div>
                  <div class="fk-rm-ad">5058 Eski Sistem Kapatma</div>
                  <div class="fk-rm-not">finans.db arsive, paralel kapanir</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="odemeler">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Odemeler</h3>
          <p>Bu sekme FAZ 4'te aktif olacak. Genel odeme listesi, vade durumu, odendi/bekliyor flag'leri yer alacak.</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="cari-odemeler">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Cari Odemeler</h3>
          <p>Korgun MSSQL'den senkronize olacak. Tedarikci/Musteri cari hareketleri, mahsuplar, vade analizi.</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 6 (Korgun entegrasyonu)</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="kredi-karti">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Kredi Karti</h3>
          <p>Manuel kayit ve PDF/CSV ekstre import bazli kullanim. Sirket ve sahsi kartlar entity bazinda ayrilacak.</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 4 (Kredi Karti modulu)</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="krediler">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Krediler</h3>
          <p>Banka kredileri ve taksitler. Otomatik taksit olusturma, vade takibi, geciken taksitler.</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 5 (finans_kredi + finans_kredi_taksit tablolari)</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="cekler">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Cekler</h3>
          <p>Cek/senet takibi - Cek_Senet tablosu uzerinden. Vade, durum, ciro zinciri.</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 5</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="kasa">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Kasa</h3>
          <p>Kasa giris/cikis hareketleri, bakiye takibi. TL ve doviz hesap kartlari.</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 5 (finans_kasa_hareket tablosu)</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="takvim">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Takvim</h3>
          <p>Aylik takvim grid. Vadesi yaklasan odemeler, krediler, cekler tek ekranda.</p>
          <p class="fk-empty-not">Eski 5058 tasarimi tasinmayacak - sifirdan CPS uyumlu yeniden yazilacak. Aktivasyon: FAZ 6</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="nakit-akisi">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">Nakit Akisi</h3>
          <p>6 ay strip + gunluk akis. Beklenen gelir/gider, kritik gunler, bakiye grafik.</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 6</p>
        </div>
      </div>
    </div>

    <div class="fk-panel" data-panel="planlama">
      <div class="card fk-empty-card">
        <div class="card-body fk-empty">
          <div class="fk-empty-icon">--</div>
          <h3 class="fk-empty-h3">12 Ay Planlama</h3>
          <p>Yil x ay matris. Kategori bazli planlama (gelir/maas/kredi/vergi/fatura/kira).</p>
          <p class="fk-empty-not">Aktivasyon: FAZ 6</p>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
/* Finans Konsolu - scoped CSS (fk- prefix) */
.fk-wrap { padding: 0; }
.fk-header { display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:12px; }
.fk-icon { display:inline-block; background:#d4a52f; color:#1a1d2e; font-weight:700; font-size:13px; padding:4px 8px; border-radius:4px; margin-right:8px; }
.fk-entity-bar { display:flex; align-items:center; gap:8px; }
.fk-entity-label { font-size:12px; color:#6b7280; font-weight:600; }
.fk-entity-select {
  border:1px solid #d4a52f;
  background:#fff;
  color:#1a1d2e;
  padding:6px 12px;
  border-radius:4px;
  font-size:13px;
  font-weight:600;
  cursor:pointer;
  outline:none;
}
.fk-entity-select:focus { border-color:#b8902a; box-shadow:0 0 0 2px rgba(212,165,47,0.2); }
.fk-entity-info { font-size:10px; color:#9ca3af; font-style:italic; }

.fk-tabs {
  display:flex;
  flex-wrap:wrap;
  gap:2px;
  margin:16px 0 0 0;
  border-bottom:2px solid #e8eaf0;
}
.fk-tab {
  background:transparent;
  border:none;
  border-bottom:3px solid transparent;
  padding:10px 16px;
  font-size:13px;
  font-weight:600;
  color:#6b7280;
  cursor:pointer;
  transition:all 0.15s;
  margin-bottom:-2px;
}
.fk-tab:hover { color:#1a1d2e; background:#f8f9fc; }
.fk-tab-active {
  color:#1a1d2e;
  border-bottom-color:#d4a52f;
  background:#fef9c3;
}

.fk-content { margin-top:16px; }
.fk-panel { display:none; }
.fk-panel-active { display:block; }

.fk-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
@media (max-width:980px) { .fk-grid-2 { grid-template-columns:1fr; } }

.fk-info-card, .fk-empty-card { border-left:4px solid #d4a52f; }
.fk-badge {
  display:inline-block;
  background:#d4a52f;
  color:#1a1d2e;
  font-weight:700;
  font-size:11px;
  letter-spacing:1px;
  padding:4px 10px;
  border-radius:4px;
  margin-bottom:12px;
}
.fk-h2 { font-size:22px; font-weight:700; color:#1a1d2e; margin-bottom:8px; }
.fk-h3 { font-size:15px; font-weight:700; color:#1a1d2e; margin-bottom:12px; }
.fk-aciklama { color:#6b7280; line-height:1.6; }

.fk-roadmap { display:flex; flex-direction:column; gap:8px; }
.fk-rm-item {
  display:grid;
  grid-template-columns:32px 1fr;
  gap:10px;
  padding:10px 12px;
  background:#f8f9fc;
  border:1px solid #e8eaf0;
  border-radius:6px;
  align-items:flex-start;
}
.fk-rm-pending { opacity:0.85; }
.fk-rm-no {
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background:#d4a52f;
  color:#1a1d2e;
  width:28px;
  height:28px;
  border-radius:4px;
  font-weight:700;
  font-size:13px;
}
.fk-rm-ad { font-size:13px; font-weight:600; color:#1a1d2e; }
.fk-rm-not { font-size:11px; color:#6b7280; margin-top:2px; }

.fk-empty { text-align:center; padding:48px 16px; }
.fk-empty-icon {
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:48px;
  height:48px;
  background:#fef9c3;
  border:2px solid #d4a52f;
  border-radius:50%;
  font-weight:700;
  font-size:18px;
  color:#d4a52f;
  margin-bottom:12px;
}
.fk-empty-h3 { font-size:18px; font-weight:700; color:#1a1d2e; margin-bottom:8px; }
.fk-empty p { color:#6b7280; line-height:1.6; max-width:480px; margin:0 auto 8px; }
.fk-empty-not { font-size:11px; color:#9ca3af; font-style:italic; margin-top:8px; }
</style>

<script>
(function(){
  // Sekme degisimi
  var tabs = document.querySelectorAll('.fk-tab');
  var panels = document.querySelectorAll('.fk-panel');
  tabs.forEach(function(t){
    t.addEventListener('click', function(){
      var name = t.getAttribute('data-tab');
      tabs.forEach(function(x){ x.classList.remove('fk-tab-active'); });
      panels.forEach(function(p){ p.classList.remove('fk-panel-active'); });
      t.classList.add('fk-tab-active');
      var panel = document.querySelector('.fk-panel[data-panel="'+name+'"]');
      if (panel) panel.classList.add('fk-panel-active');
    });
  });

  // Entity secimi - sadece UI state (madde 11: DB yazma yok)
  var sel = document.getElementById('fk-entity-select');
  if (sel) {
    sel.addEventListener('change', function(){
      console.log('Entity:', sel.value, '(UI state only, DB write yok)');
    });
  }
})();
</script>
{% endblock %}