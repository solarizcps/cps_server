{% extends "base.html" %}

{% block title %}Kredi Kartlari - Finans Konsolu{% endblock %}

{% set active = 'finans' %}

{% block content %}
<div class="fk-wrap">

  <div class="page-header fk-header">
    <div class="page-header-baslik">
      <h1 class="page-title">
        <span class="fk-icon">KK</span>
        Kredi Kartlari
      </h1>
      <div class="page-subtitle">
        Kart portfoyu ozeti - FAZ 3C (READ-only, demo veri, manuel giris ileri faz)
      </div>
    </div>
    <div class="fk-konsol-back">
      <a href="/finans/konsol" class="fk-back-btn">&larr; Konsola Don</a>
    </div>
  </div>

  <!-- KPI 4 KART -->
  <div class="fk-kpi-bar">
    <div class="fk-kpi-card">
      <div class="fk-kpi-label">Toplam Limit</div>
      <div class="fk-kpi-deger" id="fk-kpi-limit">{{ '{:,.0f}'.format(kpi.toplam_limit or 0) }} TL</div>
    </div>
    <div class="fk-kpi-card">
      <div class="fk-kpi-label">Toplam Kullanim</div>
      <div class="fk-kpi-deger fk-kpi-kullanim" id="fk-kpi-kullanim">{{ '{:,.0f}'.format(kpi.toplam_kullanim or 0) }} TL</div>
      <div class="fk-kpi-sub">% {{ '{:.1f}'.format(kpi.kullanim_orani or 0) }} kullanildi</div>
    </div>
    <div class="fk-kpi-card">
      <div class="fk-kpi-label">Yaklasan Odeme (7g)</div>
      <div class="fk-kpi-deger fk-kpi-yaklasan" id="fk-kpi-yaklasan">{{ kpi.yaklasan_odeme or 0 }}</div>
      <div class="fk-kpi-sub">kart</div>
    </div>
    <div class="fk-kpi-card">
      <div class="fk-kpi-label">Geciken Kart</div>
      <div class="fk-kpi-deger fk-kpi-geciken" id="fk-kpi-geciken">{{ kpi.geciken_kart or 0 }}</div>
      <div class="fk-kpi-sub">kart</div>
    </div>
  </div>

  <!-- TABLO -->
  <div class="card fk-list-card">
    <div class="card-body" style="padding:0;">

      {% if not kartlar %}
      <div class="fk-empty">
        <div class="fk-empty-icon">--</div>
        <h3 class="fk-empty-h3">Kayit bulunamadi</h3>
        <p>Kredi karti tablosu (finans_kredi_karti) henuz bos. FAZ 3C+ ile manuel giris/import aktif olacak.</p>
        <p style="margin-top:12px;font-size:11px;color:#9ca3af;">Su an gosterilen veri DEMO mock - canli kart bilgisi DEGIL.</p>
      </div>
      {% else %}
      <table class="fk-table">
        <thead>
          <tr>
            <th>Banka</th>
            <th>Kart Adi</th>
            <th>Son 4 Hane</th>
            <th class="fk-th-num">Limit</th>
            <th class="fk-th-num">Kullanim</th>
            <th>Son Odeme</th>
            <th>Ekstre Tarihi</th>
            <th>Entity</th>
            <th>Durum</th>
            <th class="fk-th-aksiyon">Detay</th>
          </tr>
        </thead>
        <tbody>
          {% for k in kartlar %}
          <tr class="fk-row fk-row-{{ k.durum_class }}">
            <td><strong>{{ k.Banka or '-' }}</strong></td>
            <td>{{ k.KartAd }}</td>
            <td><span class="fk-monospace">**{{ k.son_4 or '****' }}</span></td>
            <td class="fk-td-num">{{ '{:,.0f}'.format(k.Limit_ or 0) }}</td>
            <td class="fk-td-num">
              {{ '{:,.0f}'.format(k.kullanim or 0) }}
              <div class="fk-progress">
                <div class="fk-progress-fill fk-progress-{{ k.durum_class }}" style="width:{{ k.kullanim_yuzde or 0 }}%"></div>
              </div>
              <div class="fk-progress-label">% {{ '{:.0f}'.format(k.kullanim_yuzde or 0) }}</div>
            </td>
            <td>{{ k.son_odeme_tarihi or '-' }}</td>
            <td>{{ k.ekstre_tarihi or '-' }}</td>
            <td>{{ k.entity or 'solariz' }}</td>
            <td>
              <span class="fk-durum fk-durum-{{ k.durum_class }}">{{ k.durum_text }}</span>
            </td>
            <td class="fk-td-aksiyon">
              <button class="fk-btn-mini" onclick="fkKartDetay({{ k.Id or 0 }}, '{{ k.KartAd|e }}', '{{ k.Banka or ''|e }}')">Detay</button>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

    </div>
  </div>

  <!-- ENTITY YETKI INFO -->
  <div class="fk-info-bar">
    <span class="fk-info-icon">i</span>
    {% if can_view_sahsi %}
      <span>Tum entity (Solariz/NexGen/Pera/Sahsi) gosteriliyor (admin yetki)</span>
    {% else %}
      <span>3 entity (Solariz/NexGen/Pera) gosteriliyor. Sahsi yalnizca admin tarafindan gorulebilir.</span>
    {% endif %}
  </div>

  <!-- DETAY MODAL -->
  <div id="fk-kart-modal" class="fk-modal" style="display:none;">
    <div class="fk-modal-content fk-modal-large">
      <div class="fk-modal-header">
        <h2 id="fk-modal-title">Kart Detayi</h2>
        <button class="fk-modal-close" onclick="fkKartKapat()">&times;</button>
      </div>
      <div class="fk-modal-body">

        <div class="fk-modal-section">
          <h3 class="fk-modal-h3">Kart Bilgileri</h3>
          <div class="fk-detail-grid">
            <div class="fk-detail-item">
              <span class="fk-detail-label">Banka:</span>
              <span id="fk-d-banka">-</span>
            </div>
            <div class="fk-detail-item">
              <span class="fk-detail-label">Kart Sahibi:</span>
              <span class="fk-muted">(placeholder - ileri faz)</span>
            </div>
            <div class="fk-detail-item">
              <span class="fk-detail-label">Hesap Kesim:</span>
              <span class="fk-muted">(placeholder)</span>
            </div>
            <div class="fk-detail-item">
              <span class="fk-detail-label">Son Odeme:</span>
              <span class="fk-muted">(placeholder)</span>
            </div>
          </div>
        </div>

        <div class="fk-modal-section">
          <h3 class="fk-modal-h3">Son Hareketler <span class="fk-muted fk-small">(mock veri - FAZ 3C+ canli olacak)</span></h3>
          <table class="fk-mini-table">
            <thead>
              <tr><th>Tarih</th><th>Islem</th><th class="fk-th-num">Tutar</th><th>Taksit</th></tr>
            </thead>
            <tbody>
              <tr><td>2026-05-15</td><td>Migros AVM</td><td class="fk-td-num">485.20</td><td class="fk-muted">-</td></tr>
              <tr><td>2026-05-12</td><td>Akaryakit-Shell</td><td class="fk-td-num">1,250.00</td><td class="fk-muted">-</td></tr>
              <tr><td>2026-05-08</td><td>Vatan Bilgisayar</td><td class="fk-td-num">8,499.00</td><td>3/12</td></tr>
              <tr><td>2026-05-03</td><td>Restoran-Nusr-Et</td><td class="fk-td-num">3,200.00</td><td class="fk-muted">-</td></tr>
            </tbody>
          </table>
          <p class="fk-muted fk-small" style="margin-top:8px;">Yukaridaki hareketler DEMO veridir. Gercek hareket bilgisi finans_kredi_karti_hareket tablosundan FAZ 3C+ ile cekilecek.</p>
        </div>

        <div class="fk-modal-section">
          <h3 class="fk-modal-h3">Taksit Ozeti <span class="fk-muted fk-small">(placeholder)</span></h3>
          <p class="fk-muted">Aktif taksit bilgisi gosterilecek - FAZ 3C+ canli.</p>
        </div>

      </div>
      <div class="fk-modal-footer">
        <button class="fk-btn-secondary" onclick="fkKartKapat()">Kapat</button>
      </div>
    </div>
  </div>

</div>

<style>
/* === FAZ 3C - Kredi Kartlari - scoped fk- prefix === */
.fk-wrap { padding:0; }
.fk-header { display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:12px; }
.fk-icon { display:inline-block; background:#d4a52f; color:#1a1d2e; font-weight:700; font-size:13px; padding:4px 8px; border-radius:4px; margin-right:8px; }
.fk-back-btn {
  display:inline-block; padding:6px 12px; background:transparent;
  color:#6b7280; border:1px solid #e8eaf0; border-radius:4px;
  font-size:12px; font-weight:600; text-decoration:none; transition:all 0.15s;
}
.fk-back-btn:hover { background:#fef9c3; color:#1a1d2e; border-color:#d4a52f; }

.fk-kpi-bar { display:grid; grid-template-columns:repeat(4, 1fr); gap:12px; margin-top:16px; }
@media (max-width:760px) { .fk-kpi-bar { grid-template-columns:repeat(2, 1fr); } }
.fk-kpi-card {
  background:#fff; border:1px solid #e8eaf0; border-left:4px solid #d4a52f;
  border-radius:6px; padding:12px 14px;
}
.fk-kpi-label { font-size:11px; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
.fk-kpi-deger { font-size:22px; font-weight:700; color:#1a1d2e; margin-top:4px; }
.fk-kpi-sub { font-size:11px; color:#9ca3af; margin-top:2px; }
.fk-kpi-kullanim { color:#dc2626; }
.fk-kpi-yaklasan { color:#d97706; }
.fk-kpi-geciken { color:#dc2626; }

.fk-list-card { margin-top:16px; }
.fk-table { width:100%; border-collapse:collapse; font-size:13px; }
.fk-table th {
  background:#f8f9fc; padding:10px 12px; text-align:left;
  font-size:11px; font-weight:700; color:#6b7280;
  text-transform:uppercase; letter-spacing:0.5px; border-bottom:2px solid #e8eaf0;
}
.fk-th-num { text-align:right; }
.fk-th-aksiyon { text-align:center; }
.fk-table td { padding:10px 12px; border-bottom:1px solid #f1f3f6; color:#1a1d2e; }
.fk-td-num { text-align:right; font-variant-numeric:tabular-nums; }
.fk-td-aksiyon { text-align:center; }
.fk-row:hover { background:#fef9c3; }
.fk-monospace { font-family:'Courier New', monospace; font-size:12px; }

.fk-progress { width:100%; height:6px; background:#f1f3f6; border-radius:3px; margin-top:4px; overflow:hidden; }
.fk-progress-fill { height:100%; transition:width 0.3s; }
.fk-progress-normal     { background:#16a34a; }
.fk-progress-yuksek_risk { background:#d97706; }
.fk-progress-kritik     { background:#dc2626; }
.fk-progress-gecikmis   { background:#7c2d12; }
.fk-progress-label { font-size:10px; color:#9ca3af; margin-top:2px; }

.fk-durum {
  display:inline-block; padding:2px 8px; border-radius:3px;
  font-size:10px; font-weight:700; letter-spacing:0.5px;
}
.fk-durum-normal      { background:#dcfce7; color:#166534; }
.fk-durum-yuksek_risk { background:#fef3c7; color:#92400e; }
.fk-durum-kritik      { background:#fee2e2; color:#dc2626; }
.fk-durum-gecikmis    { background:#7c2d12; color:#fff; }

.fk-btn-mini {
  padding:4px 10px; background:transparent; border:1px solid #d4a52f;
  color:#d4a52f; border-radius:3px; font-size:11px; font-weight:600; cursor:pointer;
}
.fk-btn-mini:hover { background:#d4a52f; color:#1a1d2e; }
.fk-btn-secondary {
  padding:7px 16px; background:transparent; color:#6b7280;
  border:1px solid #e8eaf0; border-radius:4px; font-weight:600; font-size:12px; cursor:pointer;
}
.fk-btn-secondary:hover { background:#f8f9fc; }

.fk-info-bar {
  margin-top:14px; padding:8px 12px; background:#eff6ff; border:1px solid #bfdbfe;
  border-radius:4px; font-size:12px; color:#1e40af; display:flex; align-items:center; gap:8px;
}
.fk-info-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:18px; height:18px; background:#1e40af; color:#fff;
  border-radius:50%; font-size:11px; font-weight:700;
}

.fk-empty { text-align:center; padding:48px 16px; }
.fk-empty-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:48px; height:48px; background:#fef9c3; border:2px solid #d4a52f;
  border-radius:50%; font-weight:700; font-size:18px; color:#d4a52f; margin-bottom:12px;
}
.fk-empty-h3 { font-size:16px; font-weight:700; color:#1a1d2e; margin-bottom:6px; }
.fk-empty p { color:#6b7280; font-size:13px; }

.fk-modal {
  position:fixed; top:0; left:0; right:0; bottom:0;
  background:rgba(0,0,0,0.5); z-index:9999;
  display:flex; align-items:center; justify-content:center;
}
.fk-modal-content {
  background:#fff; border-radius:8px;
  max-width:600px; width:90%; max-height:85vh; overflow:auto;
  border-top:4px solid #d4a52f;
}
.fk-modal-large { max-width:760px; }
.fk-modal-header { padding:16px; border-bottom:1px solid #e8eaf0; display:flex; justify-content:space-between; align-items:center; }
.fk-modal-header h2 { font-size:18px; font-weight:700; color:#1a1d2e; margin:0; }
.fk-modal-close { background:none; border:none; font-size:24px; color:#6b7280; cursor:pointer; padding:0; width:32px; height:32px; }
.fk-modal-body { padding:16px; }
.fk-modal-footer { padding:12px 16px; border-top:1px solid #e8eaf0; text-align:right; }

.fk-modal-section { margin-bottom:18px; padding-bottom:14px; border-bottom:1px solid #f1f3f6; }
.fk-modal-section:last-child { border-bottom:none; }
.fk-modal-h3 { font-size:13px; font-weight:700; color:#1a1d2e; margin-bottom:10px; text-transform:uppercase; letter-spacing:0.5px; }

.fk-detail-grid { display:grid; grid-template-columns:repeat(2, 1fr); gap:10px; }
.fk-detail-item { display:flex; flex-direction:column; gap:2px; font-size:13px; }
.fk-detail-label { font-size:11px; color:#6b7280; font-weight:600; }

.fk-mini-table { width:100%; border-collapse:collapse; font-size:12px; }
.fk-mini-table th { background:#f8f9fc; padding:6px 10px; text-align:left; font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; }
.fk-mini-table td { padding:6px 10px; border-bottom:1px solid #f1f3f6; }

.fk-muted { color:#9ca3af; font-style:italic; }
.fk-small { font-size:11px; }
</style>

<script>
(function(){
  window.fkKartDetay = function(id, kartAd, banka) {
    document.getElementById('fk-modal-title').textContent = kartAd + ' - ' + banka;
    document.getElementById('fk-d-banka').textContent = banka || '-';
    document.getElementById('fk-kart-modal').style.display = 'flex';
  };
  window.fkKartKapat = function() {
    document.getElementById('fk-kart-modal').style.display = 'none';
  };
  document.getElementById('fk-kart-modal').addEventListener('click', function(e){
    if (e.target === this) fkKartKapat();
  });
})();
</script>
{% endblock %}