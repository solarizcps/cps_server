{% extends "base.html" %}
{% set active = 'enjeksiyon' %}
{% set aktif_grup = 'uretim' %}

{% block title %}Enjeksiyon Takip - Yönetim{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/enjeksiyon.css') }}?v=f6_20260513">

<div class="enj-wrap">

  <div class="enj-page-head">
    <h2>Enjeksiyon Takip <span class="sub">/ Yönetim Paneli</span></h2>
  </div>

  <div class="enj-row1">
    <div class="enj-lbl">MAKİNE SEÇ<small>Açık / Kapalı</small></div>

    {% for m in makineler %}
    <div class="enj-m" data-makine-id="{{ m.id }}">
      <div class="h">
        <div class="name"><span class="no">{{ m.sira }}</span>MAKİNE</div>
        {% if m.aktif %}
        <button type="button" class="enj-tick" title="Kapat">&check;</button>
        {% else %}
        <button type="button" class="enj-toggle" title="Aç"></button>
        {% endif %}
      </div>
      <div class="sub">{{ m.istasyon_sayisi }} İSTASYON</div>
      <div class="enj-ist">
        {% for i in range(1, m.istasyon_sayisi + 1) %}
        <button type="button" class="b {% if i in m.aktif_istasyonlar %}on{% endif %}" data-ist="{{ i }}">{{ i }}</button>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="enj-fwrap">
    <div class="enj-form">
      <div class="enj-fr">
        <div class="enj-fld"><label>Tarih</label><input type="text" value="{{ bugun }}" readonly></div>
        <div class="enj-fld"><label>Vardiya</label>
          <select>
            <option>GÜNDÜZ (08:00-20:00)</option>
            <option>GECE (20:00-08:00)</option>
            <option>MESAİ</option>
          </select>
        </div>
        <div class="enj-fld"><label>Emir / Sipariş</label>
          <select><option value="">Seçiniz</option></select>
        </div>
        <div class="enj-fld"><label>Kalıp No</label>
          <select><option value="">Seçiniz</option></select>
        </div>
        <div class="enj-fld"><label>Renk</label>
          <select><option value="">Seçiniz</option></select>
        </div>
        <div class="enj-fld"><label>Bağlı Kalıp (adet)</label><input type="number" min="0" placeholder="0"></div>
        <div class="enj-fld"><label>Kalıp Başı Çift</label><input type="number" min="0" placeholder="0"></div>
      </div>
      <div class="enj-fr">
        <div class="enj-fld"><label>Yükseklik (mm)</label><input type="number" step="0.1" placeholder="0,0"></div>
        <div class="enj-fld"><label>Boş Ağırlık (gr)</label><input type="number" step="0.1" placeholder="0,0"></div>
        <div class="enj-fld"><label>Fire Ağırlık (gr)</label><input type="number" step="0.1" placeholder="0,0"></div>
        <div class="enj-fld"><label>Teorik Çift / Tur</label><input type="number" class="calc" readonly placeholder="—"></div>
        <div class="enj-fld"><label>Personel Sayısı</label><input type="number" min="0" placeholder="0"></div>
        <div class="enj-fld"><label class="g">Teorik Çift (günlük)</label><input type="number" class="gh" readonly placeholder="—"></div>
        <div class="enj-fld"><label class="b">Net Çıkan Çift (günlük)</label><input type="number" class="bh" readonly placeholder="—"></div>
      </div>
    </div>
    <div class="enj-urun">
      <div class="et">SEÇİLİ ÜRÜN</div>
      <div class="ph">ürün görseli</div>
      <div class="ad bos">Kalıp seçiniz</div>
      <div class="alt">—</div>
    </div>
  </div>

  <div class="enj-main">
    <div class="enj-tbl-card">
      <table class="enj-tbl">
        <thead><tr><th>SAAT</th><th>TUR (ADET)</th><th>DURUM</th><th>DURUŞ / AKSAMA SEBEBİ</th></tr></thead>
        <tbody>
          {% set saatler = [(8,9),(9,10),(10,11),(11,12),(12,13),(13,14),(14,15),(15,16),(16,17),(17,18),(18,19),(19,20)] %}
          {% for bas, bit in saatler %}
          <tr data-saat="{{ '%02d:00'|format(bas) }}">
            <td>{{ '%02d:00 - %02d:00'|format(bas, bit) }}</td>
            <td><input type="number" class="tur-inp" min="0" placeholder="0"></td>
            <td>
              <select class="durum-sel">
                <option value="calisiyor">ÇALIŞIYOR</option>
                <option value="durus">DURUŞ</option>
                <option value="yavas">YAVAŞ</option>
              </select>
            </td>
            <td>
              <select class="aks-sel">
                <option value="">—</option>
                {% for a in aksama_sebepleri %}
                <option value="{{ a.id }}">{{ a.ad }}</option>
                {% endfor %}
              </select>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="enj-ozet">
      <h4>GÜNLÜK ÖZET</h4>
      <div class="or"><span class="l">TOPLAM TUR</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">TEORİK ÇİFT</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">FİRE (ÇİFT)</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">KORGUN KAPATTIĞI</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">FARK</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">FİRE ORANI</span><span class="v muted">—</span></div>
    </div>
  </div>

  <div class="enj-gs">
    <h4>GÜN SONU <small>tek defa girilir</small></h4>
    <div class="enj-gsr">
      <div class="enj-fld"><label>Toplam Fire (çift)</label><input type="number" min="0" placeholder="0"></div>
      <div class="enj-fld"><label>Fire Ağırlık (kg)</label><input type="number" step="0.01" placeholder="0,00"></div>
      <div class="enj-fld"><label>Fire Ağırlık (gr)</label><input type="number" step="1" placeholder="0"></div>
    </div>
    <div class="enj-fzone">
      <div class="enj-fz"><div class="ic">&#x1F4F7;</div><b>TARTI FOTOĞRAFI</b>tıkla &middot; yükle</div>
      <div class="enj-fz"><div class="ic">&#x1F5A5;</div><b>PLC EKRAN FOTOĞRAFI</b>tıkla &middot; yükle</div>
    </div>
    <div class="enj-fld"><label>Gün Sonu Notu</label><textarea class="enj-note" placeholder="Vardiya sonu açıklama, aksama detayı, vb."></textarea></div>
  </div>

  <div class="enj-act">
    <button type="button" class="enj-btn">GEÇMİŞ KAYITLAR</button>
    <button type="button" class="enj-btn kaydet">KAYDET</button>
  </div>

</div>
{% endblock %}
