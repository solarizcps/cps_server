{% extends "base.html" %}
{% set active = 'enjeksiyon' %}
{% set aktif_grup = 'uretim' %}

{% block title %}Enjeksiyon Takip - Yönetim{% endblock %}

{% block content %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/enjeksiyon.css') }}?v=f66_20260513">

<div class="enj-wrap">

  <div class="enj-page-head">
    <h2>Enjeksiyon Takip <span class="sub">/ Yönetim Paneli</span></h2>
    <div class="enj-vrd-badge">Vardiya: <b>{{ vardiya_metin }}</b></div>
  </div>

  <div class="enj-mak-secim">
    <div class="enj-lbl">MAKİNE SEÇ<small>Açık / Kapalı</small></div>
    {% for m in makineler %}
    <div class="enj-mak-kart {% if m.id == secili_makine_id %}aktif{% endif %}" data-makine-id="{{ m.id }}">
      <div class="ad"><span class="no">{{ m.sira }}</span>MAKİNE</div>
      {% if m.aktif %}
      <div class="enj-tick" title="Açık">&check;</div>
      {% else %}
      <div class="enj-toggle" title="Kapalı"></div>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  {% for m in makineler %}
  <div class="enj-mak-panel {% if m.id == secili_makine_id %}aktif{% endif %}" data-makine-id="{{ m.id }}">
    <div class="basl">
      <div class="lbl"><span class="no">{{ m.sira }}</span>MAKİNE<span class="sub">{{ m.istasyon_sayisi }} İSTASYON</span></div>
      <div class="tools">
        <button type="button" class="enj-mini-btn" data-toplu="a">A TÜMÜ</button>
        <button type="button" class="enj-mini-btn" data-toplu="b">B TÜMÜ</button>
        <button type="button" class="enj-mini-btn kapat" data-toplu="x">KAPAT</button>
        {% if m.aktif %}
        <div class="enj-tick">&check;</div>
        {% else %}
        <div class="enj-toggle"></div>
        {% endif %}
      </div>
    </div>
    <div class="enj-ist-list {% if m.istasyon_sayisi == 6 %}k6{% endif %}">
      {% for i in range(1, m.istasyon_sayisi + 1) %}
      {% set ka = i|string + 'A' %}{% set kb = i|string + 'B' %}
      <div class="enj-ist-cell">
        <div class="no">İST {{ i }}</div>
        <div class="ab">
          <button type="button" class="s {% if ka in m.aktif_slot_keys %}on{% endif %}" data-slot="A">A</button>
          <button type="button" class="s {% if kb in m.aktif_slot_keys %}on{% endif %}" data-slot="B">B</button>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}

  <div class="enj-fwrap">
    <div class="enj-form">
      <div class="enj-fr">
        <div class="enj-fld"><label>Tarih</label><input type="text" value="{{ bugun }}" readonly></div>
        <div class="enj-fld"><label>Vardiya</label>
          <select onchange="window.location='?vardiya='+this.value+'&makine={{ secili_makine_id }}'">
            <option value="gunduz" {% if vardiya == 'gunduz' %}selected{% endif %}>GÜNDÜZ (07:00-17:00)</option>
            <option value="gece"   {% if vardiya == 'gece' %}selected{% endif %}>GECE (17:00-07:00)</option>
            <option value="mesai"  {% if vardiya == 'mesai' %}selected{% endif %}>MESAİ</option>
          </select>
        </div>
        <div class="enj-fld"><label>Emir / Sipariş</label><select><option>Seçiniz</option></select></div>
        <div class="enj-fld"><label>Kalıp No</label><select><option>Seçiniz</option></select></div>
        <div class="enj-fld"><label>Renk</label><select><option>Seçiniz</option></select></div>
        <div class="enj-fld"><label>Bağlı Kalıp (adet)</label><input type="number" placeholder="0"></div>
        <div class="enj-fld"><label>Kalıp Başı Çift</label><input type="number" placeholder="0"></div>
      </div>
      <div class="enj-fr">
        <div class="enj-fld"><label>Yükseklik (mm)</label><input type="number" step="0.1" placeholder="0,0"></div>
        <div class="enj-fld"><label>Boş Ağırlık (gr)</label><input type="number" step="0.1" placeholder="0,0"></div>
        <div class="enj-fld"><label>Fire Ağırlık (gr)</label><input type="number" step="0.1" placeholder="0,0"></div>
        <div class="enj-fld"><label>Teorik Çift / Tur</label><input type="number" class="calc" readonly placeholder="—"></div>
        <div class="enj-fld"><label>Personel Sayısı</label><input type="number" placeholder="0"></div>
        <div class="enj-fld"><label class="g">Teorik Çift (günlük)</label><input type="number" class="gh" readonly placeholder="—"></div>
        <div class="enj-fld"><label class="b">Net Çıkan Çift (günlük)</label><input type="number" class="bh" readonly placeholder="—"></div>
      </div>
    </div>
    <div class="enj-urun">
      <div class="et">SEÇİLİ ÜRÜN</div>
      <div class="ph">ürün görseli</div>
      <div class="ad bos">Kalıp seçiniz</div>
      <div class="alt">—</div>
    </div>
  </div>

  <div class="enj-main">
    <div class="enj-tbl-card">
      <div class="enj-tbl-basl">SAATLİK TABLO &middot; <b>{{ vardiya_metin }}</b></div>
      <table class="enj-tbl">
        <thead><tr><th>SAAT</th><th>TUR (ADET)</th><th>DURUM</th><th>AKSAMA / SEBEBİ</th></tr></thead>
        <tbody>
          {% if vardiya == 'mesai' %}
          <tr><td colspan="4" class="enj-mesai-info">Mesai saatleri sonraki fazda yapılandırılacak. Gündüz veya gece vardiyasını seçiniz.</td></tr>
          {% else %}
          {% for bas, bit in saatler %}
          <tr data-saat-bas="{{ bas }}">
            <td>{{ '%02d:00 - %02d:00'|format(bas, bit) }}</td>
            <td><input type="number" class="tur-inp" min="0" placeholder="0"></td>
            <td><select class="durum-sel"><option value="calisiyor">ÇALIŞIYOR</option><option value="durus">DURUŞ</option><option value="yavas">YAVAŞ</option></select></td>
            <td><select class="aks-sel"><option value="">—</option>{% for a in aksama_sebepleri %}<option value="{{ a.id }}">{{ a.ad }}</option>{% endfor %}</select></td>
          </tr>
          {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>

    <div class="enj-ozet">
      <h4>GÜNLÜK ÖZET</h4>
      <div class="or"><span class="l">TOPLAM TUR</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">TEORİK ÇİFT</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">NET ÇIKAN ÇİFT</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">FİRE (ÇİFT)</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">KORGUN KAPATTIĞI</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">FARK</span><span class="v muted">—</span></div>
      <div class="or"><span class="l">FİRE ORANI (%)</span><span class="v muted">—</span></div>
    </div>
  </div>

  <div class="enj-gs">
    <h4>GÜN SONU BİLGİLERİ</h4>
    <div class="enj-gs-yatay">
      <div class="enj-fld"><label>TOPLAM FİRE (ÇİFT)</label><input type="number" min="0" placeholder="0"></div>
      <div class="enj-fld"><label>FİRE (KG)</label><input type="number" step="0.01" placeholder="0,000"></div>
      <div class="enj-fld"><label>FİRE (GR)</label><input type="number" step="1" placeholder="0"></div>
      <div class="enj-gs-foto"><label>TARTI FOTOĞRAFI</label><div class="zone">&#x1F4F7; Yükle</div></div>
      <div class="enj-gs-foto"><label>PLC EKRAN FOTOĞRAFI</label><div class="zone">&#x1F5A5; Yükle</div></div>
      <div class="enj-gs-not"><label>GÜN SONU NOTU</label><textarea class="enj-note" placeholder="Açıklama giriniz..."></textarea></div>
    </div>
  </div>

  <div class="enj-act">
    <button type="button" class="enj-btn"><span>&#x1F551;</span>GEÇMİŞ KAYITLAR</button>
    <button type="button" class="enj-btn kaydet"><span>&#x1F4BE;</span>KAYDET</button>
  </div>

</div>

<script src="{{ url_for('static', filename='js/enjeksiyon.js') }}?v=f66_20260513"></script>
{% endblock %}
